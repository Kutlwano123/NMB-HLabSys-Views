@{
    ViewData["Title"] = "All Users";
    ViewData["ActivePage"] = "Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>

        /* ================= HEADER ================= */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 22px;
            flex-wrap: wrap;
            gap: 12px;
        }

            .page-header h2 { margin: 0; font-size: 22px; }

            .page-header p {
                font-size: 12px;
                color: var(--text-light);
                margin-top: 4px;
            }

        /* ================= TOOLBAR ================= */
        .users-toolbar {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: center;
            margin-bottom: 16px;
        }

            .users-toolbar .search-wrap {
                flex: 1;
                min-width: 220px;
                position: relative;
            }

                .users-toolbar .search-wrap .bi-search {
                    position: absolute;
                    left: 12px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: var(--text-light);
                    font-size: 13px;
                }

                .users-toolbar input[type="search"] {
                    width: 100%;
                    padding: 10px 14px 10px 34px;
                    border: 1px solid var(--border);
                    border-radius: 10px;
                    font-size: 13px;
                    box-sizing: border-box;
                }

            .users-toolbar select {
                padding: 10px 14px;
                border: 1px solid var(--border);
                border-radius: 10px;
                font-size: 13px;
                background: #fff;
                min-width: 160px;
            }

        .results-meta {
            font-size: 12px;
            color: var(--text-light);
            margin-bottom: 10px;
        }

        /* ================= TABLE ================= */
        .users-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: visible;
        }

        table.users-table {
            width: 100%;
            border-collapse: collapse;
            margin: 0;
        }

            table.users-table th {
                text-align: left;
                font-size: 11px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                color: var(--text-light);
                padding: 14px 16px;
                border-bottom: 1px solid var(--border);
                white-space: nowrap;
            }

            table.users-table th.sortable { cursor: pointer; user-select: none; }

                table.users-table th.sortable .bi {
                    font-size: 10px;
                    opacity: 0.5;
                    margin-left: 4px;
                }

                table.users-table th.sortable.sort-active .bi { opacity: 1; }

            table.users-table td {
                padding: 12px 16px;
                border-bottom: 1px solid var(--border);
                vertical-align: middle;
                font-size: 13px;
            }

            table.users-table tbody tr:last-child td { border-bottom: none; }
            table.users-table tbody tr:hover { background: var(--bg); }
            table.users-table tr.row-hidden { display: none; }
            table.users-table tr.page-hidden { display: none; }

        .name-cell { display: flex; align-items: center; gap: 12px; }

        .avatar-circle {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .name-text { font-weight: 600; font-size: 13px; line-height: 1.3; }
        .email-text { font-size: 11px; color: var(--text-light); }

        /* --- Role badges --- */
        .role-badge {
            font-size: 11px;
            font-weight: 600;
            padding: 5px 10px;
            border-radius: 20px;
            display: inline-block;
            white-space: nowrap;
        }

        .role-admin { background: var(--accent-pale); color: var(--accent); }
        .role-doctor { background: #e8f5e9; color: #2e7d32; }
        .role-technician { background: #eef2f7; color: #3b4a5a; }
        .role-manager { background: #f1e8fb; color: #6c3fa0; }
        .role-patient { background: #e0f2f1; color: #00695c; }

        /* --- Status badges --- */
        .status-badge {
            font-size: 11px;
            font-weight: 600;
            padding: 5px 10px;
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            white-space: nowrap;
        }

            .status-badge::before {
                content: "";
                width: 6px;
                height: 6px;
                border-radius: 50%;
                display: inline-block;
            }

        .status-active { background: #eafaf1; color: #27ae60; }
        .status-active::before { background: #27ae60; }
        .status-inactive { background: #f1f2f4; color: #6b7280; }
        .status-inactive::before { background: #6b7280; }
        .status-pending { background: #fff8e6; color: #d68910; }
        .status-pending::before { background: #d68910; }

        /* --- Action buttons --- */
        .action-cell { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }

        .icon-action {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: 1px solid var(--border);
            background: #fff;
            color: var(--text-mid);
            border-radius: 8px;
            padding: 6px 10px;
            font-size: 12px;
            cursor: pointer;
            text-decoration: none;
            white-space: nowrap;
        }

            .icon-action:hover { border-color: var(--accent); color: var(--accent); }
            .icon-action:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

        /* --- Kebab / overflow menu --- */
        .overflow-wrap { position: relative; }

        .overflow-btn {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--text-mid);
        }

            .overflow-btn:hover { border-color: var(--accent); color: var(--accent); }

        .overflow-menu {
            position: absolute;
            right: 0;
            top: calc(100% + 4px);
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.12);
            min-width: 160px;
            z-index: 40;
            display: none;
            overflow: hidden;
        }

            .overflow-menu.open { display: block; }

            .overflow-menu button {
                width: 100%;
                text-align: left;
                padding: 10px 14px;
                border: none;
                background: none;
                font-size: 12px;
                cursor: pointer;
                display: flex;
                align-items: center;
                gap: 8px;
                color: #c0392b;
            }

                .overflow-menu button:hover { background: #fdf1f0; }

        /* ================= EMPTY STATE ================= */
        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: var(--text-light);
        }

            .empty-state i { font-size: 28px; display: block; margin-bottom: 10px; }
            .empty-state p { font-size: 13px; margin: 0; }

        /* ================= PAGINATION ================= */
        .pagination-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 16px;
            flex-wrap: wrap;
            gap: 10px;
        }

            .pagination-bar .page-size select {
                padding: 6px 10px;
                border: 1px solid var(--border);
                border-radius: 8px;
                font-size: 12px;
                background: #fff;
            }

            .pagination-bar .page-controls {
                display: flex;
                align-items: center;
                gap: 8px;
                font-size: 12px;
                color: var(--text-mid);
            }

            .pagination-bar button {
                border: 1px solid var(--border);
                background: #fff;
                border-radius: 8px;
                width: 30px;
                height: 30px;
                cursor: pointer;
                color: var(--text-mid);
            }

                .pagination-bar button:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
                .pagination-bar button:disabled { opacity: 0.4; cursor: not-allowed; }

        /* ================= MODALS ================= */
        .modal-overlay-users {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(20,24,30,0.45);
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

            .modal-overlay-users.open { display: flex; }

        .confirm-modal {
            background: #fff;
            border-radius: 14px;
            width: 90%;
            max-width: 380px;
            padding: 22px;
            text-align: left;
            box-shadow: 0 20px 50px rgba(0,0,0,0.2);
        }

            .confirm-modal .modal-icon {
                width: 44px;
                height: 44px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
                margin-bottom: 12px;
            }

            .confirm-modal h4 {
                font-family: 'DM Serif Display', serif;
                margin: 0 0 6px;
                font-size: 17px;
            }

            .confirm-modal p {
                font-size: 13px;
                color: var(--text-mid);
                line-height: 1.5;
                margin: 0;
            }

            .confirm-modal .safety-check {
                display: flex;
                align-items: flex-start;
                gap: 8px;
                font-size: 12px;
                color: var(--text-mid);
                margin-top: 14px;
                background: #fdf1f0;
                border: 1px solid rgba(192,57,43,0.2);
                border-radius: 8px;
                padding: 10px 12px;
            }

            .confirm-modal .modal-actions {
                display: flex;
                gap: 10px;
                margin-top: 20px;
            }

                .confirm-modal .modal-actions button {
                    flex: 1;
                    padding: 10px;
                    border-radius: 8px;
                    border: 1px solid var(--border);
                    background: #fff;
                    cursor: pointer;
                    font-size: 13px;
                }

                .confirm-modal .modal-actions button.primary {
                    background: var(--accent);
                    color: #fff;
                    border-color: var(--accent);
                }

                .confirm-modal .modal-actions button.primary.destructive {
                    background: #c0392b;
                    border-color: #c0392b;
                }

                .confirm-modal .modal-actions button:disabled {
                    opacity: 0.5;
                    cursor: not-allowed;
                }

        /* ================= TOAST ================= */
        .toast-stack {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1100;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .toast-msg {
            background: #2e2e2e;
            color: #fff;
            padding: 10px 16px;
            border-radius: 8px;
            font-size: 13px;
            opacity: 0;
            transform: translateY(6px);
            transition: 0.25s ease;
        }

            .toast-msg.show { opacity: 1; transform: translateY(0); }

        .sr-only {
            position: absolute;
            width: 1px; height: 1px;
            padding: 0; margin: -1px;
            overflow: hidden;
            clip: rect(0,0,0,0);
            white-space: nowrap;
            border: 0;
        }

        @@media (max-width: 800px) {
            table.users-table thead { display: none; }
            table.users-table, table.users-table tbody, table.users-table tr, table.users-table td { display: block; width: 100%; }
            table.users-table tr { padding: 12px 16px; border-bottom: 1px solid var(--border); }
            table.users-table td { border: none; padding: 6px 0; }
        }

    </style>
}

