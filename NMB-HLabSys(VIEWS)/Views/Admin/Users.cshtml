<!-- TOASTS -->
<div class="toast-stack" id="toastStack" aria-live="polite"></div>

@section Scripts {
    <script>
        (function() {

            // ---------- Toast helper ----------
            function showToast(message) {
                var stack = document.getElementById('toastStack');
                var toast = document.createElement('div');
                toast.className = 'toast-msg';
                toast.textContent = message;
                stack.appendChild(toast);
                requestAnimationFrame(function() { toast.classList.add('show'); });
                setTimeout(function() {
                    toast.classList.remove('show');
                    setTimeout(function() { toast.remove(); }, 300);
                }, 2500);
            }

            var ROLE_LABELS = { admin: 'Admin', doctor: 'Doctor', technician: 'Lab Technician', manager: 'Lab Manager', patient: 'Patient' };

            var searchInput = document.getElementById('userSearch');
            var roleFilter = document.getElementById('roleFilter');
            var statusFilter = document.getElementById('statusFilter');
            var pageSizeSelect = document.getElementById('pageSize');
            var prevPageBtn = document.getElementById('prevPage');
            var nextPageBtn = document.getElementById('nextPage');
            var pageIndicator = document.getElementById('pageIndicator');
            var resultsMeta = document.getElementById('resultsMeta');
            var emptyState = document.getElementById('emptyState');
            var tbody = document.querySelector('#usersTable tbody');

            var currentPage = 1;
            var sortState = { key: null, dir: 1 };

            // ---------- Filtering + sorting + pagination pipeline ----------
            function getFilteredRows() {
                var query = searchInput.value.trim().toLowerCase();
                var role = roleFilter.value;
                var status = statusFilter.value;

                return Array.prototype.slice.call(tbody.querySelectorAll('.user-row')).filter(function(row) {
                    var matchesRole = !role || row.getAttribute('data-role') === role;
                    var matchesStatus = !status || row.getAttribute('data-status') === status;
                    var matchesQuery = !query || row.getAttribute('data-name').indexOf(query) !== -1;
                    return matchesRole && matchesStatus && matchesQuery;
                });
            }

            function sortRows(rows) {
                if (!sortState.key) return rows;
                var key = sortState.key;
                return rows.slice().sort(function(a, b) {
                    var av = key === 'name' ? a.getAttribute('data-name') : a.getAttribute('data-' + key);
                    var bv = key === 'name' ? b.getAttribute('data-name') : b.getAttribute('data-' + key);
                    if (av < bv) return -1 * sortState.dir;
                    if (av > bv) return 1 * sortState.dir;
                    return 0;
                });
            }

            function render() {
                var allRows = Array.prototype.slice.call(tbody.querySelectorAll('.user-row'));
                var filtered = sortRows(getFilteredRows());
                var pageSize = parseInt(pageSizeSelect.value, 10);
                var totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
                if (currentPage > totalPages) currentPage = totalPages;

                var start = (currentPage - 1) * pageSize;
                var end = start + pageSize;
                var pageRows = filtered.slice(start, end);

                allRows.forEach(function(row) { row.classList.add('row-hidden'); });
                pageRows.forEach(function(row) { row.classList.remove('row-hidden'); });

                emptyState.style.display = filtered.length === 0 ? 'block' : 'none';
                document.querySelector('.users-card table').style.display = filtered.length === 0 ? 'none' : 'table';

                var totalUsers = allRows.length;
                if (filtered.length === 0) {
                    resultsMeta.textContent = 'Showing 0 of ' + totalUsers + ' users';
                } else {
                    resultsMeta.textContent = 'Showing ' + (start + 1) + '–' + Math.min(end, filtered.length) + ' of ' + filtered.length + ' users' + (filtered.length !== totalUsers ? ' (filtered from ' + totalUsers + ')' : '');
                }

                pageIndicator.textContent = 'Page ' + currentPage + ' of ' + totalPages;
                prevPageBtn.disabled = currentPage <= 1;
                nextPageBtn.disabled = currentPage >= totalPages;
            }

            searchInput.addEventListener('input', function() { currentPage = 1; render(); });
            roleFilter.addEventListener('change', function() { currentPage = 1; render(); });
            statusFilter.addEventListener('change', function() { currentPage = 1; render(); });
            pageSizeSelect.addEventListener('change', function() { currentPage = 1; render(); });

            prevPageBtn.addEventListener('click', function() { if (currentPage > 1) { currentPage--; render(); } });
            nextPageBtn.addEventListener('click', function() { currentPage++; render(); });

            document.querySelectorAll('#usersTable th.sortable').forEach(function(th) {
                th.addEventListener('click', function() {
                    var key = th.getAttribute('data-sort');
                    sortState.dir = (sortState.key === key) ? sortState.dir * -1 : 1;
                    sortState.key = key;
                    document.querySelectorAll('#usersTable th.sortable').forEach(function(h) { h.classList.remove('sort-active'); });
                    th.classList.add('sort-active');
                    currentPage = 1;
                    render();
                });
            });

            render();

            // ---------- Kebab / overflow menus ----------
            document.querySelectorAll('[data-kebab]').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    var menu = btn.nextElementSibling;
                    var isOpen = menu.classList.contains('open');
                    document.querySelectorAll('.overflow-menu.open').forEach(function(m) { m.classList.remove('open'); });
                    document.querySelectorAll('[data-kebab]').forEach(function(b) { b.setAttribute('aria-expanded', 'false'); });
                    if (!isOpen) {
                        menu.classList.add('open');
                        btn.setAttribute('aria-expanded', 'true');
                    }
                });
            });

            document.addEventListener('click', function() {
                document.querySelectorAll('.overflow-menu.open').forEach(function(m) { m.classList.remove('open'); });
                document.querySelectorAll('[data-kebab]').forEach(function(b) { b.setAttribute('aria-expanded', 'false'); });
            });

            // ---------- Confirm modal (Reset Password / Deactivate / Activate) ----------
            var confirmBackdrop = document.getElementById('confirmModalBackdrop');
            var confirmIcon = document.getElementById('confirmModalIcon');
            var confirmTitle = document.getElementById('confirmModalTitle');
            var confirmBody = document.getElementById('confirmModalBody');
            var confirmBtn = document.getElementById('confirmModalConfirm');
            var confirmCancelBtn = document.getElementById('confirmModalCancel');
            var confirmPendingAction = null;
            var confirmLastFocused = null;

            function openConfirmModal(options) {
                confirmPendingAction = options.onConfirm;
                confirmIcon.innerHTML = '<i class="bi ' + options.icon + '"></i>';
                confirmIcon.style.background = options.iconBg;
                confirmIcon.style.color = options.iconColor;
                confirmTitle.textContent = options.title;
                confirmBody.textContent = options.body;
                confirmBtn.textContent = options.confirmLabel;
                confirmBtn.className = 'primary' + (options.destructiveStyle ? ' destructive' : '');
                confirmLastFocused = document.activeElement;
                confirmBackdrop.classList.add('open');
                confirmBtn.focus();
            }

            function closeConfirmModal() {
                confirmBackdrop.classList.remove('open');
                confirmPendingAction = null;
                if (confirmLastFocused) confirmLastFocused.focus();
            }

            confirmCancelBtn.addEventListener('click', closeConfirmModal);
            confirmBackdrop.addEventListener('click', function(e) { if (e.target === confirmBackdrop) closeConfirmModal(); });
            confirmBtn.addEventListener('click', function() {
                if (confirmPendingAction) confirmPendingAction();
                closeConfirmModal();
            });

            // ---------- Delete modal (with safety checkbox) ----------
            var deleteBackdrop = document.getElementById('deleteModalBackdrop');
            var deleteBody = document.getElementById('deleteModalBody');
            var deleteCheck = document.getElementById('deleteConfirmCheck');
            var deleteConfirmBtn = document.getElementById('deleteModalConfirm');
            var deleteCancelBtn = document.getElementById('deleteModalCancel');
            var deletePendingRow = null;
            var deleteLastFocused = null;

            function openDeleteModal(row, name) {
                deletePendingRow = row;
                deleteBody.textContent = 'Are you sure you want to permanently delete ' + name + '\'s account?';
                deleteCheck.checked = false;
                deleteConfirmBtn.disabled = true;
                deleteLastFocused = document.activeElement;
                deleteBackdrop.classList.add('open');
                deleteCheck.focus();
            }

            function closeDeleteModal() {
                deleteBackdrop.classList.remove('open');
                deletePendingRow = null;
                if (deleteLastFocused) deleteLastFocused.focus();
            }

            deleteCheck.addEventListener('change', function() { deleteConfirmBtn.disabled = !deleteCheck.checked; });
            deleteCancelBtn.addEventListener('click', closeDeleteModal);
            deleteBackdrop.addEventListener('click', function(e) { if (e.target === deleteBackdrop) closeDeleteModal(); });

            deleteConfirmBtn.addEventListener('click', function() {
                if (!deletePendingRow) return;
                var name = deletePendingRow.querySelector('.name-text').textContent;
                deletePendingRow.remove();
                closeDeleteModal();
                showToast(name + '\'s account was deleted.');
                render();
            });

            document.addEventListener('keydown', function(e) {
                if (e.key !== 'Escape') return;
                if (confirmBackdrop.classList.contains('open')) closeConfirmModal();
                if (deleteBackdrop.classList.contains('open')) closeDeleteModal();
            });

            // ---------- Row action wiring ----------
            document.querySelectorAll('[data-action]').forEach(function(btn) {
                var action = btn.getAttribute('data-action');
                var row = btn.closest('.user-row');
                var name = btn.getAttribute('data-name');
                var email = btn.getAttribute('data-email');

                if (action === 'reset') {
                    btn.addEventListener('click', function() {
                        openConfirmModal({
                            icon: 'bi-key', iconBg: 'var(--accent-pale)', iconColor: 'var(--accent)',
                            title: 'Reset Password',
                            body: 'Send a password reset link to ' + name + ' (' + email + ')?',
                            confirmLabel: 'Send Reset Link',
                            onConfirm: function() { showToast('Password reset link sent to ' + email); }
                        });
                    });
                }

                if (action === 'resend') {
                    btn.addEventListener('click', function() {
                        showToast('Invite resent to ' + email);
                    });
                }

                if (action === 'toggle-status') {
                    btn.addEventListener('click', function() {
                        var badge = row.querySelector('[data-status-badge]');
                        var isActive = row.getAttribute('data-status') === 'active';

                        if (isActive) {
                            openConfirmModal({
                                icon: 'bi-person-dash', iconBg: '#fdf1f0', iconColor: '#c0392b',
                                title: 'Deactivate User',
                                body: name + ' will no longer be able to log in. You can reactivate this account at any time.',
                                confirmLabel: 'Deactivate',
                                destructiveStyle: true,
                                onConfirm: function() {
                                    row.setAttribute('data-status', 'inactive');
                                    badge.className = 'status-badge status-inactive';
                                    badge.textContent = 'Inactive';
                                    btn.innerHTML = '<i class="bi bi-person-check"></i> Activate';
                                    showToast(name + ' has been deactivated.');
                                    render();
                                }
                            });
                        } else {
                            openConfirmModal({
                                icon: 'bi-person-check', iconBg: '#eafaf1', iconColor: '#27ae60',
                                title: 'Activate User',
                                body: name + ' will regain access to the system.',
                                confirmLabel: 'Activate',
                                onConfirm: function() {
                                    row.setAttribute('data-status', 'active');
                                    badge.className = 'status-badge status-active';
                                    badge.textContent = 'Active';
                                    btn.innerHTML = '<i class="bi bi-person-dash"></i> Deactivate';
                                    showToast(name + ' has been activated.');
                                    render();
                                }
                            });
                        }
                    });
                }

                if (action === 'delete') {
                    btn.addEventListener('click', function() {
                        document.querySelectorAll('.overflow-menu.open').forEach(function(m) { m.classList.remove('open'); });
                        openDeleteModal(row, name);
                    });
                }
            });

        })();
    </script>
}
