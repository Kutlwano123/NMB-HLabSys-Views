@{
    ViewData["Title"] = "Test Categories";
    ViewData["ActivePage"] = "TestCategories";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- =========================
HEADER
========================= -->
<div style="margin-bottom:20px;">
    <h2 style="margin:0;">Test Categories</h2>
    <p style="color:var(--text-light);font-size:13px;margin-top:4px;">
        Manage haematology test categories
    </p>
</div>

<!-- =========================
ADD CATEGORY FORM
========================= -->
<div class="add-form" style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:24px;">

    <h4 style="margin-bottom:14px;">
        <i class="bi bi-plus-circle" style="color:var(--accent);"></i>
        Add New Category
    </h4>

    <form id="createCategoryForm">

        <div style="display:flex;gap:10px;align-items:center;">

            <input type="text"
                   placeholder="e.g. Blood Tests"
                   style="flex:1;padding:10px 12px;border:1px solid var(--border);border-radius:8px;" />

            <button type="button"
                    onclick="openAddModal()"
                    class="btn-primary"
                    style="padding:10px 20px;font-size:13px;">
                <i class="bi bi-plus"></i>
                Add
            </button>

        </div>

    </form>

</div>

<!-- =========================
TABLE (STATIC DATA)
========================= -->
<div class="card" style="padding:0;overflow:hidden;">

    <table class="table" style="margin:0;">

        <thead>
            <tr>
                <th>#</th>
                <th>Category Name</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            <!-- Dummy data -->
            <tr id="row-1">
                <td>1</td>
                <td>Blood Tests</td>
                <td>
                    <button type="button"
                            onclick="openDeleteModal(1)"
                            style="background:var(--accent-pale);
                        color:var(--accent);
                        border:1px solid rgba(122,48,48,0.2);
                        border-radius:6px;
                        padding:6px 12px;
                        font-size:12px;">
                        Delete
                    </button>
                </td>
            </tr>

            <tr id="row-2">
                <td>2</td>
                <td>Urine Analysis</td>
                <td>
                    <button type="button"
                            onclick="openDeleteModal(2)"
                            style="background:var(--accent-pale);
                        color:var(--accent);
                        border:1px solid rgba(122,48,48,0.2);
                        border-radius:6px;
                        padding:6px 12px;
                        font-size:12px;">
                        Delete
                    </button>
                </td>
            </tr>

            <tr id="row-3">
                <td>3</td>
                <td>Microbiology</td>
                <td>
                    <button type="button"
                            onclick="openDeleteModal(3)"
                            style="background:var(--accent-pale);
                        color:var(--accent);
                        border:1px solid rgba(122,48,48,0.2);
                        border-radius:6px;
                        padding:6px 12px;
                        font-size:12px;">
                        Delete
                    </button>
                </td>
            </tr>

        </tbody>

    </table>

</div>

<!-- =========================
DELETE MODAL
========================= -->
<div id="deleteModal"
     style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;
    background:rgba(0,0,0,0.5);justify-content:center;align-items:center;z-index:9999;">

    <div style="background:white;padding:20px;border-radius:12px;width:320px;text-align:center;">

        <h4>Delete Category?</h4>

        <p style="font-size:13px;color:gray;">
            This action cannot be undone.
        </p>

        <div style="display:flex;gap:10px;justify-content:center;margin-top:15px;">

            <button onclick="closeDeleteModal()"
                    style="padding:8px 14px;border:1px solid #ccc;border-radius:8px;">
                Cancel
            </button>

            <button onclick="confirmDelete()"
                    style="padding:8px 14px;background:#c0392b;color:white;border:none;border-radius:8px;">
                Delete
            </button>

        </div>

    </div>

</div>

<!-- =========================
ADD MODAL
========================= -->
<div id="addModal"
     style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;
    background:rgba(0,0,0,0.5);justify-content:center;align-items:center;z-index:9999;">

    <div style="background:white;padding:20px;border-radius:12px;width:320px;text-align:center;">

        <h4>Confirm Add</h4>

        <p style="font-size:13px;color:gray;">
            Add this new category?
        </p>

        <div style="display:flex;gap:10px;justify-content:center;margin-top:15px;">

            <button onclick="closeAddModal()"
                    style="padding:8px 14px;border:1px solid #ccc;border-radius:8px;">
                Cancel
            </button>

            <button onclick="submitCategory()"
                    style="padding:8px 14px;background:var(--accent);color:white;border:none;border-radius:8px;">
                Yes Add
            </button>

        </div>

    </div>

</div>

<!-- =========================
TOAST
========================= -->
<div id="toast"
     style="display:none;position:fixed;bottom:20px;right:20px;
    background:#2ecc71;color:white;padding:10px 14px;
    border-radius:8px;font-size:13px;z-index:9999;">
    Action completed successfully
</div>

<!-- =========================
SCRIPT
========================= -->
<script>

    let selectedCategoryId = null;

    function openDeleteModal(id) {
        selectedCategoryId = id;
        document.getElementById("deleteModal").style.display = "flex";
    }

    function closeDeleteModal() {
        document.getElementById("deleteModal").style.display = "none";
    }

    function confirmDelete() {
        document.getElementById("row-" + selectedCategoryId)?.remove();
        closeDeleteModal();
        showToast("Category deleted successfully");
    }

    function openAddModal() {
        document.getElementById("addModal").style.display = "flex";
    }

    function closeAddModal() {
        document.getElementById("addModal").style.display = "none";
    }

    function submitCategory() {
        closeAddModal();
        showToast("Category added successfully");
    }

    function showToast(message) {
        const toast = document.getElementById("toast");
        toast.innerText = message;
        toast.style.display = "block";

        setTimeout(() => {
            toast.style.display = "none";
        }, 2000);
    }

</script>