@{
    ViewData["Title"] = "Test Categories";
    ViewData["ActivePage"] = "TestCategories";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- =========================
HEADER
========================= -->
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;flex-wrap:wrap;gap:12px;">

    <div>
        <h2 style="margin:0;">Test Categories</h2>

        <p style="color:var(--text-light);font-size:13px;margin-top:4px;">
            Manage haematology test categories
        </p>
    </div>

</div>

<!-- =========================
ADD CATEGORY FORM
========================= -->
<div class="card" style="padding:18px;margin-bottom:20px;">

    <form id="createCategoryForm">

        <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;">

            <input type="text"
                   id="categoryName"
                   placeholder="e.g. Blood Tests"
                   style="flex:1;min-width:220px;padding:10px 14px;border:1px solid var(--border);border-radius:10px;" />

            <button type="button"
                    onclick="openAddModal()"
                    style="background:var(--accent);
                           color:white;
                           border:none;
                           padding:10px 18px;
                           border-radius:10px;
                           font-size:13px;
                           font-weight:600;">
                <i class="bi bi-plus-circle"></i>
                Add Category
            </button>

        </div>

    </form>

</div>

<!-- =========================
TABLE
========================= -->
<div class="card" style="padding:0;overflow:hidden;">

    <table class="table" style="margin:0;">

        <thead>
            <tr>
                <th>#</th>
                <th>Category Name</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            <!-- CATEGORY 1 -->
            <tr id="row-1">

                <td>1</td>

                <td style="font-weight:600;font-size:13px;">
                    Blood Tests
                </td>

                <td style="display:flex;gap:8px;">

                    <a href="~/Admin/EditTestCategory/1"
                       style="background:#e8eaee;
                              color:#3a4a5a;
                              border-radius:6px;
                              padding:6px 10px;
                              font-size:12px;
                              text-decoration:none;">

                        <i class="bi bi-pencil"></i>
                        Edit

                    </a>

                    <button type="button"
                            onclick="openDeleteModal(1)"
                            style="background:var(--accent-pale);
                                   color:var(--accent);
                                   border:1px solid rgba(122,48,48,0.2);
                                   border-radius:6px;
                                   padding:6px 12px;
                                   font-size:12px;
                                   cursor:pointer;">

                        <i class="bi bi-trash"></i>
                        Delete

                    </button>

                </td>

            </tr>

            <!-- CATEGORY 2 -->
            <tr id="row-2">

                <td>2</td>

                <td style="font-weight:600;font-size:13px;">
                    Urine Analysis
                </td>

                <td style="display:flex;gap:8px;">

                    <a href="~/Admin/EditTestCategory/2"
                       style="background:#e8eaee;
                              color:#3a4a5a;
                              border-radius:6px;
                              padding:6px 10px;
                              font-size:12px;
                              text-decoration:none;">

                        <i class="bi bi-pencil"></i>
                        Edit

                    </a>

                    <button type="button"
                            onclick="openDeleteModal(2)"
                            style="background:var(--accent-pale);
                                   color:var(--accent);
                                   border:1px solid rgba(122,48,48,0.2);
                                   border-radius:6px;
                                   padding:6px 12px;
                                   font-size:12px;
                                   cursor:pointer;">

                        <i class="bi bi-trash"></i>
                        Delete

                    </button>

                </td>

            </tr>

            <!-- CATEGORY 3 -->
            <tr id="row-3">

                <td>3</td>

                <td style="font-weight:600;font-size:13px;">
                    Microbiology
                </td>

                <td style="display:flex;gap:8px;">

                    <a href="~/Admin/EditTestCategory/3"
                       style="background:#e8eaee;
                              color:#3a4a5a;
                              border-radius:6px;
                              padding:6px 10px;
                              font-size:12px;
                              text-decoration:none;">

                        <i class="bi bi-pencil"></i>
                        Edit

                    </a>

                    <button type="button"
                            onclick="openDeleteModal(3)"
                            style="background:var(--accent-pale);
                                   color:var(--accent);
                                   border:1px solid rgba(122,48,48,0.2);
                                   border-radius:6px;
                                   padding:6px 12px;
                                   font-size:12px;
                                   cursor:pointer;">

                        <i class="bi bi-trash"></i>
                        Delete

                    </button>

                </td>

            </tr>

        </tbody>

    </table>

</div>

<!-- =========================
DELETE MODAL
========================= -->
<div id="deleteModal"
     style="display:none;
            position:fixed;
            inset:0;
            background:rgba(0,0,0,0.5);
            justify-content:center;
            align-items:center;
            z-index:9999;">

    <div style="background:white;
                padding:20px;
                border-radius:12px;
                width:340px;
                text-align:center;">

        <h4 style="margin-bottom:10px;">
            Confirm Delete
        </h4>

        <p style="font-size:13px;color:gray;">
            Are you sure you want to delete this category?
        </p>

        <div style="display:flex;gap:10px;justify-content:center;margin-top:15px;">

            <button onclick="closeDeleteModal()"
                    style="padding:8px 14px;
                           border:1px solid #ccc;
                           border-radius:8px;
                           background:white;">

                Cancel

            </button>

            <button onclick="confirmDelete()"
                    style="padding:8px 14px;
                           background:#c0392b;
                           color:white;
                           border:none;
                           border-radius:8px;">

                Delete

            </button>

        </div>

    </div>

</div>

<!-- =========================
ADD MODAL
========================= -->
<div id="addModal"
     style="display:none;
            position:fixed;
            inset:0;
            background:rgba(0,0,0,0.5);
            justify-content:center;
            align-items:center;
            z-index:9999;">

    <div style="background:white;
                padding:20px;
                border-radius:12px;
                width:340px;
                text-align:center;">

        <h4 style="margin-bottom:10px;">
            Confirm Add
        </h4>

        <p style="font-size:13px;color:gray;">
            Add this new category?
        </p>

        <div style="display:flex;gap:10px;justify-content:center;margin-top:15px;">

            <button onclick="closeAddModal()"
                    style="padding:8px 14px;
                           border:1px solid #ccc;
                           border-radius:8px;
                           background:white;">

                Cancel

            </button>

            <button onclick="submitCategory()"
                    style="padding:8px 14px;
                           background:var(--accent);
                           color:white;
                           border:none;
                           border-radius:8px;">

                Add

            </button>

        </div>

    </div>

</div>

<!-- =========================
TOAST
========================= -->
<div id="toast"
     style="display:none;
            position:fixed;
            bottom:20px;
            right:20px;
            background:#2ecc71;
            color:white;
            padding:10px 14px;
            border-radius:8px;
            font-size:13px;
            z-index:9999;">

    Action completed successfully

</div>

<!-- =========================
SCRIPT
========================= -->
<script>

    let selectedCategoryId = null;

    // DELETE

    function openDeleteModal(id) {

        selectedCategoryId = id;

        document.getElementById("deleteModal").style.display = "flex";
    }

    function closeDeleteModal() {

        document.getElementById("deleteModal").style.display = "none";

        selectedCategoryId = null;
    }

    function confirmDelete() {

        document.getElementById("row-" + selectedCategoryId)?.remove();

        closeDeleteModal();

        showToast("Category deleted successfully");
    }

    // ADD

    function openAddModal() {

        const input = document.getElementById("categoryName");

        if (input.value.trim() === "") {

            showToast("Please enter a category name");

            return;
        }

        document.getElementById("addModal").style.display = "flex";
    }

    function closeAddModal() {

        document.getElementById("addModal").style.display = "none";
    }

    function submitCategory() {

        closeAddModal();

        document.getElementById("categoryName").value = "";

        showToast("Category added successfully");
    }

    // TOAST

    function showToast(message) {

        const toast = document.getElementById("toast");

        toast.innerText = message;

        toast.style.display = "block";

        setTimeout(() => {

            toast.style.display = "none";

        }, 2000);
    }

</script>