@{
    ViewData["Title"] = "Reports";
    ViewData["ActivePage"] = "Reports";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 22px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .report-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 14px;
            margin-bottom: 24px;
        }

        .report-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 18px;
            transition: 0.2s ease;
        }

            .report-card:hover {
                transform: translateY(-2px);
            }

        .report-title {
            font-weight: 700;
            font-size: 14px;
            margin-top: 10px;
        }

        .report-desc {
            font-size: 12px;
            color: var(--text-light);
            margin-top: 6px;
        }

        .report-btn {
            display: inline-block;
            margin-top: 12px;
            padding: 7px 12px;
            font-size: 12px;
            border-radius: 8px;
            background: var(--accent-pale);
            color: var(--accent);
            text-decoration: none;
        }

        .filter-bar {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

            .filter-bar input,
            .filter-bar select {
                padding: 8px 10px;
                border-radius: 8px;
                border: 1px solid var(--border);
                font-size: 13px;
            }

        .table-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
        }

    </style>
}

<!-- =========================
HEADER
========================= -->
<div class="page-header">

    <div>
        <h2 style="margin:0;">Reports</h2>
        <p style="color:var(--text-light);font-size:13px;margin-top:4px;">
            Prototype report dashboard — UI preview only
        </p>
    </div>

    <button style="background:var(--accent);color:white;
        border:none;padding:10px 14px;border-radius:10px;font-size:13px;">
        <i class="bi bi-download"></i>
        Export
    </button>

</div>

<!-- =========================
REPORT CARDS
========================= -->
<div class="report-grid">

    <div class="report-card">
        <i class="bi bi-file-medical"></i>
        <div class="report-title">Test Requests Overview</div>
        <div class="report-desc">Summary of lab test requests and statuses.</div>
        <a href="#" class="report-btn">Generate</a>
    </div>

    <div class="report-card">
        <i class="bi bi-people"></i>
        <div class="report-title">User Activity</div>
        <div class="report-desc">Shows login and system usage patterns.</div>
        <a href="#" class="report-btn">Generate</a>
    </div>

    <div class="report-card">
        <i class="bi bi-check-circle"></i>
        <div class="report-title">Completed Tests</div>
        <div class="report-desc">Displays completed laboratory results.</div>
        <a href="#" class="report-btn">Generate</a>
    </div>

    <div class="report-card">
        <i class="bi bi-bar-chart"></i>
        <div class="report-title">Performance Metrics</div>
        <div class="report-desc">Shows workload and efficiency indicators.</div>
        <a href="#" class="report-btn">Generate</a>
    </div>

</div>

<!-- =========================
FILTER BAR
========================= -->
<div class="filter-bar">

    <input type="date" />
    <input type="date" />

    <select>
        <option>All Reports</option>
        <option>Test Requests</option>
        <option>User Activity</option>
        <option>Performance</option>
    </select>

    <button style="background:var(--accent);color:white;
        border:none;padding:8px 14px;border-radius:8px;font-size:13px;">
        Filter
    </button>

</div>

<!-- =========================
STATIC TABLE
========================= -->
<div class="table-card">

    <table class="table" style="margin:0;">

        <thead>
            <tr>
                <th>Report</th>
                <th>Date</th>
                <th>Type</th>
                <th>Download</th>
            </tr>
        </thead>

        <tbody>

            <tr>
                <td>Test Requests Summary</td>
                <td>21 May 2026</td>
                <td>Lab</td>
                <td><a class="report-btn">PDF</a></td>
            </tr>

            <tr>
                <td>User Activity Report</td>
                <td>20 May 2026</td>
                <td>System</td>
                <td><a class="report-btn">PDF</a></td>
            </tr>

            <tr>
                <td>Completed Tests Report</td>
                <td>19 May 2026</td>
                <td>Results</td>
                <td><a class="report-btn">PDF</a></td>
            </tr>

            <tr>
                <td>Performance Overview</td>
                <td>18 May 2026</td>
                <td>Analytics</td>
                <td><a class="report-btn">PDF</a></td>
            </tr>

            <tr>
                <td>Audit Summary</td>
                <td>17 May 2026</td>
                <td>Audit</td>
                <td><a class="report-btn">PDF</a></td>
            </tr>

        </tbody>

    </table>

</div>