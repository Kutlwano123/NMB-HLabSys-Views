@{
    ViewData["Title"] = "Chronic Conditions";
    ViewData["ActivePage"] = "Conditions";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>

        /* =========================
                   HEADER (PATIENT STYLE)
                ========================= */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 22px;
        }

            .page-header h2 {
                margin: 0;
                font-size: 22px;
            }

            .page-header p {
                font-size: 12px;
                color: var(--text-light);
                margin-top: 4px;
            }

        /* =========================
                   PANEL
                ========================= */
        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
        }

        /* =========================
                   TABLE ACTIONS
                ========================= */
        .action-btn {
            font-size: 12px;
            padding: 6px 10px;
            border-radius: 6px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .edit-btn {
            background: #e8eaee;
            color: #3a4a5a;
        }

        .delete-btn {
            background: var(--accent-pale);
            color: var(--accent);
            border: none;
            cursor: pointer;
        }

        /* =========================
                   MODALS (SHARED STYLE)
                ========================= */
        .modal-bg {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }

        .modal-box {
            background: white;
            padding: 20px;
            border-radius: 12px;
            width: 340px;
            text-align: center;
        }

        .empty {
            text-align: center;
            padding: 24px;
            font-size: 13px;
            color: var(--text-light);
        }

    </style>
}

<!-- =========================
HEADER
========================= -->
<div class="page-header">

    <div>
        <h2>Chronic Conditions</h2>
        <p>Reference list used in patient records — static prototype view</p>
    </div>

    <button onclick="openAddModal()"
            style="background:var(--accent);color:#fff;padding:8px 14px;border:none;border-radius:8px;font-size:13px;">
        <i class="bi bi-plus-circle"></i> Add Condition
    </button>

</div>

<!-- =========================
STATIC INPUT BAR (PROTOTYPE ONLY)
========================= -->
<div class="panel" style="padding:14px;margin-bottom:16px;">

    <div style="display:flex;gap:10px;flex-wrap:wrap;">

        <input type="text"
               placeholder="Search conditions..."
               style="flex:1;min-width:200px;padding:10px;border:1px solid var(--border);border-radius:8px;" />

        <button style="background:var(--accent);color:#fff;border:none;border-radius:8px;padding:10px 14px;">
            <i class="bi bi-search"></i> Search
        </button>

    </div>

</div>

<!-- =========================
TABLE
========================= -->
<div class="panel">

    <table class="table table-sm" style="margin:0;">

        <thead>
            <tr>
                <th>Condition</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            <tr id="row-1">
                <td style="font-weight:600;">Diabetes Mellitus</td>
                <td>
                    <a href="~/Admin/EditCondition/1" class="action-btn edit-btn">
                        <i class="bi bi-pencil"></i> Edit
                    </a>

                    <button class="action-btn delete-btn" onclick="openDeleteModal(1)">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </td>
            </tr>

            <tr id="row-2">
                <td style="font-weight:600;">Hypertension</td>
                <td>
                    <a href="~/Admin/EditCondition/2" class="action-btn edit-btn">
                        <i class="bi bi-pencil"></i> Edit
                    </a>

                    <button class="action-btn delete-btn" onclick="openDeleteModal(2)">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </td>
            </tr>

            <tr id="row-3">
                <td style="font-weight:600;">Asthma</td>
                <td>
                    <a href="~/Admin/EditCondition/3" class="action-btn edit-btn">
                        <i class="bi bi-pencil"></i> Edit
                    </a>

                    <button class="action-btn delete-btn" onclick="openDeleteModal(3)">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </td>
            </tr>

        </tbody>

    </table>

</div>

<!-- =========================
ADD MODAL (UNIFIED STYLE)
========================= -->
<div id="addModal"
     style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;
    background:rgba(0,0,0,0.5);justify-content:center;align-items:center;z-index:9999;">

    <div style="background:white;padding:20px;border-radius:12px;width:340px;text-align:center;">

        <h4 style="margin-bottom:10px;">Confirm Add</h4>

        <p style="font-size:13px;color:gray;">
            Add this condition?
        </p>

        <div style="display:flex;gap:10px;justify-content:center;margin-top:15px;">

            <button onclick="closeAddModal()"
                    style="padding:8px 14px;border:1px solid #ccc;border-radius:8px;background:white;">
                Cancel
            </button>

            <button onclick="submitAdd()"
                    style="padding:8px 14px;background:var(--accent);color:white;border:none;border-radius:8px;">
                Confirm
            </button>

        </div>

    </div>

</div>

<!-- =========================
DELETE MODAL (UNIFIED STYLE)
========================= -->
<div id="deleteModal"
     style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;
    background:rgba(0,0,0,0.5);justify-content:center;align-items:center;z-index:9999;">

    <div style="background:white;padding:20px;border-radius:12px;width:340px;text-align:center;">

        <h4 style="margin-bottom:10px;">Confirm Delete</h4>

        <p style="font-size:13px;color:gray;">
            Are you sure you want to delete this condition?
        </p>

        <div style="display:flex;gap:10px;justify-content:center;margin-top:15px;">

            <button onclick="closeDeleteModal()"
                    style="padding:8px 14px;border:1px solid #ccc;border-radius:8px;background:white;">
                Cancel
            </button>

            <button onclick="confirmDelete()"
                    style="padding:8px 14px;background:#c0392b;color:white;border:none;border-radius:8px;">
                Delete
            </button>

        </div>

    </div>

</div>

<!-- =========================
TOAST (UNIFIED)
========================= -->
<div id="toast"
     style="display:none;position:fixed;bottom:20px;right:20px;
    background:#2ecc71;color:white;padding:10px 14px;
    border-radius:8px;font-size:13px;z-index:9999;">
</div>

<!-- =========================
SCRIPT
========================= -->
<script>

    let selectedId = null;

    // ADD
    function openAddModal() {
        document.getElementById("addModal").style.display = "flex";
    }

    function closeAddModal() {
        document.getElementById("addModal").style.display = "none";
    }

    function submitAdd() {
        document.getElementById("addForm").submit();
    }

    // DELETE
    function openDeleteModal(id) {
        selectedId = id;
        document.getElementById("deleteModal").style.display = "flex";
    }

    function closeDeleteModal() {
        document.getElementById("deleteModal").style.display = "none";
        selectedId = null;
    }

    function confirmDelete() {

        fetch('/Admin/DeleteCondition', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: selectedId })
        })
            .then(res => {
                if (res.ok) {
                    document.getElementById("row-" + selectedId).remove();
                    closeDeleteModal();
                    showToast("Condition deleted successfully");
                }
            });

    }

    function showToast(message) {
        const toast = document.getElementById("toast");
        toast.innerText = message;
        toast.style.display = "block";

        setTimeout(() => toast.style.display = "none", 2000);
    }

</script>