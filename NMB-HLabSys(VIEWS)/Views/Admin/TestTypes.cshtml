@{
    ViewData["Title"] = "Test Types";
    ViewData["ActivePage"] = "TestTypes";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- =========================
HEADER
========================= -->
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;flex-wrap:wrap;gap:12px;">

    <div>
        <h2 style="margin:0;">Test Types</h2>
        <p style="color:var(--text-light);font-size:13px;margin-top:4px;">
            Manage specific haematology tests available in the system
        </p>
    </div>

</div>

<!-- =========================
ADD FORM (STATIC)
========================= -->
<div class="card" style="padding:18px;margin-bottom:20px;">

    <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;">

        <input type="text"
               placeholder="Test name (e.g. Full Blood Count)"
               style="flex:1;min-width:220px;padding:10px 14px;border:1px solid var(--border);border-radius:10px;" />

        <select style="padding:10px 14px;border:1px solid var(--border);border-radius:10px;min-width:200px;">
            <option>All Categories</option>
            <option>Blood Tests</option>
            <option>Urine Tests</option>
            <option>Microbiology</option>
        </select>

        <button onclick="openAddModal()"
                style="background:var(--accent);color:white;border:none;padding:10px 18px;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;">
            <i class="bi bi-plus"></i>
            Add
        </button>

    </div>

</div>

<!-- =========================
TABLE
========================= -->
<div class="card" style="padding:0;overflow:hidden;">

    <table class="table" style="margin:0;">

        <thead>
            <tr>
                <th>Test Name</th>
                <th>Category</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            <!-- ROW 1 -->
            <tr id="row-1">

                <td style="font-weight:600;">
                    Full Blood Count
                </td>

                <td>
                    Blood Tests
                </td>

                <td style="display:flex;gap:8px;">

                    <a href="~/Admin/EditTestType/1"
                       style="background:#e8eaee;
                              color:#3a4a5a;
                              border-radius:6px;
                              padding:6px 10px;
                              font-size:12px;
                              text-decoration:none;">
                        <i class="bi bi-pencil"></i>
                        Edit
                    </a>

                    <button onclick="openDeleteModal(1)"
                            style="background:var(--accent-pale);
                                   color:var(--accent);
                                   border:1px solid rgba(0,0,0,0.1);
                                   border-radius:6px;
                                   padding:6px 12px;
                                   font-size:12px;
                                   cursor:pointer;">
                        <i class="bi bi-trash"></i>
                        Delete
                    </button>

                </td>

            </tr>

            <!-- ROW 2 -->
            <tr id="row-2">

                <td style="font-weight:600;">
                    Iron Studies
                </td>

                <td>
                    Blood Tests
                </td>

                <td style="display:flex;gap:8px;">

                    <a href="~/Admin/EditTestType/2"
                       style="background:#e8eaee;
                              color:#3a4a5a;
                              border-radius:6px;
                              padding:6px 10px;
                              font-size:12px;
                              text-decoration:none;">
                        <i class="bi bi-pencil"></i>
                        Edit
                    </a>

                    <button onclick="openDeleteModal(2)"
                            style="background:var(--accent-pale);
                                   color:var(--accent);
                                   border:1px solid rgba(0,0,0,0.1);
                                   border-radius:6px;
                                   padding:6px 12px;
                                   font-size:12px;
                                   cursor:pointer;">
                        <i class="bi bi-trash"></i>
                        Delete
                    </button>

                </td>

            </tr>

            <!-- ROW 3 -->
            <tr id="row-3">

                <td style="font-weight:600;">
                    Platelet Count
                </td>

                <td>
                    Haematology
                </td>

                <td style="display:flex;gap:8px;">

                    <a href="~/Admin/EditTestType/3"
                       style="background:#e8eaee;
                              color:#3a4a5a;
                              border-radius:6px;
                              padding:6px 10px;
                              font-size:12px;
                              text-decoration:none;">
                        <i class="bi bi-pencil"></i>
                        Edit
                    </a>

                    <button onclick="openDeleteModal(3)"
                            style="background:var(--accent-pale);
                                   color:var(--accent);
                                   border:1px solid rgba(0,0,0,0.1);
                                   border-radius:6px;
                                   padding:6px 12px;
                                   font-size:12px;
                                   cursor:pointer;">
                        <i class="bi bi-trash"></i>
                        Delete
                    </button>

                </td>

            </tr>

        </tbody>

    </table>

</div>

<!-- =========================
ADD MODAL
========================= -->
<div id="addModal"
     style="display:none;
            position:fixed;
            top:0;
            left:0;
            width:100%;
            height:100%;
            background:rgba(0,0,0,0.5);
            justify-content:center;
            align-items:center;
            z-index:9999;">

    <div style="background:white;
                padding:20px;
                border-radius:12px;
                width:340px;
                text-align:center;">

        <h4>Confirm Add</h4>

        <p style="font-size:13px;color:gray;">
            Add this test type?
        </p>

        <div style="display:flex;gap:10px;justify-content:center;margin-top:15px;">

            <button onclick="closeAddModal()"
                    style="padding:8px 14px;
                           border:1px solid #ccc;
                           border-radius:8px;
                           background:white;
                           cursor:pointer;">
                Cancel
            </button>

            <button onclick="submitAdd()"
                    style="padding:8px 14px;
                           background:var(--accent);
                           color:white;
                           border:none;
                           border-radius:8px;
                           cursor:pointer;">
                Confirm
            </button>

        </div>

    </div>

</div>

<!-- =========================
DELETE MODAL
========================= -->
<div id="deleteModal"
     style="display:none;
            position:fixed;
            top:0;
            left:0;
            width:100%;
            height:100%;
            background:rgba(0,0,0,0.5);
            justify-content:center;
            align-items:center;
            z-index:9999;">

    <div style="background:white;
                padding:20px;
                border-radius:12px;
                width:340px;
                text-align:center;">

        <h4>Confirm Delete</h4>

        <p style="font-size:13px;color:gray;">
            This action cannot be undone.
        </p>

        <div style="display:flex;gap:10px;justify-content:center;margin-top:15px;">

            <button onclick="closeDeleteModal()"
                    style="padding:8px 14px;
                           border:1px solid #ccc;
                           border-radius:8px;
                           background:white;
                           cursor:pointer;">
                Cancel
            </button>

            <button onclick="confirmDelete()"
                    style="padding:8px 14px;
                           background:#c0392b;
                           color:white;
                           border:none;
                           border-radius:8px;
                           cursor:pointer;">
                Delete
            </button>

        </div>

    </div>

</div>

<!-- =========================
TOAST
========================= -->
<div id="toast"
     style="display:none;
            position:fixed;
            bottom:20px;
            right:20px;
            background:#2ecc71;
            color:white;
            padding:10px 14px;
            border-radius:8px;
            font-size:13px;
            z-index:9999;">
</div>

<!-- =========================
SCRIPT
========================= -->
<script>

    let selectedId = null;

    // =========================
    // ADD
    // =========================

    function openAddModal() {

        document.getElementById("addModal").style.display = "flex";
    }

    function closeAddModal() {

        document.getElementById("addModal").style.display = "none";
    }

    function submitAdd() {

        closeAddModal();

        showToast("Test type added successfully (prototype)");
    }

    // =========================
    // DELETE
    // =========================

    function openDeleteModal(id) {

        selectedId = id;

        document.getElementById("deleteModal").style.display = "flex";
    }

    function closeDeleteModal() {

        document.getElementById("deleteModal").style.display = "none";

        selectedId = null;
    }

    function confirmDelete() {

        document.getElementById("row-" + selectedId)?.remove();

        closeDeleteModal();

        showToast("Test type deleted successfully");
    }

    // =========================
    // TOAST
    // =========================

    function showToast(message) {

        const toast = document.getElementById("toast");

        toast.innerText = message;

        toast.style.display = "block";

        setTimeout(() => {

            toast.style.display = "none";

        }, 2000);
    }

</script>