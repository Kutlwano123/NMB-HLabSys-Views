@{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>

        /* =========================
                   HEADER
                ========================= */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 22px;
        }

            .page-header h2 {
                margin: 0;
                font-size: 22px;
            }

            .page-header p {
                font-size: 12px;
                color: var(--text-light);
                margin-top: 4px;
            }

        /* =========================
                   STAT GRID
                ========================= */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 16px;
            margin-bottom: 16px;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 18px;
            display: flex;
            align-items: center;
            gap: 14px;
            transition: 0.2s ease;
            position: relative;
        }

        button.stat-card {
            cursor: pointer;
            text-align: left;
            width: 100%;
            font: inherit;
        }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(0,0,0,0.06);
        }

        button.stat-card:focus-visible {
            outline: 3px solid var(--accent);
            outline-offset: 2px;
        }

        .stat-card.active {
            border-color: var(--accent);
            box-shadow: 0 0 0 2px var(--accent-pale);
        }

        .stat-icon {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

            .stat-icon.red {
                background: var(--accent-pale);
                color: var(--accent);
            }

            .stat-icon.green {
                background: #e8f5e9;
                color: #2e7d32;
            }

            .stat-icon.gold {
                background: #fff3cd;
                color: #b58900;
            }

            .stat-icon.slate {
                background: #eef2f7;
                color: #3b4a5a;
            }

        .stat-card-body {
            flex: 1;
            min-width: 0;
        }

        .stat-value {
            font-family: 'DM Serif Display', serif;
            font-size: 26px;
            line-height: 1;
        }

        .stat-label {
            font-size: 12px;
            color: var(--text-light);
        }

        .stat-card-actions {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

            .stat-card-actions .mini-link,
            .stat-card-actions .quick-add-btn {
                width: 28px;
                height: 28px;
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                border: 1px solid var(--border);
                background: var(--bg);
                color: var(--text-mid);
                text-decoration: none;
                cursor: pointer;
                font-size: 12px;
            }

                .stat-card-actions .mini-link:hover,
                .stat-card-actions .quick-add-btn:hover {
                    border-color: var(--accent);
                    color: var(--accent);
                }

                .stat-card-actions .quick-add-btn:focus-visible,
                .stat-card-actions .mini-link:focus-visible {
                    outline: 2px solid var(--accent);
                    outline-offset: 2px;
                }

        /* --- User role breakdown (expands under Total Users) --- */
        .user-breakdown {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin: -6px 0 22px;
            padding: 12px 14px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
        }

        .breakdown-chip {
            border: 1px solid var(--border);
            background: var(--bg);
            color: var(--text-dark);
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            cursor: pointer;
        }

            .breakdown-chip:hover,
            .breakdown-chip.active {
                border-color: var(--accent);
                background: var(--accent-pale);
                color: var(--accent);
            }

            .breakdown-chip:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 2px;
            }

        /* =========================
                   TWO COLUMN
                ========================= */
        .two-col {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        @@media (max-width: 900px) {
            .two-col {
                grid-template-columns: 1fr;
            }
        }

        .section-heading {
            font-family: 'DM Serif Display', serif;
            font-size: 16px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 14px;
        }

        .empty {
            text-align: center;
            padding: 24px;
            font-size: 13px;
            color: var(--text-light);
        }

        .status-badge {
            font-size: 11px;
            padding: 4px 10px;
            border-radius: 20px;
            font-weight: 600;
            display: inline-block;
        }

        .status-pending {
            background: #fff3cd;
            color: #7a5d00;
        }

        .status-completed {
            background: #e8f5e9;
            color: #2e7d32;
        }

        .status-processing {
            background: #e8ecf3;
            color: #415a77;
        }

        .role-badge {
            font-size: 11px;
            padding: 4px 10px;
            border-radius: 20px;
            background: var(--accent-pale);
            color: var(--accent);
        }

        /* --- Table toolbar (search / filter) --- */
        .table-toolbar {
            display: flex;
            gap: 8px;
            margin-bottom: 12px;
            flex-wrap: wrap;
        }

            .table-toolbar input[type="search"] {
                flex: 1;
                min-width: 140px;
                padding: 6px 10px;
                border: 1px solid var(--border);
                border-radius: 8px;
                font-size: 12px;
            }

            .table-toolbar select {
                padding: 6px 10px;
                border: 1px solid var(--border);
                border-radius: 8px;
                font-size: 12px;
                background: #fff;
            }

        th.sortable {
            cursor: pointer;
            user-select: none;
            white-space: nowrap;
        }

            th.sortable .bi {
                font-size: 10px;
                opacity: 0.5;
                margin-left: 4px;
            }

            th.sortable.sort-active .bi {
                opacity: 1;
            }

        .row-hidden {
            display: none;
        }

        .view-all-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-top: 10px;
            font-size: 12px;
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
        }

            .view-all-link:hover {
                text-decoration: underline;
            }

        /* =========================
                   RECENT ACTIVITY (Audit Log)
                ========================= */
        .activity-list {
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .activity-item {
            display: flex;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
        }

            .activity-item:last-child {
                border-bottom: none;
            }

        .activity-icon {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--accent-pale);
            color: var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }

        .activity-text {
            font-size: 13px;
        }

        .activity-time {
            font-size: 11px;
            color: var(--text-light);
        }

        /* =========================
                   QUICK ADD MODAL
                ========================= */
        .modal-overlay-admin {
            position: fixed;
            inset: 0;
            background: rgba(20,24,30,0.45);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

            .modal-overlay-admin.open {
                display: flex;
            }

        .quick-add-modal {
            background: #fff;
            border-radius: 14px;
            max-width: 380px;
            width: 90%;
            padding: 22px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.2);
        }

            .quick-add-modal h3 {
                font-family: 'DM Serif Display', serif;
                font-size: 18px;
                margin: 0 0 4px;
            }

            .quick-add-modal .modal-sub {
                font-size: 12px;
                color: var(--text-light);
                margin-bottom: 16px;
            }

            .quick-add-modal label {
                display: block;
                font-size: 12px;
                font-weight: 600;
                margin-bottom: 4px;
                margin-top: 12px;
            }

            .quick-add-modal input[type="text"],
            .quick-add-modal textarea {
                width: 100%;
                padding: 8px 10px;
                border: 1px solid var(--border);
                border-radius: 8px;
                font-size: 13px;
                font-family: inherit;
                box-sizing: border-box;
            }

            .quick-add-modal textarea {
                min-height: 60px;
                resize: vertical;
            }

            .quick-add-modal .modal-close {
                background: none;
                border: none;
                font-size: 20px;
                float: right;
                cursor: pointer;
                color: var(--text-light);
                line-height: 1;
            }

            .quick-add-modal .modal-actions {
                display: flex;
                gap: 10px;
                margin-top: 20px;
            }

                .quick-add-modal .modal-actions button {
                    flex: 1;
                    padding: 10px;
                    border-radius: 8px;
                    border: 1px solid var(--border);
                    background: #fff;
                    cursor: pointer;
                    font-size: 13px;
                }

                    .quick-add-modal .modal-actions button.primary {
                        background: var(--accent);
                        color: #fff;
                        border-color: var(--accent);
                    }

        /* --- Toast --- */
        .toast-stack {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1100;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .toast-msg {
            background: #2e2e2e;
            color: #fff;
            padding: 10px 16px;
            border-radius: 8px;
            font-size: 13px;
            opacity: 0;
            transform: translateY(6px);
            transition: 0.25s ease;
        }

            .toast-msg.show {
                opacity: 1;
                transform: translateY(0);
            }

        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0,0,0,0);
            white-space: nowrap;
            border: 0;
        }

    </style>
}

<!-- =========================
HEADER
========================= -->
<div class="page-header">

    <div>
        <h2>Welcome back, Admin 👋</h2>
        <p id="todayDateAdmin"></p>
    </div>

    <a href="~/Admin/Users"
       style="background:var(--accent);color:#fff;padding:8px 14px;border-radius:8px;text-decoration:none;font-size:13px;">
        Manage Users
    </a>

</div>

<!-- =========================
STAT CARDS
========================= -->
<div class="stat-grid" id="statGrid" role="group" aria-label="Dashboard shortcuts">

    <!-- Total Users: expands a role breakdown, each role filters the Recent Users table -->
    <button type="button" class="stat-card" id="totalUsersCard" aria-expanded="false" aria-controls="userBreakdown"
            title="Click to see a breakdown by role">
        <div class="stat-icon red" aria-hidden="true"><i class="bi bi-people"></i></div>
        <div class="stat-card-body">
            <div class="stat-value" data-count="12">0</div>
            <div class="stat-label">Total Users</div>
        </div>
    </button>

    <!-- Pending Requests: jumps to + filters the Recent Requests table -->
    <button type="button" class="stat-card" data-filter="pending" title="Show pending test requests">
        <div class="stat-icon gold" aria-hidden="true"><i class="bi bi-hourglass-split"></i></div>
        <div class="stat-card-body">
            <div class="stat-value" data-count="6">0</div>
            <div class="stat-label">Pending Requests</div>
        </div>
    </button>

    <!-- Test Categories -->
    <div class="stat-card">
        <div class="stat-icon slate" aria-hidden="true"><i class="bi bi-tags"></i></div>
        <div class="stat-card-body">
            <div class="stat-value" data-count="9" id="count-categories">0</div>
            <div class="stat-label">Test Categories</div>
        </div>
        <div class="stat-card-actions">
            <a href="~/Admin/TestCategories" class="mini-link" title="Manage test categories" aria-label="Manage test categories"><i class="bi bi-arrow-right"></i></a>
            <button type="button" class="quick-add-btn" data-type="categories" title="Quick add a category" aria-label="Quick add a category"><i class="bi bi-plus-lg"></i></button>
        </div>
    </div>

    <!-- Medications -->
    <div class="stat-card">
        <div class="stat-icon green" aria-hidden="true"><i class="bi bi-capsule"></i></div>
        <div class="stat-card-body">
            <div class="stat-value" data-count="21" id="count-medications">0</div>
            <div class="stat-label">Medications</div>
        </div>
        <div class="stat-card-actions">
            <a href="~/Admin/Medications" class="mini-link" title="Manage medications" aria-label="Manage medications"><i class="bi bi-arrow-right"></i></a>
            <button type="button" class="quick-add-btn" data-type="medications" title="Quick add a medication" aria-label="Quick add a medication"><i class="bi bi-plus-lg"></i></button>
        </div>
    </div>

    <!-- Conditions -->
    <div class="stat-card">
        <div class="stat-icon gold" aria-hidden="true"><i class="bi bi-heart-pulse"></i></div>
        <div class="stat-card-body">
            <div class="stat-value" data-count="14" id="count-conditions">0</div>
            <div class="stat-label">Conditions</div>
        </div>
        <div class="stat-card-actions">
            <a href="~/Admin/Conditions" class="mini-link" title="Manage conditions" aria-label="Manage conditions"><i class="bi bi-arrow-right"></i></a>
            <button type="button" class="quick-add-btn" data-type="conditions" title="Quick add a condition" aria-label="Quick add a condition"><i class="bi bi-plus-lg"></i></button>
        </div>
    </div>

    <!-- Allergies -->
    <div class="stat-card">
        <div class="stat-icon red" aria-hidden="true"><i class="bi bi-exclamation-triangle"></i></div>
        <div class="stat-card-body">
            <div class="stat-value" data-count="11" id="count-allergies">0</div>
            <div class="stat-label">Allergies</div>
        </div>
        <div class="stat-card-actions">
            <a href="~/Admin/Allergies" class="mini-link" title="Manage allergies" aria-label="Manage allergies"><i class="bi bi-arrow-right"></i></a>
            <button type="button" class="quick-add-btn" data-type="allergies" title="Quick add an allergy" aria-label="Quick add an allergy"><i class="bi bi-plus-lg"></i></button>
        </div>
    </div>

</div>

<!-- Role breakdown, toggled by the Total Users card -->
<div class="user-breakdown" id="userBreakdown" hidden>
    <button type="button" class="breakdown-chip active" data-role="">All (12)</button>
    <button type="button" class="breakdown-chip" data-role="doctor">Doctors (4)</button>
    <button type="button" class="breakdown-chip" data-role="technician">Technicians (3)</button>
    <button type="button" class="breakdown-chip" data-role="patient">Patients (5)</button>
</div>

<!-- =========================
TWO COLUMN: REQUESTS + USERS
========================= -->
<div class="two-col">

    <!-- RECENT REQUESTS -->
    <div id="requestsSection">

        <div class="section-heading">
            <i class="bi bi-file-medical" style="color:var(--accent);" aria-hidden="true"></i>
            Recent Requests
        </div>

        <div class="panel">

            <div class="table-toolbar">
                <label class="sr-only" for="requestSearch">Search requests</label>
                <input type="search" id="requestSearch" placeholder="Search by patient or status...">

                <label class="sr-only" for="requestStatusFilter">Filter by status</label>
                <select id="requestStatusFilter">
                    <option value="">All statuses</option>
                    <option value="completed">Completed</option>
                    <option value="pending">Pending</option>
                    <option value="processing">Processing</option>
                </select>
            </div>

            <table class="table table-sm" id="requestsTable">
                <thead>
                    <tr>
                        <th class="sortable" data-sort="patient" scope="col">Patient <i class="bi bi-arrow-down-up"></i></th>
                        <th class="sortable" data-sort="status" scope="col">Status <i class="bi bi-arrow-down-up"></i></th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="req-row" data-status="completed" data-patient="john smith">
                        <td>John Smith</td>
                        <td><span class="status-badge status-completed">Completed</span></td>
                    </tr>
                    <tr class="req-row" data-status="pending" data-patient="mary johnson">
                        <td>Mary Johnson</td>
                        <td><span class="status-badge status-pending">Pending</span></td>
                    </tr>
                    <tr class="req-row" data-status="processing" data-patient="david brown">
                        <td>David Brown</td>
                        <td><span class="status-badge status-processing">Processing</span></td>
                    </tr>
                </tbody>
            </table>

            <div class="empty" id="noRequestsMsg" style="display:none;">
                No requests match your search or filter.
            </div>

        </div>

        <a href="~/Admin/TestRequests" class="view-all-link">View all requests <i class="bi bi-arrow-right"></i></a>

    </div>

    <!-- RECENT USERS -->
    <div id="usersSection">

        <div class="section-heading">
            <i class="bi bi-people" style="color:var(--accent);" aria-hidden="true"></i>
            Recent Users
        </div>

        <div class="panel">

            <div class="table-toolbar">
                <label class="sr-only" for="userSearch">Search users</label>
                <input type="search" id="userSearch" placeholder="Search by name or email...">

                <label class="sr-only" for="userRoleFilter">Filter by role</label>
                <select id="userRoleFilter">
                    <option value="">All roles</option>
                    <option value="doctor">Doctor</option>
                    <option value="technician">Technician</option>
                    <option value="patient">Patient</option>
                </select>
            </div>

            <table class="table table-sm" id="usersTable">
                <thead>
                    <tr>
                        <th class="sortable" data-sort="name" scope="col">Name <i class="bi bi-arrow-down-up"></i></th>
                        <th class="sortable" data-sort="role" scope="col">Role <i class="bi bi-arrow-down-up"></i></th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="user-row" data-role="doctor" data-name="dr smith smith@hospital.com">
                        <td>
                            <div style="font-weight:600;font-size:13px;">Dr Smith</div>
                            <div style="font-size:11px;color:var(--text-light);">smith@hospital.com</div>
                        </td>
                        <td><span class="role-badge">Doctor</span></td>
                    </tr>
                    <tr class="user-row" data-role="technician" data-name="lab tech 1 tech@lab.com">
                        <td>
                            <div style="font-weight:600;font-size:13px;">Lab Tech 1</div>
                            <div style="font-size:11px;color:var(--text-light);">tech@lab.com</div>
                        </td>
                        <td><span class="role-badge">Technician</span></td>
                    </tr>
                    <tr class="user-row" data-role="patient" data-name="john patient john@gmail.com">
                        <td>
                            <div style="font-weight:600;font-size:13px;">John Patient</div>
                            <div style="font-size:11px;color:var(--text-light);">john@gmail.com</div>
                        </td>
                        <td><span class="role-badge">Patient</span></td>
                    </tr>
                </tbody>
            </table>

            <div class="empty" id="noUsersMsg" style="display:none;">
                No users match your search or filter.
            </div>

        </div>

        <a href="~/Admin/Users" class="view-all-link">View all users <i class="bi bi-arrow-right"></i></a>

    </div>

</div>

<!-- =========================
RECENT ACTIVITY (Audit Log)
========================= -->
<div>

    <div class="section-heading">
        <i class="bi bi-journal-text" style="color:var(--accent);" aria-hidden="true"></i>
        Recent Activity
    </div>

    <div class="panel">

        <ul class="activity-list" id="activityList">
            <li class="activity-item">
                <div class="activity-icon" aria-hidden="true"><i class="bi bi-person-plus"></i></div>
                <div class="activity-text">
                    <div><strong>Dr Smith</strong> created a new user account for <strong>Lab Tech 1</strong>.</div>
                    <div class="activity-time">2 minutes ago</div>
                </div>
            </li>
            <li class="activity-item">
                <div class="activity-icon" aria-hidden="true"><i class="bi bi-check-circle"></i></div>
                <div class="activity-text">
                    <div>Test request for <strong>John Smith</strong> marked as Completed.</div>
                    <div class="activity-time">40 minutes ago</div>
                </div>
            </li>
            <li class="activity-item">
                <div class="activity-icon" aria-hidden="true"><i class="bi bi-capsule"></i></div>
                <div class="activity-text">
                    <div><strong>System Admin</strong> added a new medication: Amoxicillin.</div>
                    <div class="activity-time">1 hour ago</div>
                </div>
            </li>
            <li class="activity-item">
                <div class="activity-icon" aria-hidden="true"><i class="bi bi-shield-lock"></i></div>
                <div class="activity-text">
                    <div><strong>System Admin</strong> updated permissions for <strong>Dr Smith</strong>.</div>
                    <div class="activity-time">3 hours ago</div>
                </div>
            </li>
            <li class="activity-item">
                <div class="activity-icon" aria-hidden="true"><i class="bi bi-exclamation-triangle"></i></div>
                <div class="activity-text">
                    <div><strong>System Admin</strong> added a new allergy: Sulfa drugs.</div>
                    <div class="activity-time">Yesterday, 4:12 PM</div>
                </div>
            </li>
        </ul>

    </div>

    <a href="~/Admin/AuditLog" class="view-all-link">View full audit log <i class="bi bi-arrow-right"></i></a>

</div>

<!-- =========================
QUICK ADD MODAL
========================= -->
<div class="modal-overlay-admin" id="quickAddBackdrop" role="dialog" aria-modal="true" aria-labelledby="quickAddTitle">
    <div class="quick-add-modal">
        <button type="button" class="modal-close" id="quickAddClose" aria-label="Close">&times;</button>
        <h3 id="quickAddTitle">Add Medication</h3>
        <div class="modal-sub" id="quickAddSub">Add a new medication to the master list.</div>

        <label for="quickAddName">Name</label>
        <input type="text" id="quickAddName" placeholder="e.g. Amoxicillin" />

        <label for="quickAddNotes">Notes (optional)</label>
        <textarea id="quickAddNotes" placeholder="Dosage, category, or any other detail"></textarea>

        <div class="modal-actions">
            <button type="button" id="quickAddCancel">Cancel</button>
            <button type="button" id="quickAddSave" class="primary">Save</button>
        </div>
    </div>
</div>

<!-- TOASTS -->
<div class="toast-stack" id="toastStack" aria-live="polite"></div>

@section Scripts {
    <script>
        (function() {

            // ---------- Live date (matches Patient dashboard) ----------
            var dateEl = document.getElementById('todayDateAdmin');
            function updateDate() {
                var today = new Date();
                dateEl.textContent = today.toLocaleDateString('en-ZA', {
                    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
                }) + ' — System Overview';
            }
            updateDate();

            // ---------- Count-up animation ----------
            document.querySelectorAll('.stat-value[data-count]').forEach(function(el) {
                var target = parseInt(el.getAttribute('data-count'), 10) || 0;
                var current = 0;
                var step = Math.max(1, Math.ceil(target / 20));
                var timer = setInterval(function() {
                    current += step;
                    if (current >= target) { current = target; clearInterval(timer); }
                    el.textContent = current;
                }, 30);
            });

            // ---------- Toast helper ----------
            function showToast(message) {
                var stack = document.getElementById('toastStack');
                var toast = document.createElement('div');
                toast.className = 'toast-msg';
                toast.textContent = message;
                stack.appendChild(toast);
                requestAnimationFrame(function() { toast.classList.add('show'); });
                setTimeout(function() {
                    toast.classList.remove('show');
                    setTimeout(function() { toast.remove(); }, 300);
                }, 2500);
            }

            // ---------- Total Users: role breakdown toggle ----------
            var totalUsersCard = document.getElementById('totalUsersCard');
            var userBreakdown = document.getElementById('userBreakdown');

            totalUsersCard.addEventListener('click', function() {
                var expanded = totalUsersCard.getAttribute('aria-expanded') === 'true';
                totalUsersCard.setAttribute('aria-expanded', String(!expanded));
                userBreakdown.hidden = expanded;
                if (!expanded) {
                    userBreakdown.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }
            });

            // ---------- Requests table: search + status filter + sort ----------
            var requestSearch = document.getElementById('requestSearch');
            var requestStatusFilter = document.getElementById('requestStatusFilter');
            var noRequestsMsg = document.getElementById('noRequestsMsg');
            var requestSortState = { key: null, dir: 1 };

            function applyRequestFilters() {
                var query = requestSearch.value.trim().toLowerCase();
                var status = requestStatusFilter.value;
                var visibleCount = 0;

                document.querySelectorAll('.req-row').forEach(function(row) {
                    var rowStatus = row.getAttribute('data-status');
                    var text = row.textContent.toLowerCase();
                    var matchesStatus = !status || rowStatus === status;
                    var matchesQuery = !query || text.indexOf(query) !== -1;
                    var visible = matchesStatus && matchesQuery;
                    row.classList.toggle('row-hidden', !visible);
                    if (visible) visibleCount++;
                });

                noRequestsMsg.style.display = visibleCount === 0 ? 'block' : 'none';
            }

            requestSearch.addEventListener('input', applyRequestFilters);
            requestStatusFilter.addEventListener('change', applyRequestFilters);

            document.querySelectorAll('#requestsTable th.sortable').forEach(function(th) {
                th.addEventListener('click', function() {
                    var key = th.getAttribute('data-sort');
                    requestSortState.dir = (requestSortState.key === key) ? requestSortState.dir * -1 : 1;
                    requestSortState.key = key;

                    document.querySelectorAll('#requestsTable th.sortable').forEach(function(h) {
                        h.classList.remove('sort-active');
                    });
                    th.classList.add('sort-active');

                    var tbody = document.querySelector('#requestsTable tbody');
                    var rows = Array.prototype.slice.call(tbody.querySelectorAll('.req-row'));
                    rows.sort(function(a, b) {
                        var av = key === 'patient' ? a.getAttribute('data-patient') : a.getAttribute('data-status');
                        var bv = key === 'patient' ? b.getAttribute('data-patient') : b.getAttribute('data-status');
                        if (av < bv) return -1 * requestSortState.dir;
                        if (av > bv) return 1 * requestSortState.dir;
                        return 0;
                    });
                    rows.forEach(function(row) { tbody.appendChild(row); });
                });
            });

            // Pending Requests stat card jumps to + filters the requests table
            document.querySelector('.stat-card[data-filter="pending"]').addEventListener('click', function() {
                requestStatusFilter.value = 'pending';
                applyRequestFilters();
                document.getElementById('requestsSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
            });

            // ---------- Users table: search + role filter + sort ----------
            var userSearch = document.getElementById('userSearch');
            var userRoleFilter = document.getElementById('userRoleFilter');
            var noUsersMsg = document.getElementById('noUsersMsg');
            var userSortState = { key: null, dir: 1 };

            function applyUserFilters() {
                var query = userSearch.value.trim().toLowerCase();
                var role = userRoleFilter.value;
                var visibleCount = 0;

                document.querySelectorAll('.user-row').forEach(function(row) {
                    var rowRole = row.getAttribute('data-role');
                    var text = row.getAttribute('data-name') + ' ' + row.textContent.toLowerCase();
                    var matchesRole = !role || rowRole === role;
                    var matchesQuery = !query || text.toLowerCase().indexOf(query) !== -1;
                    var visible = matchesRole && matchesQuery;
                    row.classList.toggle('row-hidden', !visible);
                    if (visible) visibleCount++;
                });

                noUsersMsg.style.display = visibleCount === 0 ? 'block' : 'none';
            }

            userSearch.addEventListener('input', applyUserFilters);
            userRoleFilter.addEventListener('change', function() {
                document.querySelectorAll('.breakdown-chip').forEach(function(c) { c.classList.remove('active'); });
                var match = document.querySelector('.breakdown-chip[data-role="' + userRoleFilter.value + '"]');
                if (match) match.classList.add('active');
                applyUserFilters();
            });

            document.querySelectorAll('#usersTable th.sortable').forEach(function(th) {
                th.addEventListener('click', function() {
                    var key = th.getAttribute('data-sort');
                    userSortState.dir = (userSortState.key === key) ? userSortState.dir * -1 : 1;
                    userSortState.key = key;

                    document.querySelectorAll('#usersTable th.sortable').forEach(function(h) {
                        h.classList.remove('sort-active');
                    });
                    th.classList.add('sort-active');

                    var tbody = document.querySelector('#usersTable tbody');
                    var rows = Array.prototype.slice.call(tbody.querySelectorAll('.user-row'));
                    rows.sort(function(a, b) {
                        var av = key === 'role' ? a.getAttribute('data-role') : a.getAttribute('data-name');
                        var bv = key === 'role' ? b.getAttribute('data-role') : b.getAttribute('data-name');
                        if (av < bv) return -1 * userSortState.dir;
                        if (av > bv) return 1 * userSortState.dir;
                        return 0;
                    });
                    rows.forEach(function(row) { tbody.appendChild(row); });
                });
            });

            // Total Users breakdown chips filter the Recent Users table by role
            document.querySelectorAll('.breakdown-chip').forEach(function(chip) {
                chip.addEventListener('click', function() {
                    document.querySelectorAll('.breakdown-chip').forEach(function(c) { c.classList.remove('active'); });
                    chip.classList.add('active');
                    userRoleFilter.value = chip.getAttribute('data-role');
                    applyUserFilters();
                    document.getElementById('usersSection').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                });
            });

            // ---------- Quick Add modal (Categories / Medications / Conditions / Allergies) ----------
            // Demo-only: updates the on-page counter and shows a toast. Swap this
            // out for a real POST to the backend once the pages are wired up.
            var quickAddConfig = {
                categories:  { title: 'Add Test Category', sub: 'Add a new test category to the master list.',  namePlaceholder: 'e.g. Haematology' },
                medications: { title: 'Add Medication',    sub: 'Add a new medication to the master list.',     namePlaceholder: 'e.g. Amoxicillin' },
                conditions:  { title: 'Add Condition',     sub: 'Add a new condition to the master list.',      namePlaceholder: 'e.g. Hypertension' },
                allergies:   { title: 'Add Allergy',       sub: 'Add a new allergy to the master list.',        namePlaceholder: 'e.g. Penicillin' }
            };

            var quickAddBackdrop = document.getElementById('quickAddBackdrop');
            var quickAddTitle = document.getElementById('quickAddTitle');
            var quickAddSub = document.getElementById('quickAddSub');
            var quickAddName = document.getElementById('quickAddName');
            var quickAddNotes = document.getElementById('quickAddNotes');
            var quickAddCurrentType = null;
            var quickAddLastFocused = null;

            function openQuickAdd(type) {
                var config = quickAddConfig[type];
                if (!config) return;
                quickAddCurrentType = type;
                quickAddTitle.textContent = config.title;
                quickAddSub.textContent = config.sub;
                quickAddName.placeholder = config.namePlaceholder;
                quickAddName.value = '';
                quickAddNotes.value = '';
                quickAddLastFocused = document.activeElement;
                quickAddBackdrop.classList.add('open');
                quickAddName.focus();
            }

            function closeQuickAdd() {
                quickAddBackdrop.classList.remove('open');
                if (quickAddLastFocused) quickAddLastFocused.focus();
            }

            document.querySelectorAll('.quick-add-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    openQuickAdd(btn.getAttribute('data-type'));
                });
            });

            document.getElementById('quickAddClose').addEventListener('click', closeQuickAdd);
            document.getElementById('quickAddCancel').addEventListener('click', closeQuickAdd);
            quickAddBackdrop.addEventListener('click', function(e) {
                if (e.target === quickAddBackdrop) closeQuickAdd();
            });
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && quickAddBackdrop.classList.contains('open')) closeQuickAdd();
            });

            document.getElementById('quickAddSave').addEventListener('click', function() {
                var name = quickAddName.value.trim();
                if (!name) {
                    quickAddName.focus();
                    return;
                }
                var counterEl = document.getElementById('count-' + quickAddCurrentType);
                if (counterEl) {
                    var current = parseInt(counterEl.textContent, 10) || 0;
                    counterEl.textContent = current + 1;
                }
                var label = quickAddConfig[quickAddCurrentType].title.replace('Add ', '');
                showToast(label + ' "' + name + '" added.');
                closeQuickAdd();
            });

            // ---------- Global topnav search (hooks into this page's tables) ----------
            var globalSearch = document.getElementById('globalSearch');
            if (globalSearch) {
                globalSearch.addEventListener('input', function() {
                    requestSearch.value = globalSearch.value;
                    userSearch.value = globalSearch.value;
                    applyRequestFilters();
                    applyUserFilters();
                });
            }

        })();
    </script>
}
