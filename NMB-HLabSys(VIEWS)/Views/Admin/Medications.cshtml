@{
    ViewData["Title"] = "Medications";
    ViewData["ActivePage"] = "Medications";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>

        /* ================= HEADER ================= */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 22px;
        }

            .page-header h2 {
                margin: 0;
                font-size: 22px;
            }

            .page-header p {
                font-size: 12px;
                color: var(--text-light);
                margin-top: 4px;
                max-width: 520px;
            }

        .btn-primary-sm {
            background: var(--accent);
            color: #fff;
            border: none;
            padding: 9px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            white-space: nowrap;
        }

        /* ================= TOOLBAR ================= */
        .toolbar {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 18px;
        }

        .toolbar-left {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
            flex: 1;
        }

        .search-box {
            position: relative;
            flex: 1;
            min-width: 220px;
            max-width: 320px;
        }

            .search-box i {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-light);
                font-size: 13px;
            }

            .search-box input {
                width: 100%;
                padding: 9px 12px 9px 34px;
                border: 1px solid var(--border);
                border-radius: 8px;
                font-size: 13px;
                box-sizing: border-box;
            }

        .filter-select {
            padding: 9px 12px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 13px;
            min-width: 170px;
            background: var(--surface);
        }

        .archived-toggle {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12.5px;
            color: var(--text-light);
            white-space: nowrap;
        }

            .archived-toggle input {
                width: auto;
            }

        /* ================= BADGES ================= */
        .badge-cat {
            display: inline-block;
            font-size: 11px;
            font-weight: 700;
            padding: 3px 9px;
            border-radius: 999px;
            background: #f1e8fe;
            color: #6a2fb0;
        }

        .badge-form {
            display: inline-block;
            font-size: 11px;
            font-weight: 600;
            padding: 3px 9px;
            border-radius: 999px;
            background: var(--bg);
            border: 1px solid var(--border);
            color: var(--text-light);
        }

        .status-badge {
            display: inline-block;
            font-size: 11px;
            font-weight: 700;
            padding: 3px 9px;
            border-radius: 999px;
        }

        .status-Active {
            background: #e6f7ee;
            color: #1f8a4c;
        }

        .status-Archived {
            background: #f0f0f0;
            color: #777;
        }

        /* ================= TABLE ================= */
        .table td {
            vertical-align: middle;
        }

        .row-archived td {
            opacity: .55;
        }

        .med-name {
            font-weight: 600;
            font-size: 13px;
        }

        .med-generic {
            font-size: 11.5px;
            color: var(--text-light);
            margin-top: 1px;
        }

        .notes-cell {
            font-size: 12px;
            color: var(--text-light);
            max-width: 220px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .action-btn {
            border-radius: 6px;
            padding: 6px 10px;
            font-size: 12px;
            cursor: pointer;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .action-edit {
            background: #e8eaee;
            color: #3a4a5a;
        }

        .action-archive {
            background: var(--accent-pale);
            color: var(--accent);
            border: 1px solid rgba(122,48,48,0.2);
        }

        .action-restore {
            background: #e6f7ee;
            color: #1f8a4c;
            border: 1px solid rgba(31,138,76,0.2);
        }

        .empty-state {
            padding: 40px 20px;
            text-align: center;
            color: var(--text-light);
            font-size: 13px;
        }

            .empty-state i {
                font-size: 26px;
                display: block;
                margin-bottom: 8px;
                opacity: .5;
            }

        /* ================= MODAL SHELL ================= */
        .cat-modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            justify-content: center;
            align-items: center;
            z-index: 9999;
            padding: 20px;
        }

            .cat-modal-overlay.open {
                display: flex;
            }

        .cat-modal-box {
            width: 100%;
            max-width: 460px;
            background: white;
            border-radius: 14px;
            padding: 24px;
            text-align: left;
        }

            .cat-modal-box h4 {
                margin: 0 0 4px 0;
                font-size: 17px;
            }

            .cat-modal-box .cat-modal-sub {
                font-size: 12.5px;
                color: var(--text-light);
                margin-bottom: 18px;
            }

        .form-row-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        @@media (max-width: 480px) {
            .form-row-2 {
                grid-template-columns: 1fr;
            }
        }

        .cat-form-group {
            margin-bottom: 16px;
        }

            .cat-form-group label {
                display: block;
                margin-bottom: 7px;
                font-size: 13px;
                font-weight: 600;
                color: var(--text-dark);
            }

            .cat-form-group label .req {
                color: #c41e3a;
            }

            .cat-form-group input,
            .cat-form-group select,
            .cat-form-group textarea {
                width: 100%;
                padding: 11px 14px;
                border: 1px solid var(--border);
                border-radius: 10px;
                font-size: 13px;
                outline: none;
                box-sizing: border-box;
                transition: .2s ease;
                font-family: inherit;
            }

                .cat-form-group textarea {
                    resize: vertical;
                    min-height: 70px;
                }

                .cat-form-group input:focus,
                .cat-form-group select:focus,
                .cat-form-group textarea:focus {
                    border-color: var(--accent);
                    box-shadow: 0 0 0 3px rgba(122,48,48,0.08);
                }

        .cat-modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 22px;
        }

        .cat-modal-btn {
            border: none;
            padding: 10px 18px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
        }

        .cat-modal-cancel {
            background: #ececec;
            color: #333;
        }

        .cat-modal-confirm {
            background: var(--accent);
            color: white;
        }

        .cat-modal-box-sm {
            width: 100%;
            max-width: 340px;
            background: white;
            border-radius: 14px;
            padding: 22px;
            text-align: center;
        }

            .cat-modal-box-sm .cat-icon {
                width: 52px;
                height: 52px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 14px;
                font-size: 22px;
            }

            .cat-modal-box-sm h4 {
                margin: 0 0 8px 0;
            }

            .cat-modal-box-sm p {
                font-size: 13px;
                color: var(--text-light);
                margin-bottom: 18px;
            }

        .cat-modal-actions-center {
            display: flex;
            justify-content: center;
            gap: 10px;
        }

            .cat-modal-actions-center .cat-modal-btn {
                flex: 1;
            }

        .cat-modal-archive {
            background: #c0392b;
            color: white;
        }

        .cat-modal-restore {
            background: #1f8a4c;
            color: white;
        }

        .cat-icon-archive {
            background: #fdecea;
            color: #c0392b;
        }

        .cat-icon-restore {
            background: #e6f7ee;
            color: #1f8a4c;
        }

        #toast {
            display: none;
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #2ecc71;
            color: white;
            padding: 10px 16px;
            border-radius: 8px;
            font-size: 13px;
            z-index: 99999;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

    </style>
}

<!-- ================= HEADER ================= -->
<div class="page-header">

    <div>
        <h2>Medications</h2>
        <p>Reference list of medications used throughout the system, with dosage form, strength, and category.</p>
    </div>

    <button type="button" class="btn-primary-sm" onclick="openAddModal()">
        <i class="bi bi-plus-circle"></i>
        Add Medication
    </button>

</div>

<!-- ================= TOOLBAR ================= -->
<div class="toolbar">

    <div class="toolbar-left">
        <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" id="searchInput" placeholder="Search by name or generic name…" oninput="renderTable()" />
        </div>

        <select id="categoryFilter" class="filter-select" onchange="renderTable()">
            <option value="">All Categories</option>
            <option value="Antibiotics">Antibiotics</option>
            <option value="Analgesics">Analgesics</option>
            <option value="Antihypertensives">Antihypertensives</option>
            <option value="Antidiabetics">Antidiabetics</option>
            <option value="Antihistamines">Antihistamines</option>
        </select>

        <select id="formFilter" class="filter-select" onchange="renderTable()">
            <option value="">All Forms</option>
            <option value="Tablet">Tablet</option>
            <option value="Capsule">Capsule</option>
            <option value="Syrup">Syrup</option>
            <option value="Injection">Injection</option>
            <option value="Cream">Cream</option>
            <option value="Drops">Drops</option>
            <option value="Inhaler">Inhaler</option>
        </select>
    </div>

    <label class="archived-toggle">
        <input type="checkbox" id="showArchived" onchange="renderTable()" />
        Show archived
    </label>

</div>

<!-- ================= TABLE ================= -->
<div class="card" style="padding:0;overflow:hidden;">

    <table class="table" style="margin:0;width:100%;">

        <thead>
            <tr>
                <th>#</th>
                <th>Medication</th>
                <th>Category</th>
                <th>Form</th>
                <th>Strength</th>
                <th>Notes</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody id="medTableBody">
            <!-- populated by JS -->
        </tbody>

    </table>

    <div class="empty-state" id="emptyState" style="display:none;">
        <i class="bi bi-capsule"></i>
        No medications found.
    </div>

</div>

<!-- ================= ADD MODAL ================= -->
<div class="cat-modal-overlay" id="addModal">

    <div class="cat-modal-box">

        <h4>Add Medication</h4>
        <div class="cat-modal-sub">Add a new medication to the system reference list.</div>

        <div class="form-row-2">
            <div class="cat-form-group">
                <label for="addName">Medication Name <span class="req">*</span></label>
                <input type="text" id="addName" placeholder="e.g. Metformin" />
            </div>
            <div class="cat-form-group">
                <label for="addGeneric">Generic Name</label>
                <input type="text" id="addGeneric" placeholder="e.g. Metformin Hydrochloride" />
            </div>
        </div>

        <div class="form-row-2">
            <div class="cat-form-group">
                <label for="addCategory">Category <span class="req">*</span></label>
                <select id="addCategory">
                    <option value="Antibiotics">Antibiotics</option>
                    <option value="Analgesics">Analgesics</option>
                    <option value="Antihypertensives">Antihypertensives</option>
                    <option value="Antidiabetics">Antidiabetics</option>
                    <option value="Antihistamines">Antihistamines</option>
                </select>
            </div>
            <div class="cat-form-group">
                <label for="addForm">Dosage Form <span class="req">*</span></label>
                <select id="addForm">
                    <option value="Tablet">Tablet</option>
                    <option value="Capsule">Capsule</option>
                    <option value="Syrup">Syrup</option>
                    <option value="Injection">Injection</option>
                    <option value="Cream">Cream</option>
                    <option value="Drops">Drops</option>
                    <option value="Inhaler">Inhaler</option>
                </select>
            </div>
        </div>

        <div class="cat-form-group">
            <label for="addStrength">Strength</label>
            <input type="text" id="addStrength" placeholder="e.g. 500mg" />
        </div>

        <div class="cat-form-group">
            <label for="addNotes">Notes</label>
            <textarea id="addNotes" placeholder="e.g. Take with food. Avoid alcohol."></textarea>
        </div>

        <div class="cat-modal-actions">
            <button class="cat-modal-btn cat-modal-cancel" type="button" onclick="closeAddModal()">Cancel</button>
            <button class="cat-modal-btn cat-modal-confirm" type="button" onclick="submitAdd()">
                <i class="bi bi-plus-circle"></i>
                Add Medication
            </button>
        </div>

    </div>

</div>

<!-- ================= EDIT MODAL ================= -->
<div class="cat-modal-overlay" id="editModal">

    <div class="cat-modal-box">

        <h4>Edit Medication</h4>
        <div class="cat-modal-sub">Modify details for <strong id="editNameLabel"></strong></div>

        <div class="form-row-2">
            <div class="cat-form-group">
                <label for="editName">Medication Name <span class="req">*</span></label>
                <input type="text" id="editName" />
            </div>
            <div class="cat-form-group">
                <label for="editGeneric">Generic Name</label>
                <input type="text" id="editGeneric" />
            </div>
        </div>

        <div class="form-row-2">
            <div class="cat-form-group">
                <label for="editCategory">Category <span class="req">*</span></label>
                <select id="editCategory">
                    <option value="Antibiotics">Antibiotics</option>
                    <option value="Analgesics">Analgesics</option>
                    <option value="Antihypertensives">Antihypertensives</option>
                    <option value="Antidiabetics">Antidiabetics</option>
                    <option value="Antihistamines">Antihistamines</option>
                </select>
            </div>
            <div class="cat-form-group">
                <label for="editForm">Dosage Form <span class="req">*</span></label>
                <select id="editForm">
                    <option value="Tablet">Tablet</option>
                    <option value="Capsule">Capsule</option>
                    <option value="Syrup">Syrup</option>
                    <option value="Injection">Injection</option>
                    <option value="Cream">Cream</option>
                    <option value="Drops">Drops</option>
                    <option value="Inhaler">Inhaler</option>
                </select>
            </div>
        </div>

        <div class="cat-form-group">
            <label for="editStrength">Strength</label>
            <input type="text" id="editStrength" />
        </div>

        <div class="cat-form-group">
            <label for="editNotes">Notes</label>
            <textarea id="editNotes"></textarea>
        </div>

        <div class="cat-modal-actions">
            <button class="cat-modal-btn cat-modal-cancel" type="button" onclick="closeEditModal()">Cancel</button>
            <button class="cat-modal-btn cat-modal-confirm" type="button" onclick="submitEdit()">
                <i class="bi bi-check-circle"></i>
                Save Changes
            </button>
        </div>

    </div>

</div>

<!-- ================= ARCHIVE / RESTORE MODAL ================= -->
<div class="cat-modal-overlay" id="archiveModal">

    <div class="cat-modal-box-sm">

        <div class="cat-icon" id="archiveIcon">
            <i class="bi bi-archive"></i>
        </div>

        <h4 id="archiveTitle">Archive Medication</h4>

        <p id="archiveText">
            Archived medications are hidden from selection lists but existing
            patient records that reference them are unaffected.
        </p>

        <div class="cat-modal-actions-center">
            <button class="cat-modal-btn cat-modal-cancel" type="button" onclick="closeArchiveModal()">Cancel</button>
            <button class="cat-modal-btn" type="button" id="archiveConfirmBtn" onclick="confirmArchive()">Archive</button>
        </div>

    </div>

</div>

<!-- ================= TOAST ================= -->
<div id="toast">Action completed successfully</div>

<!-- ================= SCRIPT ================= -->
<script>
    (function () {

        // ---------- Seed data (prototype only — replace with data from the server) ----------
        var medications = [
            { id: 1, name: 'Metformin', generic: 'Metformin Hydrochloride', category: 'Antidiabetics', form: 'Tablet', strength: '500mg', notes: 'Take with food to reduce GI upset.', status: 'Active' },
            { id: 2, name: 'Aspirin', generic: 'Acetylsalicylic Acid', category: 'Analgesics', form: 'Tablet', strength: '300mg', notes: 'Avoid on an empty stomach.', status: 'Active' },
            { id: 3, name: 'Ibuprofen', generic: 'Ibuprofen', category: 'Analgesics', form: 'Tablet', strength: '400mg', notes: 'Anti-inflammatory; take after meals.', status: 'Active' },
            { id: 4, name: 'Amoxicillin', generic: 'Amoxicillin Trihydrate', category: 'Antibiotics', form: 'Capsule', strength: '500mg', notes: 'Complete full course even if symptoms improve.', status: 'Active' },
            { id: 5, name: 'Diclofenac', generic: 'Diclofenac Sodium', category: 'Analgesics', form: 'Cream', strength: '1%', notes: 'Discontinued from formulary.', status: 'Archived' }
        ];

        var nextId = medications.length + 1;
        var editTargetId = null;
        var archiveTargetId = null;
        var archiveTargetAction = null;

        // ---------- Table rendering ----------
        window.renderTable = function () {
            var tbody = document.getElementById('medTableBody');
            var emptyState = document.getElementById('emptyState');
            var search = document.getElementById('searchInput').value.trim().toLowerCase();
            var category = document.getElementById('categoryFilter').value;
            var form = document.getElementById('formFilter').value;
            var showArchived = document.getElementById('showArchived').checked;

            var rows = medications.filter(function (m) {
                if (!showArchived && m.status === 'Archived') return false;
                if (category && m.category !== category) return false;
                if (form && m.form !== form) return false;
                if (search && m.name.toLowerCase().indexOf(search) === -1 && m.generic.toLowerCase().indexOf(search) === -1) return false;
                return true;
            });

            tbody.innerHTML = '';
            emptyState.style.display = rows.length === 0 ? 'block' : 'none';

            rows.forEach(function (m, index) {
                var tr = document.createElement('tr');
                tr.id = 'row-' + m.id;
                if (m.status === 'Archived') tr.classList.add('row-archived');

                tr.innerHTML =
                    '<td>' + (index + 1) + '</td>' +
                    '<td><div class="med-name">' + escapeHtml(m.name) + '</div><div class="med-generic">' + escapeHtml(m.generic || '—') + '</div></td>' +
                    '<td><span class="badge-cat">' + escapeHtml(m.category) + '</span></td>' +
                    '<td><span class="badge-form">' + escapeHtml(m.form) + '</span></td>' +
                    '<td style="font-size:12.5px;">' + escapeHtml(m.strength || '—') + '</td>' +
                    '<td class="notes-cell" title="' + escapeHtml(m.notes || '') + '">' + escapeHtml(m.notes || '—') + '</td>' +
                    '<td><span class="status-badge status-' + m.status + '">' + m.status + '</span></td>' +
                    '<td></td>';

                var actionsCell = tr.querySelector('td:last-child');
                actionsCell.style.display = 'flex';
                actionsCell.style.gap = '8px';

                var editBtn = document.createElement('button');
                editBtn.type = 'button';
                editBtn.className = 'action-btn action-edit';
                editBtn.innerHTML = '<i class="bi bi-pencil"></i> Edit';
                editBtn.onclick = function () { openEditModal(m.id); };
                actionsCell.appendChild(editBtn);

                if (m.status === 'Active') {
                    var archiveBtn = document.createElement('button');
                    archiveBtn.type = 'button';
                    archiveBtn.className = 'action-btn action-archive';
                    archiveBtn.innerHTML = '<i class="bi bi-archive"></i> Archive';
                    archiveBtn.onclick = function () { openArchiveModal(m.id, false); };
                    actionsCell.appendChild(archiveBtn);
                } else {
                    var restoreBtn = document.createElement('button');
                    restoreBtn.type = 'button';
                    restoreBtn.className = 'action-btn action-restore';
                    restoreBtn.innerHTML = '<i class="bi bi-arrow-counterclockwise"></i> Restore';
                    restoreBtn.onclick = function () { openArchiveModal(m.id, true); };
                    actionsCell.appendChild(restoreBtn);
                }

                tbody.appendChild(tr);
            });
        };

        function escapeHtml(str) {
            var div = document.createElement('div');
            div.textContent = str;
            return div.innerHTML;
        }

        // ---------- Add ----------
        window.openAddModal = function () {
            document.getElementById('addName').value = '';
            document.getElementById('addGeneric').value = '';
            document.getElementById('addCategory').value = 'Antibiotics';
            document.getElementById('addForm').value = 'Tablet';
            document.getElementById('addStrength').value = '';
            document.getElementById('addNotes').value = '';
            document.getElementById('addModal').classList.add('open');
        };

        window.closeAddModal = function () {
            document.getElementById('addModal').classList.remove('open');
        };

        window.submitAdd = function () {
            var name = document.getElementById('addName').value.trim();
            if (!name) {
                showToast('Please provide a medication name');
                return;
            }

            // TODO: replace with a real POST to your Medications controller.

            medications.push({
                id: nextId++,
                name: name,
                generic: document.getElementById('addGeneric').value.trim(),
                category: document.getElementById('addCategory').value,
                form: document.getElementById('addForm').value,
                strength: document.getElementById('addStrength').value.trim(),
                notes: document.getElementById('addNotes').value.trim(),
                status: 'Active'
            });

            closeAddModal();
            showToast('Medication added successfully');
            renderTable();
        };

        // ---------- Edit ----------
        window.openEditModal = function (id) {
            var m = medications.find(function (x) { return x.id === id; });
            if (!m) return;

            editTargetId = id;
            document.getElementById('editNameLabel').textContent = m.name;
            document.getElementById('editName').value = m.name;
            document.getElementById('editGeneric').value = m.generic || '';
            document.getElementById('editCategory').value = m.category;
            document.getElementById('editForm').value = m.form;
            document.getElementById('editStrength').value = m.strength || '';
            document.getElementById('editNotes').value = m.notes || '';
            document.getElementById('editModal').classList.add('open');
        };

        window.closeEditModal = function () {
            document.getElementById('editModal').classList.remove('open');
            editTargetId = null;
        };

        window.submitEdit = function () {
            var name = document.getElementById('editName').value.trim();
            if (!name) {
                showToast('Please provide a medication name');
                return;
            }

            // TODO: replace with a real PUT/POST to your Medications controller.

            var m = medications.find(function (x) { return x.id === editTargetId; });
            if (m) {
                m.name = name;
                m.generic = document.getElementById('editGeneric').value.trim();
                m.category = document.getElementById('editCategory').value;
                m.form = document.getElementById('editForm').value;
                m.strength = document.getElementById('editStrength').value.trim();
                m.notes = document.getElementById('editNotes').value.trim();
            }

            closeEditModal();
            showToast('Medication updated successfully');
            renderTable();
        };

        // ---------- Archive / Restore ----------
        window.openArchiveModal = function (id, isCurrentlyArchived) {
            var m = medications.find(function (x) { return x.id === id; });
            if (!m) return;

            archiveTargetId = id;
            archiveTargetAction = isCurrentlyArchived ? 'Restore' : 'Archive';

            var icon = document.getElementById('archiveIcon');
            var title = document.getElementById('archiveTitle');
            var text = document.getElementById('archiveText');
            var btn = document.getElementById('archiveConfirmBtn');

            if (archiveTargetAction === 'Archive') {
                icon.className = 'cat-icon cat-icon-archive';
                icon.innerHTML = '<i class="bi bi-archive"></i>';
                title.textContent = 'Archive "' + m.name + '"?';
                text.textContent = 'Archived medications are hidden from selection lists but existing patient records that reference them are unaffected.';
                btn.textContent = 'Archive';
                btn.className = 'cat-modal-btn cat-modal-archive';
            } else {
                icon.className = 'cat-icon cat-icon-restore';
                icon.innerHTML = '<i class="bi bi-arrow-counterclockwise"></i>';
                title.textContent = 'Restore "' + m.name + '"?';
                text.textContent = 'This medication will become available again in selection lists across the system.';
                btn.textContent = 'Restore';
                btn.className = 'cat-modal-btn cat-modal-restore';
            }

            document.getElementById('archiveModal').classList.add('open');
        };

        window.closeArchiveModal = function () {
            document.getElementById('archiveModal').classList.remove('open');
            archiveTargetId = null;
            archiveTargetAction = null;
        };

        window.confirmArchive = function () {
            var m = medications.find(function (x) { return x.id === archiveTargetId; });
            if (m) m.status = archiveTargetAction === 'Archive' ? 'Archived' : 'Active';

            // TODO: replace with a real POST to your Medications controller.

            var action = archiveTargetAction;
            closeArchiveModal();
            showToast('Medication ' + (action === 'Archive' ? 'archived' : 'restored') + ' successfully');
            renderTable();
        };

        // ---------- Toast ----------
        var toastTimer = null;
        window.showToast = function (message) {
            var toast = document.getElementById('toast');
            toast.textContent = message;
            toast.style.display = 'block';
            clearTimeout(toastTimer);
            toastTimer = setTimeout(function () { toast.style.display = 'none'; }, 2200);
        };

        // ---------- Close modals on outside click ----------
        window.addEventListener('click', function (e) {
            if (e.target.id === 'addModal') closeAddModal();
            if (e.target.id === 'editModal') closeEditModal();
            if (e.target.id === 'archiveModal') closeArchiveModal();
        });

        renderTable();

    })();
</script>
