@{
    ViewData["Title"] = "Edit User";
    ViewData["ActivePage"] = "Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>

        /* =========================
           HEADER
        ========================= */
        .page-header {
            margin-bottom: 20px;
        }

        .page-header h2 {
            margin: 0;
            font-size: 22px;
        }

        .page-header p {
            font-size: 12px;
            color: var(--text-light);
            margin-top: 4px;
        }

        /* =========================
           FORM PANEL
        ========================= */
        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            max-width: 700px;
        }

        .field {
            margin-bottom: 16px;
        }

        .field label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 6px;
        }

        .field input,
        .field select {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 13px;
            outline: none;
        }

        .toggle {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
        }

        /* =========================
           MODAL
        ========================= */
        .modal-bg {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }

        .modal {
            background: white;
            padding: 22px;
            border-radius: 12px;
            width: 340px;
            text-align: center;
        }

    </style>
}

<!-- =========================
HEADER
========================= -->
<div class="page-header">
    <h2>Edit User</h2>
    <p>Modify user details (prototype view)</p>
</div>

<!-- =========================
FORM (STATIC)
========================= -->
<div class="panel">

    <div class="field">
        <label>Username</label>
        <input type="text" value="john.doe" />
    </div>

    <div class="field">
        <label>Email</label>
        <input type="email" value="john.doe@email.com" />
    </div>

    <div class="field">
        <label>Role</label>
        <select>
            <option selected>Doctor</option>
            <option>Admin</option>
            <option>Patient</option>
            <option>Lab Technician</option>
            <option>Lab Manager</option>
        </select>
    </div>

    <div class="field">
        <label>New Password (optional)</label>
        <input type="password" placeholder="Leave blank to keep current password" />
    </div>

    <div class="field toggle">
        <input type="checkbox" checked />
        <span>Active User</span>
    </div>

    <button type="button"
            onclick="openModal()"
            style="background:var(--accent);color:#fff;border:none;
            padding:10px 16px;border-radius:8px;font-size:13px;">
        Save Changes
    </button>

</div>

<!-- =========================
CONFIRM MODAL
========================= -->
<div id="confirmModal" class="modal-bg">

    <div class="modal">

        <h4>Confirm Update</h4>

        <p style="font-size:13px;color:var(--text-light);">
            Save changes to this user?
        </p>

        <div style="display:flex;gap:10px;justify-content:center;margin-top:14px;">

            <button onclick="closeModal()"
                    style="padding:8px 14px;border:1px solid var(--border);
                    border-radius:8px;background:white;">
                Cancel
            </button>

            <button onclick="showSuccess()"
                    style="padding:8px 14px;background:var(--accent);
                    color:white;border:none;border-radius:8px;">
                Confirm
            </button>

        </div>

    </div>

</div>

<!-- =========================
SUCCESS MODAL
========================= -->
<div id="successModal" class="modal-bg">

    <div class="modal">

        <div style="font-size:40px;color:#2ecc71;margin-bottom:10px;">
            <i class="bi bi-check-circle-fill"></i>
        </div>

        <h4 style="margin-bottom:6px;">Updated Successfully</h4>

        <p style="font-size:13px;color:var(--text-light);">
            User changes have been saved (prototype only).
        </p>

        <button onclick="closeSuccess()"
                style="margin-top:12px;padding:8px 14px;background:#2ecc71;
                color:white;border:none;border-radius:8px;">
            OK
        </button>

    </div>

</div>

<!-- =========================
SCRIPT
========================= -->
<script>

    function openModal() {
        document.getElementById("confirmModal").style.display = "flex";
    }

    function closeModal() {
        document.getElementById("confirmModal").style.display = "none";
    }

    function showSuccess() {
        closeModal();
        document.getElementById("successModal").style.display = "flex";
    }

    function closeSuccess() {
        document.getElementById("successModal").style.display = "none";
    }

    // close when clicking outside modal
    window.addEventListener("click", function (e) {
        const confirm = document.getElementById("confirmModal");
        const success = document.getElementById("successModal");

        if (e.target === confirm) closeModal();
        if (e.target === success) closeSuccess();
    });

</script>