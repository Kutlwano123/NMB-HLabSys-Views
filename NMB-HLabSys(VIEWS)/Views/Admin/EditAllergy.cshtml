@{
    ViewData["Title"] = "Edit Allergy";
    ViewData["ActivePage"] = "Allergies";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var id = ViewBag.AllergyId;
    var name = ViewBag.AllergyName;
    var status = ViewBag.Status;
}

@section Styles {
    <style>

        .page-header {
            margin-bottom: 20px;
        }

        .page-header h2 {
            margin: 0;
            font-size: 22px;
        }

        .page-header p {
            font-size: 12px;
            color: var(--text-light);
            margin-top: 4px;
        }

        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            max-width: 600px;
        }

        .field {
            margin-bottom: 16px;
        }

        .field label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 6px;
        }

        .field input,
        .field select {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 13px;
        }

        .btn-row {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        .btn-save {
            background: var(--accent);
            color: white;
            border: none;
            padding: 10px 16px;
            border-radius: 8px;
            font-size: 13px;
            cursor: pointer;
        }

        .btn-cancel {
            background: #eef0f3;
            color: #3a4a5a;
            text-decoration: none;
            padding: 10px 16px;
            border-radius: 8px;
            font-size: 13px;
        }

        .modal-bg {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }

        .modal {
            background: white;
            padding: 20px;
            border-radius: 12px;
            width: 340px;
            text-align: center;
        }

    </style>
}

<div class="page-header">

    <h2>Edit Allergy</h2>
    <p>Update allergy details (prototype view)</p>

</div>

<div class="panel">

    <div class="field">

        <label>Allergy Name</label>

        <input type="text" value="@name" />

    </div>

    <div class="field">

        <label>Status</label>

        <select>
            <option selected>@status</option>
            <option>Active</option>
            <option>Inactive</option>
        </select>

    </div>

    <div class="btn-row">

        <button class="btn-save" onclick="openModal()">
            Save Changes
        </button>

        <a href="~/Admin/Allergies" class="btn-cancel">
            Cancel
        </a>

    </div>

</div>

<!-- CONFIRM MODAL -->
<div id="confirmModal" class="modal-bg">

    <div class="modal">

        <h4>Confirm Update</h4>

        <p style="font-size:13px;color:gray;">
            Save changes to this allergy?
        </p>

        <div style="display:flex;gap:10px;justify-content:center;margin-top:15px;">

            <button onclick="closeModal()"
                    style="padding:8px 14px;border:1px solid #ccc;border-radius:8px;background:white;">
                Cancel
            </button>

            <button onclick="confirmSave()"
                    style="padding:8px 14px;background:var(--accent);color:white;border:none;border-radius:8px;">
                Save
            </button>

        </div>

    </div>

</div>

<script>

    function openModal() {
        document.getElementById("confirmModal").style.display = "flex";
    }

    function closeModal() {
        document.getElementById("confirmModal").style.display = "none";
    }

    function confirmSave() {
        closeModal();
        alert("Allergy updated (prototype)");
    }

    window.addEventListener("click", function (e) {
        const modal = document.getElementById("confirmModal");
        if (e.target === modal) closeModal();
    });

</script>