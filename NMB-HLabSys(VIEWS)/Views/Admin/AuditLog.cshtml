                <td><span class="badge-lite">Admin</span></td>
                <td><span class="action-badge action-login">Login</span></td>
                <td style="font-size:12px;color:var(--text-light);">User logged in</td>
                <td style="font-size:12px;color:var(--text-light);">192.168.1.10</td>
            </tr>

            <tr>
                <td style="font-size:12px;color:var(--text-light);">09:25</td>
