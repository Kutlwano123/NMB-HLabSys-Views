@{
    ViewData["Title"] = "Consent Management";
    ViewData["ActivePage"] = "Consent";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
}

@section Styles {
<style>
    .add-form {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 24px;
    }

    .add-form h4 {
        margin-bottom: 14px;
        font-size: 15px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr auto;
        gap: 10px;
        align-items: end;
    }

    .form-group label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-mid);
        margin-bottom: 5px;
    }

    .form-group select {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 13px;
        background: var(--bg);
        outline: none;
    }

    .custom-modal {
        display: none;
        position: fixed;
        z-index: 9999;
        inset: 0;
        background: rgba(0,0,0,0.45);
        backdrop-filter: blur(4px);
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .custom-modal-content {
        background: var(--surface);
        width: 100%;
        max-width: 420px;
        border-radius: 18px;
        padding: 28px;
        text-align: center;
        animation: modalFade .25s ease;
    }

    .modal-icon {
        width: 70px;
        height: 70px;
        margin: 0 auto 18px;
        border-radius: 50%;
        background: rgba(122,48,48,0.08);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-icon i {
        font-size: 30px;
        color: var(--accent);
    }

    .modal-actions {
        display: flex;
        gap: 12px;
        margin-top: 18px;
    }

    .modal-actions button {
        flex: 1;
        border: none;
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-cancel { background: #f1f1f1; }
    .btn-revoke { background: var(--accent); color: white; }

    @@keyframes modalFade {
        from { opacity: 0; transform: scale(.92); }
        to { opacity: 1; transform: scale(1); }
    }
</style>
}

<div style="margin-bottom:20px;">
    <h2 style="margin:0;">Consent Management</h2>
    <p style="color:var(--text-light);font-size:13px;margin-top:4px;">
        Control which doctors can access your test results
    </p>
</div>

<!-- =========================
GRANT FORM (STATIC)
========================= -->
<div class="add-form">
    <h4><i class="bi bi-shield-plus" style="color:var(--accent);"></i> Grant Access to a Doctor</h4>

    <form>
        <div class="form-row">

            <div class="form-group">
                <label>Doctor ID</label>
                <select>
                    <option>— Select Doctor —</option>
                    <option>Dr Modise</option>
                    <option>Dr Smith</option>
                    <option>Dr Johnson</option>
                </select>
            </div>

            <div class="form-group">
                <label>Test Request</label>
                <select>
                    <option>— Select Request —</option>
                    <option>Request #1 — 12 May 2026</option>
                    <option>Request #2 — 15 May 2026</option>
                    <option>Request #3 — 20 May 2026</option>
                </select>
            </div>

            <button type="button" class="btn-primary" style="height:42px;">
                <i class="bi bi-shield-check"></i> Grant
            </button>

        </div>
    </form>
</div>

<!-- =========================
TABLE TITLE
========================= -->
<div style="font-family:'DM Serif Display',serif;font-size:16px;margin-bottom:14px;">
    Active Consents
</div>

<!-- =========================
TABLE (STATIC DATA)
========================= -->
<div class="card" style="padding:0;overflow:hidden;">
    <table class="table" style="margin:0;">
        <thead>
            <tr>
                <th>#</th>
                <th>Doctor ID</th>
                <th>Request #</th>
                <th>Granted Date</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody id="consentTable"></tbody>
    </table>
</div>

<!-- =========================
MODAL
========================= -->
<div id="revokeModal" class="custom-modal">
    <div class="custom-modal-content">

        <div class="modal-icon">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>

        <h3>Revoke Consent?</h3>
        <p>This doctor will immediately lose access.</p>

        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeRevokeModal()">Cancel</button>
            <button class="btn-revoke" onclick="revokeConfirmed()">Revoke</button>
        </div>

    </div>
</div>

<script>
    // =========================
    // STATIC DATA SOURCE
    // =========================
    const consents = [
        { id: 1, doctor: 101, request: 12, date: "10 May 2026" },
        { id: 2, doctor: 205, request: 14, date: "15 May 2026" },
        { id: 3, doctor: 309, request: 18, date: "20 May 2026" }
    ];

    let selectedConsentId = null;

    // =========================
    // RENDER TABLE
    // =========================
    function renderTable() {
        const table = document.getElementById("consentTable");
        table.innerHTML = "";

        consents.forEach((c, i) => {
            table.innerHTML += `
                <tr>
                    <td style="color:var(--text-light);font-size:12px;">${i + 1}</td>
                    <td>Doctor #${c.doctor}</td>
                    <td>Request #${c.request}</td>
                    <td style="font-size:12px;color:var(--text-light);">${c.date}</td>
                    <td>
                        <span style="font-size:11px;background:#e8f0e8;color:#3a6b3a;padding:2px 8px;border-radius:10px;">
                            Active
                        </span>
                    </td>
                    <td>
                        <button onclick="openRevokeModal(${c.id})"
                            style="background:var(--accent-pale);border:1px solid var(--border);padding:4px 10px;border-radius:6px;">
                            Revoke
                        </button>
                    </td>
                </tr>
            `;
        });
    }

    // =========================
    // MODAL LOGIC
    // =========================
    function openRevokeModal(id) {
        selectedConsentId = id;
        document.getElementById("revokeModal").style.display = "flex";
    }

    function closeRevokeModal() {
        document.getElementById("revokeModal").style.display = "none";
    }

    function revokeConfirmed() {
        const index = consents.findIndex(c => c.id === selectedConsentId);
        if (index !== -1) consents.splice(index, 1);

        closeRevokeModal();
        renderTable();
    }

    window.onclick = function (e) {
        if (e.target.id === "revokeModal") closeRevokeModal();
    };

    // INIT
    renderTable();
</script>