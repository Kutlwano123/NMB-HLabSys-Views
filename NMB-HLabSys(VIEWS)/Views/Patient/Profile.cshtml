@{
    ViewData["Title"] = "My Profile";
    ViewData["ActivePage"] = "Profile";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";

    // Safely extract raw string values supplied by the controller
    string firstName = ViewBag.FirstName as string ?? string.Empty;
    string surname = ViewBag.Surname as string ?? string.Empty;
    string idNumber = ViewBag.IdNumber as string ?? string.Empty;
    string dateOfBirth = ViewBag.DateOfBirth as string ?? string.Empty;
    string phone = ViewBag.Phone as string ?? string.Empty;
    string email = ViewBag.Email as string ?? string.Empty;
    string address = ViewBag.Address as string ?? string.Empty;
}

@section Styles {

    <style>

        .success-alert {
            background: #e8f5e9;
            border: 1px solid #c8e6c9;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 13px;
            color: #2e7d32;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .error-alert {
            background: #fdecea;
            border: 1px solid #f5c6cb;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 13px;
            color: #a52a2a;
            margin-bottom: 18px;
        }

        .settings-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            align-items: start;
        }

        @@media (max-width: 900px) {
            .settings-grid {
                grid-template-columns: 1fr;
            }
        }

        .card h3 {
            margin-top: 0;
            font-family: 'DM Serif Display', serif;
            font-size: 17px;
        }

        .card-desc {
            color: var(--text-light);
            font-size: 12.5px;
            margin-top: -6px;
            margin-bottom: 18px;
        }

        .form-row.cols-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .form-group {
            margin-bottom: 16px;
        }

            .form-group label {
                display: block;
                font-size: 12px;
                font-weight: 600;
                margin-bottom: 5px;
                color: var(--text, #2b2b2b);
            }

        .form-control[readonly] {
            background: #f4f4f4;
            color: var(--text-light);
            cursor: not-allowed;
        }

        .pw-hint {
            font-size: 11.5px;
            color: var(--text-light);
            margin-top: -8px;
            margin-bottom: 16px;
        }

        .pw-strength-bars span {
            flex: 1;
            height: 4px;
            background: var(--border);
            border-radius: 2px;
            transition: background 0.2s;
        }

        /* --- Confirm modal (profile save) --- */
        .custom-modal {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(0,0,0,0.45);
            backdrop-filter: blur(4px);
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

            .custom-modal.open {
                display: flex;
            }

        .custom-modal-content {
            background: var(--surface);
            width: 100%;
            max-width: 520px;
            border-radius: 18px;
            padding: 28px;
            animation: modalFade .25s ease;
            box-shadow: 0 20px 50px rgba(0,0,0,0.18);
        }

        .modal-icon {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: var(--accent-pale);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 18px;
        }

            .modal-icon i {
                font-size: 30px;
                color: var(--accent);
            }

        .summary-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 20px;
        }

        .summary-box {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 12px;
        }

        .summary-label {
            font-size: 11px;
            color: var(--text-light);
            margin-bottom: 4px;
        }

        .summary-value {
            font-size: 13px;
            font-weight: 600;
            word-break: break-word;
        }

        .modal-actions {
            display: flex;
            gap: 12px;
            margin-top: 24px;
        }

            .modal-actions button {
                flex: 1;
                border: none;
                border-radius: 10px;
                padding: 12px;
                cursor: pointer;
                font-weight: 600;
            }

        .btn-cancel {
            background: #ececec;
        }

        .btn-save {
            background: var(--accent);
            color: white;
        }

            .btn-save:disabled {
                opacity: 0.6;
                cursor: not-allowed;
            }

        @@keyframes modalFade {
            from {
                opacity: 0;
                transform: scale(.94);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

    </style>

}

<div style="margin-bottom:20px;">
    <h2 style="margin:0;">My Profile</h2>
    <p style="color:var(--text-light);font-size:13px;margin-top:4px;">
        View and update your personal details, contact information, and password.
    </p>
</div>

@if (TempData["ProfileSuccess"] != null)
{
    <div class="success-alert" role="status">
        <i class="bi bi-check-circle-fill"></i>
        @TempData["ProfileSuccess"]
    </div>
}

@if (TempData["ProfileError"] != null)
{
    <div class="error-alert" role="alert">
        @TempData["ProfileError"]
    </div>
}

<div class="settings-grid">

    <!-- PROFILE & CONTACT -->
    <section class="card">

        <h3>Profile &amp; Contact</h3>
        <p class="card-desc">Update your personal and contact details. Your current password is required to save changes.</p>

        <form id="profileForm" asp-action="UpdateProfile" asp-controller="Patient" method="post">
            @Html.AntiForgeryToken()

            <div class="form-row cols-2">
                <div class="form-group">
                    <label for="nameInput">First Name</label>
                    <input id="nameInput" name="firstName" class="form-control" value="@firstName" placeholder="First Name" autocomplete="given-name" required />
                </div>
                <div class="form-group">
                    <label for="surnameInput">Surname</label>
                    <input id="surnameInput" name="surname" class="form-control" value="@surname" placeholder="Surname" autocomplete="family-name" required />
                </div>
            </div>

            <div class="form-group">
                <label for="saIdNumber">SA ID Number</label>
                <input id="saIdNumber" name="idNumber" class="form-control" value="@idNumber" maxlength="13" inputmode="numeric" pattern="\d{13}" placeholder="13-digit SA ID number" />
                @* <div class="pw-hint" id="idHint">Your date of birth is worked out automatically from the first 6 digits.</div> *@
                <div class="pw-hint" id="idErrorHint" style="display:none;color:#a52a2a;">That doesn't look like a valid SA ID number — check the first 6 digits (YYMMDD).</div>
            </div>

            <div class="form-group">
                <label for="dateOfBirth">Date of Birth</label>
                <input id="dateOfBirth" name="dateOfBirth" class="form-control" value="@dateOfBirth" readonly title="Calculated automatically from your ID number" />
            </div>

            <div class="form-row cols-2">
                <div class="form-group">
                    <label for="phoneInput">Phone Number</label>
                    <input id="phoneInput" name="phone" type="tel" class="form-control" value="@phone" placeholder="+27 …" autocomplete="tel" required />
                </div>
                <div class="form-group">
                    <label for="emailInput">Email Address</label>
                    <input id="emailInput" name="email" type="email" class="form-control" value="@email" autocomplete="email" required />
                </div>
            </div>

            <div class="form-group">
                <label for="addressInput">Address</label>
                <input id="addressInput" name="address" class="form-control" value="@address" placeholder="Street, City" autocomplete="street-address" required />
            </div>

            

            <button type="button" class="btn-primary" onclick="openProfileModal()">
                <i class="bi bi-save"></i>
                Save Changes
            </button>

        </form>

    </section>

    <!-- CHANGE PASSWORD -->
    <section class="card">

        <h3>Change Password</h3>
        <p class="card-desc">Choose a strong password with at least 8 characters, including uppercase, a number, and a special character.</p>

        <form asp-action="UpdatePassword" asp-controller="Patient" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group" style="margin-top:15px;padding-top:15px;border-top:1px solid #eee;">
                <label for="currentPasswordProfile">Confirm Current Password <span class="text-danger">*</span></label>
                <input id="currentPasswordProfile" name="currentPassword" type="password" class="form-control" autocomplete="current-password" required />
            </div>

            <div class="form-group">
                <label for="pwdNew">New Password</label>
                <input id="pwdNew" name="newPassword" type="password" class="form-control" autocomplete="new-password" required />
                <div class="pw-strength-bars" id="pwBars" aria-hidden="true" style="display:flex;gap:4px;margin-top:5px;">
                    <span></span><span></span><span></span><span></span>
                </div>
                <div class="pw-hint">Uppercase, number, and special character all improve strength.</div>
            </div>

            <div class="form-group">
                <label for="pwdConfirm">Confirm New Password</label>
                <input id="pwdConfirm" name="confirmPassword" type="password" class="form-control" autocomplete="new-password" required />
                <div class="pw-hint" id="pwMatchHint" style="display:none;color:#a52a2a;">Passwords don't match.</div>
            </div>

            <button type="submit" class="btn-primary" id="pwSubmitBtn">
                <i class="bi bi-shield-lock"></i>
                Update Password
            </button>
            

        </form>

    </section>

</div>

<!-- PROFILE CONFIRM MODAL -->
<div id="profileModal" class="custom-modal" role="dialog" aria-modal="true" aria-labelledby="profileModalTitle">

    <div class="custom-modal-content">

        <div class="modal-icon">
            <i class="bi bi-person-check"></i>
        </div>

        <h3 id="profileModalTitle" style="text-align:center;">Confirm Profile Update</h3>
        <p style="text-align:center;color:var(--text-light);font-size:13px;">Review your details before saving</p>

        <div class="summary-grid">

            <div class="summary-box">
                <div class="summary-label">Name</div>
                <div class="summary-value" id="summaryName"></div>
            </div>

            <div class="summary-box">
                <div class="summary-label">Surname</div>
                <div class="summary-value" id="summarySurname"></div>
            </div>

            <div class="summary-box">
                <div class="summary-label">Phone</div>
                <div class="summary-value" id="summaryPhone"></div>
            </div>

            <div class="summary-box">
                <div class="summary-label">Email</div>
                <div class="summary-value" id="summaryEmail"></div>
            </div>

            <div class="summary-box" style="grid-column:1 / -1;">
                <div class="summary-label">Address</div>
                <div class="summary-value" id="summaryAddress"></div>
            </div>

        </div>

        <div class="modal-actions">

            <button class="btn-cancel" type="button" onclick="closeProfileModal()">
                Cancel
            </button>

            <button class="btn-save" type="button" id="confirmSaveBtn" onclick="submitProfileForm()">
                Confirm &amp; Save
            </button>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            // ---------- Profile confirm modal ----------
            var modal = document.getElementById('profileModal');
            var lastFocused = null;

            window.openProfileModal = function () {
                var form = document.getElementById('profileForm');
                if (!form.reportValidity()) return; // require native validation (incl. current password) first

                document.getElementById('summaryName').innerText = document.getElementById('nameInput').value;
                document.getElementById('summarySurname').innerText = document.getElementById('surnameInput').value;
                document.getElementById('summaryPhone').innerText = document.getElementById('phoneInput').value;
                document.getElementById('summaryEmail').innerText = document.getElementById('emailInput').value;
                document.getElementById('summaryAddress').innerText = document.getElementById('addressInput').value;

                lastFocused = document.activeElement;
                modal.classList.add('open');
                document.getElementById('confirmSaveBtn').focus();
            };

            window.closeProfileModal = function () {
                modal.classList.remove('open');
                if (lastFocused) lastFocused.focus();
            };

            window.submitProfileForm = function () {
                var btn = document.getElementById('confirmSaveBtn');
                btn.disabled = true;
                btn.textContent = 'Saving…';
                document.getElementById('profileForm').submit();
            };

            modal.addEventListener('click', function (e) {
                if (e.target === modal) closeProfileModal();
            });
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && modal.classList.contains('open')) closeProfileModal();
            });

            // ---------- SA ID number → auto date of birth ----------
            var idInput = document.getElementById('saIdNumber');
            var dobInput = document.getElementById('dateOfBirth');
            var idErrorHint = document.getElementById('idErrorHint');

            function pad(n) {
                return n < 10 ? '0' + n : '' + n;
            }

            // Reads the first 6 digits (YYMMDD) of an SA ID number and returns
            // an { year, month, day } object, or null if they don't form a real date.
            function parseDobFromId(id) {
                if (!/^\d{6}/.test(id)) return null;

                var yy = parseInt(id.substring(0, 2), 10);
                var mm = parseInt(id.substring(2, 4), 10);
                var dd = parseInt(id.substring(4, 6), 10);

                if (mm < 1 || mm > 12) return null;

                // SA ID numbers don't encode the century directly, so we use the
                // common convention: if treating yy as 20yy gives a future date,
                // it must actually be 19yy instead.
                var currentYear = new Date().getFullYear();
                var currentYY = currentYear % 100;
                var century = (yy <= currentYY) ? 2000 : 1900;
                var fullYear = century + yy;

                var date = new Date(fullYear, mm - 1, dd);
                var isRealDate = date.getFullYear() === fullYear &&
                    date.getMonth() === mm - 1 &&
                    date.getDate() === dd;

                if (!isRealDate) return null;

                return { year: fullYear, month: mm, day: dd };
            }

            function updateDobFromId() {
                var digitsOnly = idInput.value.replace(/\D/g, '');
                if (digitsOnly !== idInput.value) {
                    idInput.value = digitsOnly;
                }

                if (digitsOnly.length < 6) {
                    dobInput.value = '';
                    idErrorHint.style.display = 'none';
                    idInput.setCustomValidity('');
                    return;
                }

                var dob = parseDobFromId(digitsOnly);

                if (!dob) {
                    dobInput.value = '';
                    idErrorHint.style.display = 'block';
                    idInput.setCustomValidity('Invalid SA ID number');
                    return;
                }

                idErrorHint.style.display = 'none';
                idInput.setCustomValidity('');
                dobInput.value = dob.year + '-' + pad(dob.month) + '-' + pad(dob.day);
            }

            if (idInput && dobInput) {
                idInput.addEventListener('input', updateDobFromId);
                // populate on page load in case the ID field already has a value
                updateDobFromId();
            }

            // ---------- Password strength meter ----------

            var pwInput = document.getElementById('pwdNew');
            var bars = document.querySelectorAll('#pwBars span');
            if (pwInput && bars.length) {
                pwInput.addEventListener('input', function () {
                    var pw = pwInput.value;
                    var score = [pw.length >= 8, /[A-Z]/.test(pw), /\d/.test(pw), /[^a-zA-Z\d]/.test(pw)].filter(Boolean).length;
                    var colors = ['#e0e0e0', '#c41e3a', '#8a6a20', '#2d5a4a', '#2d5a4a'];
                    bars.forEach(function (b, i) {
                        b.style.background = i < score ? colors[score] : '#e0e0e0';
                    });
                });
            }

            // ---------- Confirm-password live check ----------
            var pwNew = document.getElementById('pwdNew');
            var pwConfirm = document.getElementById('pwdConfirm');
            var pwMatchHint = document.getElementById('pwMatchHint');
            var pwSubmitBtn = document.getElementById('pwSubmitBtn');

            function checkMatch() {
                if (pwConfirm.value && pwNew.value !== pwConfirm.value) {
                    pwMatchHint.style.display = 'block';
                    pwConfirm.setCustomValidity('Passwords do not match');
                } else {
                    pwMatchHint.style.display = 'none';
                    pwConfirm.setCustomValidity('');
                }
            }

            if (pwNew && pwConfirm) {
                pwNew.addEventListener('input', checkMatch);
                pwConfirm.addEventListener('input', checkMatch);
            }
        })();
    </script>
}
