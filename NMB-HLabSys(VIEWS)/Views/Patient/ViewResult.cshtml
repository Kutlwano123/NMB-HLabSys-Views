@{
    ViewData["Title"] = "Laboratory Report";
    ViewData["ActivePage"] = "TestRequests";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";

    // =========================
    // STATIC DUMMY DATA
    // =========================
    var report = new
    {
        ReportNo = "LAB-2026-000124",
        LabName = "NMB Laboratory Services",
        LabSubtitle = "Nelson Mandela Bay Municipality",

        PatientName = "Yash M. Patel",
        PatientId = "P000555",
        Gender = "Male",
        Age = 21,
        DateOfBirth = new DateTime(2005, 3, 12),
        Doctor = "Dr. Hiren Shah",
        Ward = "Internal Medicine",

        SampleType = "Whole Blood",
        Collected = new DateTime(2026, 4, 5, 9, 15, 0),
        Received = new DateTime(2026, 4, 5, 9, 45, 0),
        Reported = new DateTime(2026, 4, 5, 14, 30, 0),
        LabSection = "Haematology",

        TestName = "Full Blood Count",
        Category = "Haematology",
        RequestId = 12,

        Verified = true,
        VerifiedBy = "Dr. Payal Shah",
        VerifiedTitle = "Consultant Pathologist",

        GeneratedOn = new DateTime(2026, 4, 5, 14, 31, 0)
    };

    // Each result: Name, Result, Unit, RangeLow, RangeHigh, RangeText (for text ranges)
    var results = new[]
{
    new { Name = "Haemoglobin (Hb)", Result = 13.8, Unit = "g/dL", Low = 12.0, High = 16.0 },
    new { Name = "RBC Count", Result = 4.95, Unit = "x10¹²/L", Low = 4.2, High = 5.4 },
    new { Name = "WBC Count", Result = 7.4, Unit = "x10⁹/L", Low = 4.0, High = 11.0 },
    new { Name = "Platelet Count", Result = 255.0, Unit = "x10⁹/L", Low = 150.0, High = 450.0 },
    new { Name = "Haematocrit (PCV)", Result = 42.1, Unit = "%", Low = 37.0, High = 47.0 },
    new { Name = "MCV", Result = 88.0, Unit = "fL", Low = 80.0, High = 96.0 },
    new { Name = "MCH", Result = 30.0, Unit = "pg", Low = 27.0, High = 33.0 },
    new { Name = "MCHC", Result = 34.0, Unit = "g/dL", Low = 32.0, High = 36.0 },
    new { Name = "RDW", Result = 13.4, Unit = "%", Low = 11.5, High = 14.5 }
};

    // Helper flags for each result row
    Func<double, double, double, string> getStatus = (val, low, high) =>
        val < low ? "LOW" : (val > high ? "HIGH" : "NORMAL");

    var anyAbnormal = results.Any(r => getStatus(r.Result, r.Low, r.High) != "NORMAL");
}

<style>

    .report-container {
        background: #fff;
        border: 1px solid #e6e6e6;
        border-radius: 14px;
        padding: 25px;
        max-width: 950px;
        margin: auto;
    }

    /* ===== TOP ACTION BAR ===== */
    .action-bar {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        max-width: 950px;
        margin: 0 auto 12px auto;
    }

    .action-btn {
        border: 1px solid #d8dce0;
        background: #fff;
        color: #333;
        padding: 8px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .action-btn:hover {
            background: #f4f6f8;
        }

        .action-btn.primary {
            background: #155724;
            color: #fff;
            border-color: #155724;
        }

            .action-btn.primary:hover {
                background: #0f421b;
            }

    /* ===== HEADER ===== */
    .report-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        border-bottom: 2px solid #eee;
        padding-bottom: 15px;
        margin-bottom: 20px;
    }

    .hospital-title {
        font-size: 19px;
        font-weight: 700;
        letter-spacing: 0.3px;
    }

    .hospital-subtitle {
        font-size: 12px;
        color: #666;
        margin-top: 2px;
    }

    .report-type {
        font-size: 13px;
        color: #444;
        font-weight: 600;
        margin-top: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .header-right {
        text-align: right;
    }

    .report-id {
        font-size: 12px;
        color: #555;
        margin-bottom: 6px;
    }

        .report-id b {
            color: #222;
        }

    .badge-status {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
    }

    .verified {
        background: #d4edda;
        color: #155724;
    }

    .pending {
        background: #fff3cd;
        color: #856404;
    }

    /* ===== INFO SECTIONS ===== */
    .section-title {
        margin-top: 20px;
        margin-bottom: 10px;
        font-weight: 700;
        font-size: 14px;
        color: #222;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 10px;
    }

    .box {
        background: #f8f9fa;
        padding: 12px;
        border-radius: 10px;
    }

    .label {
        font-size: 11px;
        color: #777;
    }

    .value {
        font-weight: 600;
        font-size: 13px;
        color: #222;
    }

    /* ===== RESULTS TABLE ===== */
    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
    }

    th, td {
        border-bottom: 1px solid #eee;
        padding: 12px;
        font-size: 13px;
        text-align: left;
    }

    th {
        background: #fafafa;
    }

    .normal {
        color: green;
        font-weight: 600;
    }

    .abnormal {
        color: #c0392b;
        font-weight: 700;
    }

    .flag-normal {
        color: green;
        font-weight: 600;
    }

    .flag-abnormal {
        color: #c0392b;
        font-weight: 700;
    }

    /* ===== INTERPRETATION ===== */
    .interpretation-box {
        margin-top: 10px;
        padding: 14px 16px;
        border-radius: 10px;
        border: 1px solid #eee;
        background: #fafafa;
        font-size: 13px;
        line-height: 1.7;
    }

        .interpretation-box ul {
            margin: 0 0 8px 18px;
            padding: 0;
        }

    .interpretation-summary {
        font-weight: 600;
        margin-top: 6px;
    }

    /* ===== FOOTER / SIGN-OFF ===== */
    .report-footer {
        margin-top: 30px;
        padding-top: 18px;
        border-top: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .signoff .name {
        font-weight: 700;
        font-size: 14px;
        margin-bottom: 2px;
    }

    .signoff .title {
        font-size: 12px;
        color: #666;
    }

    .signoff .verified-note {
        font-size: 11px;
        color: #155724;
        margin-top: 4px;
    }

    .footer-meta {
        text-align: right;
        font-size: 11px;
        color: #888;
    }

    @@media print {
        .action-bar {
            display: none !important;
        }

        body {
            background: #fff !important;
        }

        .report-container {
            border: none;
            padding: 0;
        }
    }

</style>

<!-- BACK BUTTON -->
<a href="~/Patient/TestRequests"
   class="btn btn-light"
   style="margin-bottom:15px;">

    <i class="bi bi-arrow-left"></i>
    Back to Results

</a>

<!-- ACTION BUTTONS -->
<div class="action-bar">
    <button class="action-btn" onclick="window.print()">
        <i class="bi bi-printer"></i> Print Report
    </button>
    <button class="action-btn primary" onclick="window.print()">
        <i class="bi bi-download"></i> Download PDF
    </button>
    <button class="action-btn" onclick="navigator.share ? navigator.share({ title: 'Lab Report', url: window.location.href }) : alert('Copy this link to share: ' + window.location.href)">
        <i class="bi bi-share"></i> Share
    </button>
</div>

<div class="report-container">

    <!-- HEADER -->
    <div class="report-header">

        <div>
            <div class="hospital-title">@report.LabName.ToUpper()</div>
            <div class="hospital-subtitle">@report.LabSubtitle</div>
            <div class="report-type">Laboratory Test Report</div>
        </div>

        <div class="header-right">
            <div class="report-id">Report No: <b>@report.ReportNo</b></div>
            <div class="report-id">Generated: <b>@report.GeneratedOn.ToString("dd MMM yyyy HH:mm")</b></div>
            @if (report.Verified)
            {
                <span class="badge-status verified">&#10003; VERIFIED</span>
            }
            else
            {
                <span class="badge-status pending">PENDING</span>
            }
        </div>

    </div>

    <!-- PATIENT INFO -->
    <div class="section-title">Patient Information</div>
    <div class="info-grid">

        <div class="box">
            <div class="label">Patient Name</div>
            <div class="value">@report.PatientName</div>
        </div>

        <div class="box">
            <div class="label">Patient ID</div>
            <div class="value">@report.PatientId</div>
        </div>

        <div class="box">
            <div class="label">Gender</div>
            <div class="value">@report.Gender</div>
        </div>

        <div class="box">
            <div class="label">Age</div>
            <div class="value">@report.Age years</div>
        </div>

        <div class="box">
            <div class="label">Date of Birth</div>
            <div class="value">@report.DateOfBirth.ToString("dd MMM yyyy")</div>
        </div>

        <div class="box">
            <div class="label">Referring Doctor</div>
            <div class="value">@report.Doctor</div>
        </div>

        <div class="box">
            <div class="label">Ward / Clinic</div>
            <div class="value">@report.Ward</div>
        </div>

        <div class="box">
            <div class="label">Request ID</div>
            <div class="value">#@report.RequestId</div>
        </div>

    </div>

    <!-- SAMPLE INFO -->
    <div class="section-title">Specimen Information</div>
    <div class="info-grid">

        <div class="box">
            <div class="label">Sample Type</div>
            <div class="value">@report.SampleType</div>
        </div>

        <div class="box">
            <div class="label">Collected</div>
            <div class="value">@report.Collected.ToString("dd MMM yyyy HH:mm")</div>
        </div>

        <div class="box">
            <div class="label">Received</div>
            <div class="value">@report.Received.ToString("dd MMM yyyy HH:mm")</div>
        </div>

        <div class="box">
            <div class="label">Reported</div>
            <div class="value">@report.Reported.ToString("dd MMM yyyy HH:mm")</div>
        </div>

        <div class="box">
            <div class="label">Laboratory Section</div>
            <div class="value">@report.LabSection</div>
        </div>

        <div class="box">
            <div class="label">Test Name</div>
            <div class="value">@report.TestName</div>
        </div>

    </div>

    <!-- RESULT TABLE -->
    <div class="section-title">Laboratory Results &ndash; @report.TestName</div>

    <table>
        <thead>
            <tr>
                <th>Test</th>
                <th>Result</th>
                <th>Unit</th>
                <th>Reference Range</th>
                <th>Flag</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var r in results)
            {
                var flag = getStatus(r.Result, r.Low, r.High);
                <tr>
                    <td>@r.Name</td>
                    <td class="@(flag == "NORMAL" ? "" : "abnormal")">@r.Result</td>
                    <td>@r.Unit</td>
                    <td>@r.Low &ndash; @r.High</td>
                    <td>
                        @if (flag == "NORMAL")
                        {
                            <span class="flag-normal">&#10003; Normal</span>
                        }
                        else
                        {
                            <span class="flag-abnormal">@flag</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- INTERPRETATION -->
    <div class="section-title">Clinical Interpretation</div>

    <div class="interpretation-box">
        <ul>
            @foreach (var r in results)
            {
                var flag = getStatus(r.Result, r.Low, r.High);
                if (flag == "NORMAL")
                {
                    <li class="normal">@r.Name is within normal limits.</li>
                }
                else
                {
                    <li class="abnormal">@r.Name is @flag.ToLower() (@r.Result @r.Unit); reference @r.Low &ndash; @r.High @r.Unit.</li>
                }
            }
        </ul>

        <div class="interpretation-summary @(anyAbnormal ? "abnormal" : "normal")">
            @if (anyAbnormal)
            {
                <span>Overall findings show one or more parameters outside the reference range. Clinical correlation is recommended.</span>
            }
            else
            {
                <span>Overall findings are consistent with a normal Full Blood Count.</span>
            }
        </div>
    </div>

    <!-- FOOTER / SIGN-OFF -->
    <div class="report-footer">
        <div class="signoff">
            <div class="name">@report.VerifiedBy</div>
            <div class="title">@report.VerifiedTitle</div>
            @if (report.Verified)
            {
                <div class="verified-note">&#10003; Electronically verified</div>
            }
        </div>

        <div class="footer-meta">
            Generated: @report.GeneratedOn.ToString("dd MMM yyyy HH:mm")<br />
            Page 1 of 1
        </div>
    </div>

</div>
