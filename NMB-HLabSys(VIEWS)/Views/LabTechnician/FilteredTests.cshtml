@model NMB_HLabSys_VIEWS.ViewModels.FilteredTestListViewModel
@{
    ViewData["Title"] = "Filtered Test List";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
    ViewData["ActivePage"] = "FilteredTests";
}

<h2>Test List with Advanced Filtering</h2>

<div class="card mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0">
            <i class="bi bi-funnel"></i> Filter Options
            <a class="btn btn-sm btn-outline-secondary float-end" data-bs-toggle="collapse" href="#filterPanel">
                <i class="bi bi-chevron-down"></i> Expand
            </a>
        </h5>
    </div>
    <div class="card-body collapse show" id="filterPanel">
        <form method="get" asp-action="FilteredTests" class="needs-validation">
            <div class="row mb-3">
                <div class="col-md-3">
                    <label class="form-label">Search (Request #, Patient, Test)</label>
                    <input type="text" name="searchTerm" class="form-control" value="@Model.CurrentFilter.SearchTerm" placeholder="Type to search..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Urgency</label>
                    <select name="urgencyFilter" class="form-select">
                        <option value="">-- All Urgencies --</option>
                        @foreach (var u in Model.CurrentFilter.AvailableUrgencies)
                        {
                            if (Model.CurrentFilter.UrgencyFilter == u)
                            {
                                <option value="@u" selected>@u</option>
                            }
                            else
                            {
                                <option value="@u">@u</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select name="statusFilter" class="form-select">
                        <option value="">-- All Statuses --</option>
                        @foreach (var s in Model.CurrentFilter.AvailableStatuses)
                        {
                            if (Model.CurrentFilter.StatusFilter == s)
                            {
                                <option value="@s" selected>@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Category</label>
                    <select name="categoryFilter" class="form-select">
                        <option value="">-- All Categories --</option>
                        @foreach (var c in Model.CurrentFilter.AvailableCategories)
                        {
                            if (Model.CurrentFilter.CategoryFilter == c)
                            {
                                <option value="@c" selected>@c</option>
                            }
                            else
                            {
                                <option value="@c">@c</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-3">
                    <label class="form-label">From Date</label>
                    <input type="date" name="fromDate" class="form-control" value="@Model.CurrentFilter.FromDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">To Date</label>
                    <input type="date" name="toDate" class="form-control" value="@Model.CurrentFilter.ToDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Sort By</label>
                    <select name="sortBy" class="form-select">
                        @{
                            var sortByOptions = new[] { ("DueDate", "Due Date"), ("RequestDate", "Request Date"), ("Urgency", "Urgency"), ("Patient", "Patient Name"), ("TestName", "Test Name") };
                        }
                        @foreach (var (value, label) in sortByOptions)
                        {
                            if (Model.CurrentFilter.SortBy == value)
                            {
                                <option value="@value" selected>@label</option>
                            }
                            else
                            {
                                <option value="@value">@label</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Sort Order</label>
                    <select name="sortOrder" class="form-select">
                        @if (Model.CurrentFilter.SortOrder == "asc")
                        {
                            <option value="asc" selected>Ascending</option>
                            <option value="desc">Descending</option>
                        }
                        else
                        {
                            <option value="asc">Ascending</option>
                            <option value="desc" selected>Descending</option>
                        }
                    </select>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> Apply Filters
                </button>
                <a href="/LabTechnician/FilteredTests" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-clockwise"></i> Reset
                </a>
            </div>
        </form>
    </div>
</div>

<div class="alert alert-info mb-3">
    Showing <strong>@Model.FilteredCount</strong> of <strong>@Model.TotalCount</strong> tests
</div>

@if (!Model.Tests.Any())
{
    <div class="alert alert-warning">
        <i class="bi bi-info-circle"></i> No tests match the selected filters.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Request #</th>
                    <th>Patient</th>
                    <th>Test</th>
                    <th>Category</th>
                    <th>Urgency</th>
                    <th>Status</th>
                    <th>Requested</th>
                    <th>Due Date</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var test in Model.Tests)
                {
                    var rowClass = test.IsOverdue ? "table-danger" : (test.Urgency == "STAT" || test.Urgency == "Urgent" ? "table-warning" : "");
                    <tr class="@rowClass">
                        <td>
                            <strong>@test.RequestNumber</strong>
                            @if (test.IsOverdue)
                            {
                                <span class="badge bg-danger">Overdue</span>
                            }
                        </td>
                        <td>@test.PatientName</td>
                        <td>@test.TestName</td>
                        <td>@test.Category</td>
                        <td>
                            <span class="badge @(test.Urgency == "STAT" ? "bg-danger" : test.Urgency == "Urgent" ? "bg-warning text-dark" : "bg-secondary")">
                                @test.Urgency
                            </span>
                        </td>
                        <td>@test.Status</td>
                        <td>@test.RequestDate.ToString("g")</td>
                        <td>
                            @if (test.DueDate.HasValue)
                            {
                                <span class="@(test.IsOverdue ? "text-danger fw-bold" : "")">
                                    @test.DueDate.Value.ToString("g")
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-center">
                            <a href="/LabTechnician/CaptureResultForm?requestId=@test.TestRequestId" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
