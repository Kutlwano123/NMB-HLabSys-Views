@model NMB_HLabSys_VIEWS.ViewModels.NotificationCenterViewModel
@{
    ViewData["Title"] = "Notification Center";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
    ViewData["ActivePage"] = "Notifications";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Notification Center</h2>
    <span class="badge bg-secondary">@Model.UnreadCount unread</span>
</div>

@if (!Model.Notifications.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No notifications at this time.
    </div>
}
else
{
    <div class="list-group">
        @foreach (var notif in Model.Notifications)
        {
            <a href="#" class="list-group-item list-group-item-action @(notif.IsRead ? "" : "active")" data-notif-id="@notif.NotificationId">
                <div class="d-flex w-100 justify-content-between align-items-start">
                    <div class="flex-grow-1">
                        <div class="d-flex gap-2 align-items-center mb-1">
                            <h6 class="mb-0">@notif.Title</h6>
                            <span class="@notif.TypeBadgeClass">@notif.NotificationType</span>
                            @if (!notif.IsRead)
                            {
                                <span class="badge bg-primary rounded-circle" style="width: 8px; height: 8px; padding: 0;"></span>
                            }
                        </div>
                        <p class="text-muted mb-1">@notif.Message</p>
                        <small class="text-muted">@notif.CreatedAt.ToString("g")</small>
                    </div>
                    @if (notif.RelatedTestRequestId.HasValue)
                    {
                        <a href="/LabTechnician/CaptureResultForm?requestId=@notif.RelatedTestRequestId" class="btn btn-sm btn-primary">View Test</a>
                    }
                </div>
            </a>
        }
    </div>
}

<style>
.list-group-item.active {
    background-color: #f5f5f5;
    border-color: #7a3030;
}

.list-group-item:hover {
    background-color: #fafafa;
}
</style>

<script>
document.querySelectorAll('[data-notif-id]').forEach(item => {
    item.addEventListener('click', function (e) {
        const notifId = this.getAttribute('data-notif-id');
        fetch('/LabTechnician/MarkNotificationRead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ notificationId: notifId })
        }).catch(console.error);
    });
});
</script>
