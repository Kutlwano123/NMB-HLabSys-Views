@model NMB_HLabSys_VIEWS.ViewModels.ConsumableTrackingViewModel
@{
    ViewData["Title"] = "Required Consumables";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
    ViewData["ActivePage"] = "Tasks";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">
            <i class="bi bi-droplet"></i> Required Consumables for @Model.TestName
        </h5>
    </div>
    <div class="card-body">
        @if (!Model.AllConsumablesAvailable)
        {
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle"></i> 
                <strong>Stock Alert:</strong> Some required consumables are below required quantities. 
                Please contact the lab manager before proceeding.
            </div>
        }

        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Consumable</th>
                        <th class="text-center">Required</th>
                        <th class="text-center">Available</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in Model.Requirements)
                    {
                        <tr class="@(req.IsSufficientStock ? "" : "table-danger")">
                            <td>@req.ConsumableName</td>
                            <td class="text-center">@req.QuantityRequired @req.Unit</td>
                            <td class="text-center">
                                <span class="@(req.IsSufficientStock ? "badge bg-success" : "badge bg-danger")">
                                    @req.AvailableQuantity @req.Unit
                                </span>
                            </td>
                            <td class="text-center">
                                @if (req.IsSufficientStock)
                                {
                                    <i class="bi bi-check-circle text-success"></i>
                                }
                                else
                                {
                                    <span class="text-danger">
                                        <i class="bi bi-x-circle"></i> Insufficient
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="alert alert-info mt-3">
            <i class="bi bi-info-circle"></i> 
            <strong>Note:</strong> Consumable quantities are automatically deducted when you capture results 
            (in production mode). Verify stock is adequate before proceeding.
        </div>
    </div>
</div>

<div class="mt-3">
    <a href="/LabTechnician/Dashboard" class="btn btn-secondary">Back to Dashboard</a>
</div>
