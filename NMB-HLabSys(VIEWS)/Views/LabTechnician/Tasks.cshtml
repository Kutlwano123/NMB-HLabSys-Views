@using NMB_HLabSys_VIEWS.Data
@model IEnumerable<StubTestRequest>
@{
    ViewData["Title"] = "Assigned Tasks";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
    ViewData["ActivePage"] = "Tasks";
}

<h2>Diagnostic Task Assignments</h2>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Request Number</th>
            <th>Patient Name</th>
            <th>Target Test</th>
            <th>Urgency</th>
            <th>Action Link</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.RequestNumber</td>
                <td>@t.PatientName</td>
                <td>@(t.TestType?.TestName ?? "Haematology Screen")</td>
                <td>
                    <span class="badge @(t.Urgency == "STAT" ? "bg-danger" : "bg-secondary")">@t.Urgency</span>
                </td>
                <td>
                    <a class="btn btn-sm btn-primary" href="/LabTechnician/CaptureResultForm?requestId=@t.TestRequestId">
                        <i class="bi bi-pencil-square"></i> Open Entry Form
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
