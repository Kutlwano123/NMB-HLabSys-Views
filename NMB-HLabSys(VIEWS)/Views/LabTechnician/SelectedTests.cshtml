@* SelectedTests.cshtml *@
@using NMB_HLabSys_VIEWS.Data
@model IEnumerable<StubTestRequest>
@{
    ViewData["Title"] = "Selected Tests";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
    ViewData["ActivePage"] = "SelectedTests";
}

<h2>Tests Selected by You</h2>

<table class="table table-hover">
    <thead>
        <tr><th>Request</th><th>Patient</th><th>Test</th><th>Progress</th><th>Action</th></tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.RequestNumber</td>
                <td>@t.PatientName</td>
                <td>@t.TestType?.TestName</td>
                <td>@t.TestProgressStatus?.StatusName</td>
                <td>
                    <a class="btn btn-sm btn-success" href="~/LabTechnician/CaptureResultForm?requestId=@t.TestRequestId">
                        Capture Result
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
