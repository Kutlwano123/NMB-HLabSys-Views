@model List<NMB_HLabSys_VIEWS.ViewModels.ConsumableInventoryViewModel>
@{
    ViewData["Title"] = "Consumable Inventory";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
    ViewData["ActivePage"] = "Consumables";
}

<h2>Consumable Inventory</h2>
<p class="text-muted">Real-time stock levels for consumables assigned to your test types.</p>

@if (Model.Any(c => c.IsLow))
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i> <strong>Low Stock Alert:</strong> 
        @{
            var lowItems = Model.Where(c => c.IsLow).Select(c => c.ConsumableName).ToList();
            <text>@string.Join(", ", lowItems)</text>
        }
    </div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Consumable Name</th>
                <th>Unit</th>
                <th class="text-center">In Stock</th>
                <th class="text-center">Minimum Threshold</th>
                <th class="text-center">Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsLow ? "table-warning" : "")">
                    <td>@item.ConsumableName</td>
                    <td>@item.Unit</td>
                    <td class="text-center">
                        <span class="badge @(item.IsLow ? "bg-danger" : "bg-success")">
                            @item.QuantityInStock
                        </span>
                    </td>
                    <td class="text-center">@item.MinimumThreshold</td>
                    <td class="text-center">
                        @if (item.IsLow)
                        {
                            <span class="badge bg-danger">
                                <i class="bi bi-exclamation-circle"></i> LOW STOCK
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">
                                <i class="bi bi-check-circle"></i> Adequate
                            </span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-4">
    <h4>Quick Actions</h4>
    <a href="/LabTechnician/Dashboard" class="btn btn-secondary">Back to Dashboard</a>
</div>
