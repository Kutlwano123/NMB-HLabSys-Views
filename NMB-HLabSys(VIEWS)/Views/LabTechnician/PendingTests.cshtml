@using NMB_HLabSys_VIEWS.Data
@model IEnumerable<StubTestRequest>
@{
    ViewData["Title"] = "Pending & Sample Receipt";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
    ViewData["ActivePage"] = "PendingTests";
}

<h2>Pending Tests <small class="text-muted fs-6">(Assigned Test Types Only)</small></h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<table class="table table-hover">
    <thead>
        <tr>
            <th>Request #</th>
            <th>Patient</th>
            <th>Test</th>
            <th>Status</th>
            <th>Due</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            var overdue = t.DueDate < DateTime.Now;
            <tr class="@(overdue ? "table-danger" : "")">
                <td>@t.RequestNumber</td>
                <td>@t.PatientName</td>
                <td>@t.TestType?.TestName</td>
                <td>@t.RequestStatus?.StatusName / @t.TestProgressStatus?.StatusName</td>
                <td>@t.DueDate?.ToString("g") @(overdue ? "⚠ OVERDUE" : "")</td>
                <td class="d-flex flex-wrap gap-1">
                    @if (t.RequestStatus?.StatusName == "Pending")
                    {
                        <form method="post" asp-action="ReceiveSamples" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" value="@t.TestRequestId" />
                            <button type="submit" class="btn btn-sm btn-outline-primary">Receive Samples</button>
                        </form>
                    }
                    @if (t.RequestStatus?.StatusName == "Samples Received" || t.RequestStatus?.StatusName == "Pending")
                    {
                        <form method="post" asp-action="SelectTest" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" value="@t.TestRequestId" />
                            <button type="submit" class="btn btn-sm btn-primary">Select Test</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
