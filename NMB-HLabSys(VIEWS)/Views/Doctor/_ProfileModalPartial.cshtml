<div class="modal-overlay" id="profileModal" aria-hidden="true" role="dialog" aria-labelledby="profileModalTitle">
    <div class="modal-card profile-modal">
        <div class="modal-header">
            <h2 id="profileModalTitle">Manage Profile</h2>
            <button type="button" class="modal-close" id="closeProfileModal" aria-label="Close">&times;</button>
        </div>
        <form id="profileForm" class="modal-body">
            <div class="profile-modal-avatar-row">
                <div class="profile-modal-avatar" id="profileModalAvatar">UM</div>
                <p class="profile-modal-hint">Your details appear in the sidebar and top bar across all screens.</p>
            </div>
            <div class="form-row cols-2">
                <div class="form-group">
                    <label for="profileTitle">Title</label>
                    <select id="profileTitle" name="title">
                        <option value="Dr.">Dr.</option>
                        <option value="Prof.">Prof.</option>
                        <option value="Mr.">Mr.</option>
                        <option value="Ms.">Ms.</option>
                    </select>
                </div>
               @*  <div class="form-group">
                    <label for="profileFirstName">First name</label>
                    <input type="text" id="profileFirstName" name="firstName" required value="Unathi" />
                </div>
            </div> *@
            <div class="form-row cols-2">
                <div class="form-group">
                    <label for="profileLastName">Last name</label>
                    <input type="text" id="profileLastName" name="lastName" required value="Mzathu" />
                </div>
                <div class="form-group">
                    <label for="profileHpcsa">HPCSA number</label>
                    <input type="text" id="profileHpcsa" name="hpcsa" value="MP1234567" />
                </div>
            </div>
            <div class="form-row cols-2">
                <div class="form-group">
                    <label for="profileEmail">Email</label>
                    <input type="email" id="profileEmail" name="email" value="doctor@clinic.co.za" />
                </div>
                <div class="form-group">
                    <label for="profilePhone">Phone</label>
                    <input type="tel" id="profilePhone" name="phone" value="+27 82 123 4567" />
                </div>
            </div>
            <div class="form-group">
                <label for="profilePractice">Practice / Hospital</label>
                <input type="text" id="profilePractice" name="practice" value="NMB Campus Health" />
            </div>
            <div class="form-group">
                <label for="profileSpecialty">Specialty / Role</label>
                <input type="text" id="profileSpecialty" name="specialty" value="General Practitioner" />
            </div>
        </form>
        <div class="modal-footer">
            <button type="button" class="btn btn-outline" id="cancelProfileBtn">Cancel</button>
            <button type="submit" form="profileForm" class="btn">Save Profile</button>
        </div>
    </div>
</div>