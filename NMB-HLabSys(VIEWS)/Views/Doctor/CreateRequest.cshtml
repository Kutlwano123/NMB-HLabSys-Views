@{
    ViewData["Title"] = "Create Test Request - NMB-HLabSys";
    ViewData["ActiveNav"] = "create";
    Layout = "_DoctorLayout";
}

<div class="page-header">
    <div class="page-tag"><span class="tag-dot"></span> Requests</div>
    <h1 class="doctor-title">Create Test Request</h1>
    <p class="doctor-sub">Capture request details, urgency, and sample barcodes for lab processing.</p>
</div>

<div class="info-strip">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <circle cx="12" cy="12" r="10" />
        <path d="M12 16v-4M12 8h.01" />
    </svg>
    <span>
        When you submit this request, the patient will receive an email notification confirming
        that their test has been ordered and providing their request reference number.
    </span>
</div>

<section class="panel-card">
    <h3>New Request</h3>

    <form asp-controller="Doctor" asp-action="CreateRequest" method="post" id="labRequestForm">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All"
             class="text-danger small mb-3 fw-bold"
             style="list-style-type:none;padding:0"></div>

        @* ── Row 1: Patient, Date, Urgency ── *@
        <div class="form-row cols-3">
            <div class="form-group">
                <label for="patientId">Patient</label>
                <select id="patientId" name="patientId" required>
                    <option value="">Select patient</option>
                    @if (ViewBag.PatientOptions != null)
                    {
                        foreach (var p in (List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.PatientOptions)
                        {
                            <option value="@p.Value">@p.Text</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label for="requestDate">Request Date</label>
                <input type="date" id="requestDate" name="requestDate"
                       value="@DateTime.UtcNow.ToString("yyyy-MM-dd")" required />
            </div>
            <div class="form-group">
                <label for="urgency">Urgency</label>
                <select id="urgency" name="urgency">
                    <option value="Routine">Routine</option>
                    <option value="Urgent">Urgent</option>
                    <option value="Stat">STAT</option>
                </select>
            </div>
        </div>

        @* ── Barcode input + Added Samples display ── *@
        <div style="margin-top:20px">
            <label style="font-size:12px;font-weight:600;color:var(--text-mid);margin-bottom:8px;display:block">
                Sample Barcodes <span style="color:var(--red)">*</span>
            </label>

            @* Barcode entry row *@
            <div class="barcode-input-row">
                <input type="text" id="barcodeEntry"
                       placeholder="e.g. BC-2026-0001 — press Enter or click Add"
                       style="font-family:'DM Mono',monospace" />
                <button type="button" class="btn btn-outline btn-sm" onclick="addBarcode()">
                    + Add
                </button>
            </div>

            @* Added samples chips *@
            <div style="margin-top:10px">
                <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;
                            color:var(--text-light);margin-bottom:8px">
                    Added Samples
                </div>
                <div class="barcode-chips" id="barcodeChips">
                    <span id="noSamplesHint"
                          style="font-size:12px;color:var(--text-light);font-style:italic;padding:6px 0">
                        No samples added yet.
                    </span>
                </div>
            </div>

            @* Hidden field: sends comma-separated barcodes OR textarea fallback ── *@
            <input type="hidden" name="rawBarcodesInput" id="rawBarcodesInput" />

            <p style="font-size:12px;color:var(--text-light);margin-top:10px">
                Scan or type each barcode and click <strong>Add</strong> (or press Enter).
                Each barcode will appear as a chip above.
            </p>
        </div>

        @* ── Test types multi-select ── *@
        <div class="form-group" style="margin-top:20px">
            <label for="selectedTestTypeIds">
                Requested Test Types <span style="color:var(--red)">*</span>
            </label>
            <select id="selectedTestTypeIds" name="selectedTestTypeIds"
                    multiple style="min-height:130px" required>
                @if (ViewBag.TestTypeOptions != null)
                {
                    foreach (var t in (List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.TestTypeOptions)
                    {
                        <option value="@t.Value">@t.Text</option>
                    }
                }
            </select>
            <small style="font-size:12px;color:var(--text-light);display:block;margin-top:6px">
                Hold <strong>Ctrl</strong> (Windows) or <strong>⌘ Command</strong> (Mac) to select multiple tests.
            </small>
        </div>

        @* ── Clinical notes ── *@
        <div class="form-group" style="margin-top:20px">
            <label for="clinicalNotes">Clinical Notes</label>
            <textarea id="clinicalNotes" name="clinicalNotes" rows="3"
                      placeholder="Symptoms, context, relevant history…"></textarea>
        </div>

        @* ── Actions ── *@
        <div class="form-actions" style="margin-top:24px">
            <button class="btn" type="submit">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="22" y1="2" x2="11" y2="13" />
                    <polygon points="22 2 15 22 11 13 2 9 22 2" />
                </svg>
                Submit Request
            </button>
            <a asp-action="Dashboard" class="btn btn-outline" style="text-decoration:none;text-align:center">
                Cancel
            </a>
        </div>
    </form>
</section>

<script>
    var barcodes = [];

    /* Add barcode chip */
    function addBarcode() {
        var inp = document.getElementById('barcodeEntry');
        var val = inp.value.trim().toUpperCase();
        if (!val) return;
        if (barcodes.includes(val)) { alert('Barcode already added.'); inp.value = ''; return; }

        barcodes.push(val);
        renderChips();
        inp.value = '';
        inp.focus();
    }

    /* Remove a chip */
    function removeBarcode(val) {
        barcodes = barcodes.filter(function(b){ return b !== val; });
        renderChips();
    }

    /* Render chip list and sync hidden input */
    function renderChips() {
        var container = document.getElementById('barcodeChips');
        var hint      = document.getElementById('noSamplesHint');

        if (barcodes.length === 0) {
            container.innerHTML = '';
            container.appendChild(hint);
            hint.style.display = '';
            document.getElementById('rawBarcodesInput').value = '';
            return;
        }

        hint.style.display = 'none';
        container.innerHTML = barcodes.map(function(b) {
            return '<div class="barcode-chip">' +
                        b +
                        '<button type="button" onclick="removeBarcode(\'' + b + '\')" title="Remove">✕</button>' +
                   '</div>';
        }).join('');

        /* sync hidden field (newline-separated for controller) */
        document.getElementById('rawBarcodesInput').value = barcodes.join('\n');
    }

    /* Allow Enter key to add barcode */
    document.getElementById('barcodeEntry').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') { e.preventDefault(); addBarcode(); }
    });
</script>
