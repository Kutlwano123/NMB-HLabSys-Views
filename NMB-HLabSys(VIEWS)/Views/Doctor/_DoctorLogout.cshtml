<div class="doctor-logout-form">
    <span class="logout-label">Account</span>
    <form method="post" asp-controller="Account" asp-action="Logout">
        @Html.AntiForgeryToken()
        <button type="submit" class="doctor-logout-btn">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M13 4.5L17.5 10 13 15.5M17.5 10H7.5" />
                <path d="M7.5 3H4a1 1 0 00-1 1v12a1 1 0 001 1h3.5" />
            </svg>
            Log Out
        </button>
    </form>
</div>