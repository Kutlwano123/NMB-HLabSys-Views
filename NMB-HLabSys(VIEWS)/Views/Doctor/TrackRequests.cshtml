@model List<(int Id, string RequestNumber, string PatientName, string Status, DateTime UpdatedAt)>
@{
    ViewData["Title"] = "Track Request - NMB-HLabSys";
    ViewData["ActiveNav"] = "track";
    Layout = "_DoctorLayout";
}

<div class="page-header">
    <div class="page-tag"><span class="tag-dot"></span> Requests</div>
    <h1 class="doctor-title">Track Test Requests</h1>
    <p class="doctor-sub">Monitor processing lifecycle, timestamps, and active sample batches.</p>
</div>

<div class="track-layout">

    <section class="panel-card" style="margin-bottom: 0;">
        <h3>Active Lab Requests</h3>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Request #</th>
                        <th>Patient Name</th>
                        <th>Status Flag</th>
                        <th>Last Updated</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var r in Model)
                        {
                            <tr class="request-row @(r.Status == "Submitted" ? "selected" : "")" data-request="@r.RequestNumber" data-status="@r.Status.ToLower()">
                                <td class="fw-bold text-dark">@r.RequestNumber</td>
                                <td>@r.PatientName</td>
                                <td>
                                    @switch (r.Status)
                                    {
                                        case "Submitted":
                                            <span class="chip pending">Submitted</span>
                                            break;
                                        case "SamplesReceived":
                                            <span class="chip progress">Samples Received</span>
                                            break;
                                        case "InProgress":
                                            <span class="chip progress">In Progress</span>
                                            break;
                                        case "Completed":
                                            <span class="chip ok">Completed</span>
                                            break;
                                        case "Released":
                                            <span class="chip ok">Released</span>
                                            break;
                                        case "Cancelled":
                                            <span class="chip danger">Cancelled</span>
                                            break;
                                        default:
                                            <span class="chip">@r.Status</span>
                                            break;
                                    }
                                </td>
                                <td class="td-sm">@r.UpdatedAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a asp-action="Results" asp-route-id="@r.Id" class="btn btn-sm btn-outline text-decoration-none">
                                            <i class="fas fa-eye"></i> View Results
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="td-sm text-center text-muted italic" style="padding: 20px;">
                                No matching laboratory test requests found on file.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <aside class="timeline-panel">
        <h4>Request Progress Timeline</h4>

        @if (Model != null && Model.Any())
        {
            var activeReq = Model.First();
            <p class="text-muted small mb-3" style="margin-top:-10px;">Tracking: <strong>@activeReq.RequestNumber</strong></p>

            <ul class="timeline">
                <li class="timeline-step done">
                    <div class="timeline-dot"></div>
                    <div class="timeline-step-title">Request Submitted</div>
                    <div class="timeline-step-time">@activeReq.UpdatedAt.ToString("dd MMM HH:mm")</div>
                </li>

                <li class="timeline-step @(activeReq.Status != "Submitted" ? "done" : "active")">
                    <div class="timeline-dot"></div>
                    <div class="timeline-step-title">Samples Logged in Lab</div>
                    <div class="timeline-step-time">@(activeReq.Status != "Submitted" ? activeReq.UpdatedAt.AddMinutes(45).ToString("dd MMM HH:mm") : "Awaiting processing...")</div>
                </li>

                <li class="timeline-step @(activeReq.Status == "Completed" || activeReq.Status == "Released" ? "done" : (activeReq.Status == "InProgress" ? "active" : ""))">
                    <div class="timeline-dot"></div>
                    <div class="timeline-step-title">Diagnostic Analysis Running</div>
                    <div class="timeline-step-time">In Queue</div>
                </li>

                <li class="timeline-step @(activeReq.Status == "Released" ? "done" : (activeReq.Status == "Completed" ? "active" : ""))">
                    <div class="timeline-dot"></div>
                    <div class="timeline-step-title">Results Verified by Manager</div>
                    <div class="timeline-step-time">Pending Approval</div>
                </li>

                <li class="timeline-step @(activeReq.Status == "Released" ? "active" : "")">
                    <div class="timeline-dot"></div>
                    <div class="timeline-step-title">Report Issued to Patient</div>
                    <div class="timeline-step-time">Final Stage</div>
                </li>
            </ul>
        }
        else
        {
            <p class="td-sm text-muted italic">Select a laboratory transaction entry from the dataset table grid matrix to compile its processing tracking ledger layout.</p>
        }
    </aside>
</div>