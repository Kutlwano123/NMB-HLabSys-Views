<header class="doctor-topbar">
    <button type="button" class="topbar-menu-btn" id="sidebarToggle" aria-label="Open menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18" /></svg>
    </button>

    <div class="topbar-actions">
        <button type="button" class="topbar-icon-btn" id="notifBtn" aria-label="Notifications">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 01-3.46 0" /></svg>
            <span class="notif-dot pulse-dot" aria-hidden="true"></span>
        </button>

        <a class="topbar-profile-btn" asp-controller="Doctor" asp-action="Settings" aria-label="Settings">
            <span class="topbar-avatar" id="topbarAvatar">@(ViewData["DoctorInitials"] ?? "UM")</span>
            <span class="topbar-profile-text">
                <span class="topbar-name" id="topbarName">@(ViewData["DoctorDisplayName"] ?? "Dr. Unathi Mzathu")</span>
                <span class="topbar-role" id="topbarRole">@(ViewData["DoctorRoleSubtitle"] ?? "General Practitioner")</span>
            </span>
        </a>
    </div>
</header>