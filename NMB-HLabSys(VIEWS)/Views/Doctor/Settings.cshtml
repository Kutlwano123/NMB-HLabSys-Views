@{
    ViewData["Title"] = "Settings - NMB-HLabSys";
    ViewData["ActiveNav"] = "settings";
    Layout = "_DoctorLayout";

    // Safely extract the raw string values supplied from the Controller's step layers
    string email = ViewBag.Email as string ?? string.Empty;
    string phone = ViewBag.Phone as string ?? string.Empty;
    string city = ViewBag.City as string ?? string.Empty;
    string postalCode = ViewBag.PostalCode as string ?? string.Empty;
}

<div class="page-header">
    <div class="page-tag"><span class="tag-dot"></span> Account</div>
    <h1 class="doctor-title">Settings</h1>
    <p class="doctor-sub">View and update your email, contact details, and password.</p>
</div>

@if (TempData["SettingsSuccess"] != null)
{
    <div class="settings-alert success" role="status">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" /></svg>
        @TempData["SettingsSuccess"]
    </div>
}

<div class="settings-grid">
    <section class="panel-card settings-panel">
        <h3>Profile &amp; Contact</h3>
        <p class="settings-panel-desc">Update your login email and contact information. Your current password is required to save changes.</p>

        <form asp-action="UpdateProfile" asp-controller="Doctor" method="post" class="settings-form">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" value="@email" autocomplete="email" required />
            </div>

            <div class="form-row cols-2">
                <div class="form-group">
                    <label for="phone">Phone Number</label>
                    <input type="tel" id="phone" name="phone" value="@phone" autocomplete="tel" placeholder="+27 …" />
                </div>
                <div class="form-group">
                    <label for="postalCode">Postal Code</label>
                    <input type="text" id="postalCode" name="postalCode" value="@postalCode" autocomplete="postal-code" placeholder="6001" />
                </div>
            </div>

            <div class="form-group">
                <label for="address">Street Address</label>
                <input type="text" id="address" name="address" autocomplete="street-address" placeholder="Street address" />
            </div>

            <div class="form-group">
                <label for="city">City</label>
                <input type="text" id="city" name="city" value="@city" autocomplete="address-level2" placeholder="Gqeberha" />
            </div>

            <div class="form-group" style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #eee;">
                <label for="currentPassword">Confirm Current Password <span class="text-danger">*</span></label>
                <input type="password" id="currentPassword" name="currentPassword" autocomplete="current-password" required />
            </div>

            <div class="form-actions" style="margin-top: 15px;">
                <button type="submit" class="btn">Save Profile</button>
            </div>
        </form>
    </section>

    <section class="panel-card settings-panel">
        <h3>Change Password</h3>
        <p class="settings-panel-desc">Choose a strong password with at least 8 characters, including uppercase, a number, and a special character.</p>

        <form asp-action="UpdatePassword" asp-controller="Doctor" method="post" class="settings-form">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="pwdCurrent">Old Password</label>
                <input type="password" id="pwdCurrent" name="currentPassword" autocomplete="current-password" required />
            </div>

            <div class="form-group">
                <label for="settingsNewPassword">New Password</label>
                <input type="password" id="settingsNewPassword" name="newPassword" autocomplete="new-password" required />
                <div class="pw-strength-bars" id="settingsPwBars" aria-hidden="true" style="display: flex; gap: 4px; margin-top: 5px;">
                    <span style="flex: 1; height: 4px; background: var(--border); border-radius: 2px; transition: background 0.2s;"></span>
                    <span style="flex: 1; height: 4px; background: var(--border); border-radius: 2px; transition: background 0.2s;"></span>
                    <span style="flex: 1; height: 4px; background: var(--border); border-radius: 2px; transition: background 0.2s;"></span>
                    <span style="flex: 1; height: 4px; background: var(--border); border-radius: 2px; transition: background 0.2s;"></span>
                </div>
            </div>

            <div class="form-group">
                <label for="pwdConfirm">Confirm New Password</label>
                <input type="password" id="pwdConfirm" name="confirmPassword" autocomplete="new-password" required />
            </div>

            <div class="form-actions" style="margin-top: 15px;">
                <button type="submit" class="btn">Update Password</button>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const input = document.getElementById('settingsNewPassword');
            const bars = document.querySelectorAll('#settingsPwBars span');
            if (!input || !bars.length) return;
            input.addEventListener('input', function () {
                const pw = input.value;
                const score = [pw.length >= 8, /[A-Z]/.test(pw), /\d/.test(pw), /[^a-zA-Z\d]/.test(pw)].filter(Boolean).length;
                const colors = ['#e0e0e0', '#c41e3a', '#8a6a20', '#2d5a4a', '#2d5a4a'];
                bars.forEach((b, i) => { b.style.background = i < score ? colors[score] : '#e0e0e0'; });
            });
        })();
    </script>
}