@{
    ViewData["Title"] = "Edit Test Category";
    Layout = "~/Views/Shared/_ManagersLayout.cshtml";

    var category = new { Id = 1, Name = "Hematology", Description = "Blood and cellular analysis" };
}

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="card shadow-sm">
            <div class="card-header bg-warning">
                <h5 class="mb-0">Edit Test Category</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="TestCategoryID" value="@category.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Test Category Name</label>
                        <input name="TestCategoryName" class="form-control" value="@category.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="Description" class="form-control" rows="3">@category.Description</textarea>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-controller="LabManager" asp-action="TestCategories" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-warning">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>
