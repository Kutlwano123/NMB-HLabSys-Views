@{
    ViewData["Title"] = "Category Details";
    Layout = "~/Views/Shared/_ManagersLayout.cshtml";

    var category = new
    {
        Id = 1,
        Name = "Hematology",
        Description = "Blood and cellular analysis",
        TestTypes = new[]
        {
            new { TestName = "CBC",              SampleType = "EDTA Tube",   TurnAroundTime = 60  },
            new { TestName = "WBC Differential", SampleType = "EDTA Tube",   TurnAroundTime = 90  },
            new { TestName = "Platelet Count",   SampleType = "EDTA Tube",   TurnAroundTime = 45  },
            new { TestName = "Haemoglobin",      SampleType = "EDTA Tube",   TurnAroundTime = 30  },
            new { TestName = "ESR",              SampleType = "Citrate Tube", TurnAroundTime = 120 },
            new { TestName = "Reticulocyte",     SampleType = "EDTA Tube",   TurnAroundTime = 75  }
        }
    };
}

<div class="row justify-content-center">
    <div class="col-md-7">

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@category.Name</h5>
                <span class="badge bg-light text-dark">
                    @category.TestTypes.Length test type(s)
                </span>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Category Name</dt>
                    <dd class="col-sm-8">@category.Name</dd>

                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@category.Description</dd>
                </dl>
            </div>
        </div>

        <!-- Linked Test Types -->
        <div class="card shadow-sm">
            <div class="card-header bg-secondary text-white">
                <h6 class="mb-0">Test Types in this Category</h6>
            </div>
            <div class="card-body p-0">
                @if (!category.TestTypes.Any())
                {
                    <p class="text-muted p-3 mb-0">No test types linked to this category yet.</p>
                }
                else
                {
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Test Name</th>
                                <th>Sample Type</th>
                                <th>Turnaround Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var testType in category.TestTypes)
                            {
                                <tr>
                                    <td>@testType.TestName</td>
                                    <td>@testType.SampleType</td>
                                    <td>@testType.TurnAroundTime min</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <a asp-controller="LabManager" asp-action="TestCategories" class="btn btn-secondary">Back to List</a>
            <a asp-controller="LabManager" asp-action="EditTestCategory" asp-route-id="@category.Id" class="btn btn-warning">Edit</a>
        </div>

    </div>
</div>
