@{
    ViewData["Title"] = "Edit Lab Technician";
    Layout = "~/Views/Shared/_ManagersLayout.cshtml";
    var technician = new { Id = 1, Name = "John Doe", Specialty = "Microbiology", Contact = "john.doe@example.com" };
}
<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="card shadow-sm">
            <div class="card-header bg-warning">
                <h5 class="mb-0">Edit Lab Technician</h5>
            </div>
            <div class="card-body">
                <form asp-controller="LabManager" asp-action="EditLabTechnician" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="TechnicianID" value="@technician.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Lab Technician Name</label>
                        <input name="TechnicianName" class="form-control" value="@technician.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Specialty</label>
                        <input name="Specialty" class="form-control" value="@technician.Specialty" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input name="Email" type="email" class="form-control" value="@technician.Contact" />
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-controller="LabManager" asp-action="LabTechnicians" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-warning">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

