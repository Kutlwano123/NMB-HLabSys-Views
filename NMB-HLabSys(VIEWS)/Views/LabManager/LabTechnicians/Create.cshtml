@{
    ViewData["Title"] = "Create Lab Technician";
    Layout = "~/Views/Shared/_ManagersLayout.cshtml";
    var technician = new { Name = "", Contact = "" , Specialty = ""};
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Add New Lab Technician</h5>
            </div>
            <div class="card-body">
                <form asp-action="CreateLabTechnician" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="Name" class="form-label">Technician Name</label>
                        <input type="text" class="form-control" id="Name" name="Name" value="@technician.Name" required />
                    </div>
                    <div class="mb-3">
                        <label for="Specialty" class="form-label">Specialty</label>
                        <input type="text" class="form-control" id="Specialty" name="Specialty" value="@technician.Specialty" required />
                    </div>
                    <div class="mb-3">
                        <label for="Contact" class="form-label">Contact</label>
                        <input type="email" class="form-control" id="Contact" name="Contact" value="@technician.Contact" required />
                    </div>
                    <div class="d-flex justify-content-between">
                        <a asp-controller="LabManager" asp-action="LabTechnicians" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Create Technician</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>