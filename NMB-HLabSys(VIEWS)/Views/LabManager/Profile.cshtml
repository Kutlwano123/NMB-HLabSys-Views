@{
    ViewData["Title"] = "Profile";
    Layout = "~/Views/Shared/_ManagersLayout.cshtml";
    var labManager = new
    {
        UserName = "Kutlwano Modise",
        Email = "kutlwano.modise@labmanager.com"
    };
}
<div style="margin-bottom:20px;">
    <h2 style="margin:0;">My Profile</h2>
    <p style="color:var(--mgr-text-light);font-size:13px;margin-top:4px;">
        View and update your personal details
    </p>
</div>

<div class="card" style="max-width:700px;">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Username</label>
            <input class="form-control" value="@labManager.UserName" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input class="form-control" value="@labManager.Email" readonly />
        </div>

        <button type="button" class="btn btn-primary">Save Changes</button>
    </div>
</div>

