@{
    ViewData["Title"] = "Edit Consumable";
    Layout = "~/Views/Shared/_ManagersLayout.cshtml";

    var consumable = new
    {
        Id = 1,
        Name = "Syringes 5ml",
        Supplier = "MedSupply Co.",
        ReorderLevel = 20,
        QuantityOnHand = 15
    };
}

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="card shadow-sm">
            <div class="card-header bg-warning">
                <h5 class="mb-0">Edit Consumables</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="ConsumableID" value="@consumable.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Consumable Name</label>
                        <input name="ConsumableName" class="form-control" value="@consumable.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Supplier</label>
                        <input name="Supplier" class="form-control" value="@consumable.Supplier" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Reorder Level</label>
                        <input name="ReorderLevel" class="form-control" type="number" min="0" value="@consumable.ReorderLevel" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Quantity on Hand</label>
                        <input name="QuantityOnHand" class="form-control" type="number" min="0" value="@consumable.QuantityOnHand" />
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-warning">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>
