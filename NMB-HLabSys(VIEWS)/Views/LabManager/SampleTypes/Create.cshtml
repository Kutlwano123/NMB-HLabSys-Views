@{
    ViewData["Title"] = "Create Sample Type";
    Layout = "~/Views/Shared/_ManagersLayout.cshtml";
    var sampleType = new { Name = "", Description = "" };
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Add New Sample Type</h5>
            </div>
            <div class="card-body">
                <form asp-action="CreateSampleType" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="Name" class="form-label">Sample Type Name</label>
                        <input type="text" class="form-control" id="Name" name="Name" value="@sampleType.Name" required />
                    </div>
                    <div class="mb-3">
                        <label for="Description" class="form-label">Description</label>
                        <textarea class="form-control" id="Description" name="Description" rows="3" required>@sampleType.Description</textarea>
                    </div>
                    <div class="d-flex justify-content-between">
                        <a asp-controller="LabManager" asp-action="SampleTypes" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Create Sample Type</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    </div>
