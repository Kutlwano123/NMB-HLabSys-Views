@{
    ViewData["Title"] = "Edit Sample Type";
    Layout = "~/Views/Shared/_ManagersLayout.cshtml";
    var sampleType = new { Id = 1, Name = "Blood Sample", Description = "Used for blood tests and analysis." };
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Edit Sample Type</h5>
            </div>
            <div class="card-body">
                <form asp-action="EditSampleType" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@sampleType.Id" />

                    <div class="mb-3">
                        <label for="Name" class="form-label">Sample Type Name</label>
                        <input type="text" class="form-control" id="Name" name="Name" value="@sampleType.Name" required />
                    </div>

                    <div class="mb-3">
                        <label for="Description" class="form-label">Description</label>
                        <textarea class="form-control" id="Description" name="Description" rows="3">@sampleType.Description</textarea>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-controller="LabManager" asp-action="SampleTypes" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>