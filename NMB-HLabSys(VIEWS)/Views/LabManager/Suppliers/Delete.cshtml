@{
    ViewData["Title"] = "Delete Supplier";
    Layout = "~/Views/Shared/_ManagersLayout.cshtml";
    var supplier = new { Id = 1, Name = "Lab Supplies Co.", Contact = "John Doe", Email = "john.doe@lab supplies.com" };
}
<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">Confirm Deletion</h5>
            </div>
            <div class="card-body">
                    <p>Are you sure you want to delete the following supplier?</p>

                    <dl class="row">
                        <dt class="col-sm-4">Supplier Name</dt>
                        <dd class="col-sm-8">@supplier.Name</dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@supplier.Email</dd>
                    </dl>

                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i>
                        This action cannot be undone.
                    </div>

                    <form asp-action="DeleteSupplier" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="SupplierID" value="@supplier.Id" />

                        <div class="d-flex justify-content-between">
                            <a asp-controller="LabManager" asp-action="Suppliers" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-danger">Yes, Delete</button>
                        </div>
                    </form>

            </div>
        </div>

    </div>
</div>