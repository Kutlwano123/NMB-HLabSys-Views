@{
    ViewData["Title"] = "Orders";
    Layout = "~/Views/Shared/_ManagersLayout.cshtml";
    var orders = new[] {
        new { Id = 123, Consumable = "Reanalysis Kits", Supplier = "Lab Supplies Co.", Status = "In Progress", OrderedDate = DateTime.Now.AddDays(-1).ToString("MMMM dd, yyyy"), DueDate = DateTime.Now.AddDays(2).ToString("MMMM dd, yyyy") },
        new { Id = 124, Consumable = "DNA Extraction Kits", Supplier = "Medical Equipment Inc.", Status = "Completed", OrderedDate = DateTime.Now.AddDays(-5).ToString("MMMM dd, yyyy"), DueDate = DateTime.Now.AddDays(-2).ToString("MMMM dd, yyyy") },
        new { Id = 125, Consumable = "PCR Reagents", Supplier = "Diagnostic Tools Corp.", Status = "Pending", OrderedDate = DateTime.Now.ToString("MMMM dd, yyyy"), DueDate = DateTime.Now.AddDays(3).ToString("MMMM dd, yyyy") }
    };
}
<style>
    .mgr-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .mgr-page-title {
        font-family: 'DM Serif Display', serif;
        font-size: 24px;
        color: var(--mgr-text-dark, #1e2420);
        margin: 0;
    }

    .mgr-btn-primary {
        background: var(--mgr-accent, #7a3030);
        border-color: var(--mgr-accent, #7a3030);
        color: #fff;
    }

        .mgr-btn-primary:hover {
            background: var(--mgr-accent-2, #9a4040);
            border-color: var(--mgr-accent-2, #9a4040);
            color: #fff;
        }

    .mgr-table {
        background: #fff;
        border: 1px solid var(--mgr-border, #ddd9d2);
        border-radius: 12px;
        overflow: hidden;
    }

        .mgr-table thead {
            background: var(--mgr-accent-pale, #f0e8e8);
            color: var(--mgr-accent, #7a3030);
        }

        .mgr-table th,
        .mgr-table td {
            vertical-align: middle;
            border-color: var(--mgr-border, #ddd9d2);
        }

    .mgr-badge {
        background: var(--mgr-accent-pale, #f0e8e8);
        color: var(--mgr-accent, #7a3030);
        font-weight: 600;
    }

    .mgr-action-btn {
        border-radius: 6px;
        font-size: 12px;
        padding: 6px 10px;
    }

        .mgr-action-btn.btn-outline-primary {
            border-color: var(--mgr-accent, #7a3030);
            color: var(--mgr-accent, #7a3030);
        }

            .mgr-action-btn.btn-outline-primary:hover {
                background: var(--mgr-accent, #7a3030);
                color: #fff;
            }
</style>

<div class="mgr-page-header">
    <h2 class="mgr-page-title">Orders</h2>
    <a asp-action="CreateOrder" class="btn mgr-btn-primary">
        <i class="bi bi-plus-circle"></i> Create Order
    </a>
</div>

@if (!orders.Any())
{
    <div class="alert alert-info">No orders found. Create one to get started.</div>
}
else
{
    <table class="table table-hover mgr-table">
        <thead>
            <tr>
                <th>Order ID</th>
                <th>Consumable</th>
                <th>Supplier</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in orders)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.Consumable</td>
                    <td>@order.Supplier</td>
                    <td class="text-center">
                        <a asp-action="OrderDetails" asp-route-id="@order.Id"
                           class="btn btn-sm btn-outline-primary mgr-action-btn">Details</a>
                        <a asp-action="EditOrder" asp-route-id="@order.Id"
                           class="btn btn-sm btn-outline-secondary mgr-action-btn">Edit</a>
                        <a asp-action="DeleteOrder" asp-route-id="@order.Id"
                           class="btn btn-sm btn-outline-danger mgr-action-btn">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

