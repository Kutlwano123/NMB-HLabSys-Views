@{
    ViewData["Title"] = "Create Order";
    Layout = "~/Views/Shared/_ManagersLayout.cshtml";
    var order = new { OrderNumber = "", OrderItem = "", Supplier = "", Status = "Pending" };
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Create New Order</h5>
            </div>
            <div class="card-body">
                <form asp-action="CreateOrder" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="OrderNumber" class="form-label">Order Number</label>
                        <input type="text" class="form-control" id="OrderNumber" name="OrderNumber" value="@order.OrderNumber" required />
                    </div>
                    <div class="mb-3">
                        <label for="OrderItem" class="form-label">Order Item</label>
                        <input type="text" class="form-control" id="OrderItem" name="OrderItem" value="@order.OrderItem" required />
                    </div>
                    <div class="mb-3">
                        <label for="Supplier" class="form-label">Supplier</label>
                        <input type="text" class="form-control" id="Supplier" name="Supplier" value="@order.Supplier" required />
                    </div>
                    <div class="mb-3">
                        <label for="Status" class="form-label">Status</label>
                        <select class="form-select" id="Status" name="Status">
                            <option value="Pending" selected>Pending</option>
                            <option value="Ordered">Ordered</option>
                            <option value="Received">Received</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>
                    <div class="d-flex justify-content-between">
                        <a asp-controller="LabManager" asp-action="Orders" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Create Order</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>