<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — NMB H-Lab Manager</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    <style>
            :root {
                --mgr-bg: #f4f2ef;
                --mgr-surface: #faf9f7;
                --mgr-border: #ddd9d2;
                --mgr-accent: #7a3030;
                --mgr-accent-2: #9a4040;
                --mgr-accent-pale: #f0e8e8;
                --mgr-text-dark: #1e2420;
                --mgr-text-mid: #4a5248;
                --mgr-text-light: #7a857a;
            }

            html, body {
                height: 100%;
                margin: 0;
            }

            .mgr-shell {
                display: flex;
                height: 100vh;
                overflow: hidden;
                font-family: system-ui, sans-serif;
            }

            .mgr-shell.sidebar-collapsed .mgr-sidebar {
                transform: translateX(-100%);
            }

            .mgr-shell.sidebar-collapsed .mgr-main {
                margin-left: 0;
            }

            /* ── Sidebar ─────────────────────────────── */
            .mgr-sidebar {
                width: 230px;
                flex-shrink: 0;
                background: var(--mgr-surface);
                border-right: 1px solid var(--mgr-border);
                display: flex;
                flex-direction: column;
                overflow-y: auto;
                transition: transform 0.2s ease;
            }

            .sidebar-brand {
                padding: 1.25rem 1.25rem 1rem;
                border-bottom: 1px solid var(--mgr-border);
            }

                .sidebar-brand .lab-tag {
                    font-size: 11px;
                    font-weight: 600;
                    letter-spacing: 0.1em;
                    text-transform: uppercase;
                    color: var(--mgr-text-light);
                }

                .sidebar-brand .lab-name {
                    font-size: 16px;
                    font-weight: 600;
                    color: var(--mgr-text-dark);
                    margin-top: 2px;
                }

            .nav-section-label {
                padding: 1rem 1rem 0.25rem;
                font-size: 10px;
                font-weight: 600;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--mgr-text-light);
            }

            .mgr-nav-link {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 8px 1rem;
                margin: 1px 0.5rem;
                border-radius: 8px;
                font-size: 14px;
                color: var(--mgr-text-mid);
                text-decoration: none;
                transition: background 0.15s;
            }

                .mgr-nav-link:hover {
                    background: var(--mgr-bg);
                    color: var(--mgr-text-dark);
                }

                .mgr-nav-link.active {
                    background: var(--mgr-accent-pale);
                    color: var(--mgr-accent);
                    font-weight: 500;
                }

                .mgr-nav-link .bi {
                    font-size: 16px;
                }

            .nav-count-badge {
                margin-left: auto;
                background: var(--mgr-accent-pale);
                color: var(--mgr-accent);
                font-size: 11px;
                font-weight: 600;
                padding: 1px 7px;
                border-radius: 20px;
            }

            .sidebar-footer {
                margin-top: auto;
                padding: 1rem;
                border-top: 1px solid var(--mgr-border);
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .user-avatar {
                width: 34px;
                height: 34px;
                border-radius: 50%;
                background: var(--mgr-accent-pale);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 12px;
                font-weight: 600;
                color: var(--mgr-accent);
                flex-shrink: 0;
            }

            .user-name {
                font-size: 13px;
                font-weight: 500;
                color: var(--mgr-text-dark);
            }

            .user-role {
                font-size: 11px;
                color: var(--mgr-text-light);
            }

            /* ── Main area ───────────────────────────── */
            .mgr-main {
                flex: 1;
                display: flex;
                flex-direction: column;
                overflow: hidden;
                background: var(--mgr-bg);
                margin-left: 0;
                transition: margin-left 0.2s ease;
            }

            .mgr-topbar {
                background: var(--mgr-surface);
                border-bottom: 1px solid var(--mgr-border);
                padding: 0.75rem 1.5rem;
                display: flex;
                align-items: center;
                gap: 1rem;
                flex-shrink: 0;
            }

            .sidebar-toggle {
                border: none;
                background: #f8f9fa;
                color: #212529;
                width: 36px;
                height: 36px;
                border-radius: 8px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }

            .sidebar-toggle:hover {
                background: #e9ecef;
            }


            @@media (max-width: 992px) {
                .mgr-shell {
                    position: relative;
                }

                .mgr-sidebar {
                    position: fixed;
                    top: 0;
                    left: 0;
                    height: 100vh;
                    z-index: 1000;
                }

                .mgr-shell.sidebar-collapsed .mgr-sidebar {
                    transform: translateX(-100%);
                }
            }

            .topbar-breadcrumb {
                font-size: 13px;
                color: var(--mgr-text-light);
            }

                .topbar-breadcrumb .current {
                    color: var(--mgr-text-dark);
                    font-weight: 500;
                }

            .topbar-spacer {
                flex: 1;
            }

            .mgr-content {
                flex: 1;
                overflow-y: auto;
                padding: 1.5rem;
            }

            .mgr-content .form-label {
                color: var(--mgr-text-dark);
            }

            .mgr-content .form-check-label {
                color: var(--mgr-text-dark);
            }

            /* ── Global alerts ───────────────────────── */
            .alert {
                border-radius: 10px;
                font-size: 14px;
            }
    </style>
</head>
<body>
    @{
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    }
    <div class="mgr-shell">

        @* ── Sidebar ──────────────────────────────────────────────────────── *@
        <aside class="mgr-sidebar">
            <div class="sidebar-brand">
                <div class="lab-tag">NMB H-Lab</div>
                <div class="lab-name">Manager Portal</div>
            </div>

            <div class="nav-section-label">Overview</div>
            <a asp-controller="LabManager" asp-action="Dashboard"
               class="mgr-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="bi bi-grid-1x2"></i> Dashboard
            </a>

            <div class="nav-section-label">Test Management</div>
            <a asp-controller="LabManager" asp-action="Index"
               class="mgr-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <i class="bi bi-tags"></i> Test Categories
            </a>
            <a asp-controller="LabManager" asp-action="TestTypes"
               class="mgr-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "TestTypes" ? "active" : "")">
                <i class="bi bi-eyedropper"></i> Test Types
            </a>
            <a asp-controller="LabManager" asp-action="SampleTypes"
               class="mgr-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "SampleTypes" ? "active" : "")">
                <i class="bi bi-droplet-half"></i> Sample Types
            </a>

            <div class="nav-section-label">Consumables</div>
            <a asp-controller="LabManager" asp-action="Consumables"
               class="mgr-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Consumables" ? "active" : "")">
                <i class="bi bi-box-seam"></i> Consumables
            </a>
            <a asp-controller="LabManager" asp-action="Suppliers"
               class="mgr-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Suppliers" ? "active" : "")">
                <i class="bi bi-shop"></i> Suppliers
            </a>

            <a asp-controller="LabManager" asp-action="Orders"
               class="mgr-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Orders" ? "active" : "")">
                <i class="bi bi-truck"></i> Orders
                @if (ViewBag.ActiveOrderCount != null && (int)ViewBag.ActiveOrderCount > 0)
                {
                    <span class="nav-count-badge">@ViewBag.ActiveOrderCount</span>
                }
            </a>

            <div class="nav-section-label">Users</div>
            <a asp-controller="LabManager" asp-action="Doctors"
               class="mgr-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Doctors" ? "active" : "")">
                <i class="bi bi-person-vcard"></i> Doctors
            </a>
            <a asp-controller="LabManager" asp-action="LabTechnicians"
               class="mgr-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "LabTechnicians" ? "active" : "")">
                <i class="bi bi-person-badge"></i> Lab Technicians
            </a>

            <div class="nav-section-label">Reports</div>
            <a asp-controller="LabManager" asp-action="Reports"
               class="mgr-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Reports" ? "active" : "")">
                <i class="bi bi-file-earmark-bar-graph"></i> Generate Reports
            </a>

            <div class="sidebar-footer">
                <div class="user-avatar">KM</div>
                <div>
                    <div class="user-name">Kutlwano Modise</div>
                    <div class="user-role">Lab Manager</div>
                </div>
            </div>
        </aside>

        @* ── Main ─────────────────────────────────────────────────────────── *@
        <div class="mgr-main">
            <div class="mgr-topbar">
                <button type="button" class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
                    <i class="bi bi-list"></i>
                </button>
                <nav class="topbar-breadcrumb" aria-label="breadcrumb">
                    <a asp-controller="LabManager" asp-action="Dashboard"
                       style="color:inherit;text-decoration:none">Home</a>
                    @if (ViewData["Title"]?.ToString() != "Dashboard")
                    {
                        <span> / </span>
                        <span class="current">@ViewData["Title"]</span>
                    }
                </nav>
                <div class="topbar-spacer"></div>
                <a asp-controller="LabManager" asp-action="Profile"
                   class="btn btn-sm btn-outline-secondary me-2" title="My Profile">
                    <i class="bi bi-person"></i>
                </a>
                <form asp-controller="Home" asp-action="Index" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-box-arrow-right"></i> Sign out
                    </button>
                </form>
            </div>

            <div class="mgr-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </div>
        </div>

    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const managerShell = document.querySelector('.mgr-shell');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const toggleSidebar = () => {
            managerShell.classList.toggle('sidebar-collapsed');
        };

        sidebarToggle?.addEventListener('click', toggleSidebar);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
