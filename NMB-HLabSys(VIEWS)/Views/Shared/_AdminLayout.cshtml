<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NMB-HLabSys Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" />

    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;600&display=swap"
          rel="stylesheet">

    <style>

            :root {
                --accent: #7a3030;
                --accent-pale: #f8ecec;
                --surface: #ffffff;
                --bg: #f7f8fa;
                --border: #e8e8e8;
                --text-dark: #1f2937;
                --text-mid: #6b7280;
                --text-light: #9ca3af;
            }

            body {
                margin: 0;
                background: var(--bg);
                font-family: 'DM Sans', sans-serif;
                color: var(--text-dark);
            }

            /* ───────────────── SIDEBAR ───────────────── */

            .sidebar {
                height: 100vh;
                position: fixed;
                top: 0;
                left: 0;
                width: 240px;
                background: var(--surface);
                border-right: 1px solid var(--border);
                display: flex;
                flex-direction: column;
                transition: width 0.3s ease;
                z-index: 100;
                overflow: hidden;
            }

                .sidebar.collapsed {
                    width: 64px;
                }

            .sidebar-brand {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 18px 20px 12px;
                border-bottom: 1px solid var(--border);
                text-decoration: none;
            }

            .brand-icon {
                width: 36px;
                height: 36px;
                background: var(--accent);
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }

                .brand-icon i {
                    color: #fff;
                    font-size: 16px;
                }

            .brand-text {
                font-family: 'DM Serif Display', serif;
                font-size: 15px;
                color: var(--text-dark);
                white-space: nowrap;
                overflow: hidden;
            }

                .brand-text span {
                    color: var(--accent);
                }

            .sidebar-toggle {
                background: none;
                border: none;
                padding: 10px 20px;
                color: var(--text-mid);
                cursor: pointer;
                display: flex;
                align-items: center;
                gap: 8px;
                font-size: 13px;
                font-family: 'DM Sans', sans-serif;
                transition: color 0.2s;
                text-align: left;
            }

                .sidebar-toggle:hover {
                    color: var(--accent);
                }

            .sidebar-label {
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 0.8px;
                text-transform: uppercase;
                color: var(--text-light);
                padding: 12px 20px 4px;
                white-space: nowrap;
                overflow: hidden;
            }

            .sidebar.collapsed .sidebar-label {
                opacity: 0;
            }

            .sidebar-nav {
                flex: 1;
                overflow-y: auto;
                padding-bottom: 12px;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 10px 20px;
                color: var(--text-mid);
                text-decoration: none;
                font-size: 14px;
                font-weight: 500;
                transition: background 0.2s, color 0.2s;
                white-space: nowrap;
                overflow: hidden;
                border-left: 3px solid transparent;
            }

                .sidebar-link i {
                    font-size: 16px;
                    flex-shrink: 0;
                }

                .sidebar-link:hover {
                    background: var(--accent-pale);
                    color: var(--accent);
                    border-left-color: var(--accent);
                }

                .sidebar-link.active {
                    background: var(--accent-pale);
                    color: var(--accent);
                    border-left-color: var(--accent);
                    font-weight: 600;
                }

            .sidebar.collapsed .link-text {
                display: none;
            }

            .sidebar.collapsed .sidebar-link {
                justify-content: center;
                padding: 12px;
                border-left: none;
            }

            .sidebar.collapsed .sidebar-toggle {
                justify-content: center;
                padding: 12px;
            }

            /* ───────────────── USER ───────────────── */

            .sidebar-user {
                border-top: 1px solid var(--border);
                padding: 14px 20px;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .user-avatar {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                background: var(--accent);
                color: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 13px;
                font-weight: 700;
                flex-shrink: 0;
            }

            .user-info {
                overflow: hidden;
            }

            .user-name {
                font-size: 13px;
                font-weight: 600;
                color: var(--text-dark);
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .user-role {
                font-size: 11px;
                color: var(--text-light);
            }

            .sidebar.collapsed .user-info {
                display: none;
            }

            .sidebar.collapsed .sidebar-user {
                justify-content: center;
                padding: 12px;
            }

            /* ───────────────── MAIN CONTENT ───────────────── */

            .main-content {
                margin-left: 240px;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                transition: margin-left 0.3s ease;
            }

                .main-content.collapsed {
                    margin-left: 64px;
                }

            /* ───────────────── TOP NAV ───────────────── */

            .topnav {
                background: var(--surface);
                border-bottom: 1px solid var(--border);
                padding: 12px 28px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                position: sticky;
                top: 0;
                z-index: 50;
            }

            .topnav-title {
                font-family: 'DM Serif Display', serif;
                font-size: 18px;
                color: var(--text-dark);
            }

            .topnav-right {
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .topnav-icon-btn {
                width: 36px;
                height: 36px;
                border-radius: 8px;
                border: 1px solid var(--border);
                background: var(--bg);
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--text-mid);
                cursor: pointer;
                transition: all 0.2s;
                text-decoration: none;
                font-size: 14px;
                position: relative;
            }

                .topnav-icon-btn:hover {
                    border-color: var(--accent);
                    color: var(--accent);
                    background: var(--accent-pale);
                }

            .notif-dot {
                width: 8px;
                height: 8px;
                background: var(--accent);
                border-radius: 50%;
                position: absolute;
                top: 6px;
                right: 6px;
            }

            .logout-btn {
                display: flex;
                align-items: center;
                gap: 6px;
                padding: 8px 16px;
                background: var(--accent-pale);
                color: var(--accent);
                border: 1px solid rgba(122,48,48,0.2);
                border-radius: 8px;
                font-size: 13px;
                font-weight: 600;
                font-family: 'DM Sans', sans-serif;
                cursor: pointer;
                transition: all 0.2s;
            }

                .logout-btn:hover {
                    background: var(--accent);
                    color: #fff;
                }

            /* ───────────────── PAGE BODY ───────────────── */

            .page-body {
                padding: 28px;
                flex: 1;
            }

            /* ───────────────── LOGOUT MODAL ───────────────── */

            .logout-modal {
                display: none;
                position: fixed;
                inset: 0;
                z-index: 99999;
                background: rgba(0,0,0,0.45);
                backdrop-filter: blur(4px);
                justify-content: center;
                align-items: center;
                padding: 20px;
            }

            .logout-modal-content {
                background: white;
                width: 100%;
                max-width: 420px;
                border-radius: 18px;
                padding: 30px;
                text-align: center;
                animation: modalFade .25s ease;
                box-shadow: 0 20px 50px rgba(0,0,0,0.15);
            }

            .logout-icon {
                width: 75px;
                height: 75px;
                margin: 0 auto 18px;
                border-radius: 50%;
                background: var(--accent-pale);
                display: flex;
                align-items: center;
                justify-content: center;
            }

                .logout-icon i {
                    font-size: 32px;
                    color: var(--accent);
                }

            .logout-modal-content h3 {
                margin-bottom: 8px;
            }

            .logout-modal-content p {
                color: var(--text-mid);
                font-size: 13px;
                margin-bottom: 24px;
            }

            .logout-actions {
                display: flex;
                gap: 12px;
            }

                .logout-actions button {
                    width: 100%;
                    border: none;
                    border-radius: 10px;
                    padding: 12px;
                    cursor: pointer;
                    font-weight: 600;
                    transition: 0.2s ease;
                }

            .btn-cancel {
                background: #ececec;
            }

            .btn-confirm-logout {
                background: var(--accent);
                color: white;
            }

                .btn-confirm-logout:hover {
                    opacity: 0.92;
                }

            @@keyframes modalFade {

                from {
                    opacity: 0;
                    transform: scale(.94);
                }

                to {
                    opacity: 1;
                    transform: scale(1);
                }
            }

            /* ───────────────── RESPONSIVE ───────────────── */

            @@media (max-width: 768px) {

                .sidebar {
                    width: 64px;
                }

                    .sidebar .link-text,
                    .sidebar .sidebar-label,
                    .sidebar .user-info,
                    .sidebar .brand-text {
                        display: none;
                    }

                .sidebar-link {
                    justify-content: center;
                    padding: 12px;
                }

                .sidebar-toggle {
                    justify-content: center;
                    padding: 12px;
                }

                .sidebar-user {
                    justify-content: center;
                    padding: 12px;
                }

                .main-content {
                    margin-left: 64px;
                }
            }

    </style>

    @RenderSection("Styles", required: false)

</head>

<body>

    <!-- ───────────────── SIDEBAR ───────────────── -->

    <div class="sidebar" id="sidebar">

        <a class="sidebar-brand" href="/Admin/Dashboard">

            <div class="brand-icon">
                <i class="bi bi-flask"></i>
            </div>

            <span class="brand-text">
                NMB-<span>HLab</span>Sys
            </span>

        </a>

        <button class="sidebar-toggle" onclick="toggleSidebar()">

            <i class="bi bi-layout-sidebar"></i>

            <span class="link-text" style="font-size:12px;">
                Collapse
            </span>

        </button>

        <div class="sidebar-nav">

            <div class="sidebar-label">Main</div>

            <a href="/Admin/Dashboard"
               class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")">

                <i class="bi bi-speedometer2"></i>

                <span class="link-text">Dashboard</span>

            </a>

            <div class="sidebar-label">User Management</div>

            <a href="/Admin/Users"
               class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Users" ? "active" : "")">

                <i class="bi bi-people"></i>

                <span class="link-text">All Users</span>

            </a>

            <div class="sidebar-label">Lab Management</div>

            <a href="/Admin/TestCategories"
               class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "TestCategories" ? "active" : "")">

                <i class="bi bi-tags"></i>

                <span class="link-text">Test Categories</span>

            </a>

            <a href="/Admin/TestTypes"
               class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "TestTypes" ? "active" : "")">

                <i class="bi bi-flask"></i>

                <span class="link-text">Test Types</span>

            </a>

            <div class="sidebar-label">Medical Reference</div>

            <a href="/Admin/Medications"
               class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Medications" ? "active" : "")">

                <i class="bi bi-capsule"></i>

                <span class="link-text">Medications</span>

            </a>

            <a href="/Admin/Conditions"
               class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Conditions" ? "active" : "")">

                <i class="bi bi-heart-pulse"></i>

                <span class="link-text">Conditions</span>

            </a>

            <a href="/Admin/Allergies"
               class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Allergies" ? "active" : "")">

                <i class="bi bi-exclamation-triangle"></i>

                <span class="link-text">Allergies</span>

            </a>

            <div class="sidebar-label">System</div>

            <a href="/Admin/Reports"
               class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Reports" ? "active" : "")">

                <i class="bi bi-bar-chart-line"></i>

                <span class="link-text">Reports</span>

            </a>

            <a href="/Admin/AuditLog"
               class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "AuditLog" ? "active" : "")">

                <i class="bi bi-journal-text"></i>

                <span class="link-text">Audit Log</span>

            </a>

        </div>

        <!-- USER SECTION -->
        @{
            var adminName = "System Admin";
            var initials = "SA";
        }

        <div class="sidebar-user">

            <div class="user-avatar">
                @initials
            </div>

            <div class="user-info">

                <div class="user-name">
                    @adminName
                </div>

                <div class="user-role">
                    Administrator
                </div>

            </div>

        </div>

    </div>

    <!-- ───────────────── MAIN CONTENT ───────────────── -->

    <div class="main-content" id="main-content">

        <!-- TOP NAV -->

        <div class="topnav">

            <span class="topnav-title">
                @ViewData["Title"]
            </span>

            <div class="topnav-right">

                <a href="/Admin/Notifications"
                   class="topnav-icon-btn"
                   title="Notifications">

                    <i class="bi bi-bell"></i>

                    <span class="notif-dot"></span>

                </a>

                <a href="/Admin/Settings"
                   class="topnav-icon-btn"
                   title="Settings">

                    <i class="bi bi-gear"></i>

                </a>

                <button type="button"
                        onclick="openLogoutModal()"
                        class="logout-btn">

                    <i class="bi bi-box-arrow-right"></i>

                    <span>Logout</span>

                </button>

            </div>

        </div>

        <!-- PAGE BODY -->

        <div class="page-body">

            @RenderBody()

        </div>

    </div>

    <!-- ───────────────── LOGOUT MODAL ───────────────── -->

    <div id="logoutModal" class="logout-modal">

        <div class="logout-modal-content">

            <div class="logout-icon">

                <i class="bi bi-box-arrow-right"></i>

            </div>

            <h3>Confirm Logout</h3>

            <p>
                Are you sure you want to logout from the administrator dashboard?
            </p>

            <div class="logout-actions">

                <button type="button"
                        class="btn-cancel"
                        onclick="closeLogoutModal()">

                    Cancel

                </button>

                <a href="/Home/Index"
                   style="flex:1; text-decoration:none;">

                    <button type="button"
                            class="btn-confirm-logout">

                        <i class="bi bi-box-arrow-right"></i>

                        Logout

                    </button>

                </a>

            </div>

        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        function toggleSidebar() {

        const sidebar = document.getElementById('sidebar');

        const main = document.getElementById('main-content');

        sidebar.classList.toggle('collapsed');

        main.classList.toggle('collapsed');

        localStorage.setItem(
        'sidebarCollapsed',
        sidebar.classList.contains('collapsed')
        );
        }

        // PERSIST SIDEBAR STATE

        window.addEventListener('DOMContentLoaded', () => {

        if (localStorage.getItem('sidebarCollapsed') === 'true') {

        document.getElementById('sidebar').classList.add('collapsed');

        document.getElementById('main-content').classList.add('collapsed');
        }
        });

        // OPEN LOGOUT MODAL

        function openLogoutModal() {

        document.getElementById("logoutModal").style.display = "flex";
        }

        // CLOSE LOGOUT MODAL

        function closeLogoutModal() {

        document.getElementById("logoutModal").style.display = "none";
        }

        // CLOSE WHEN CLICKING OUTSIDE

        window.addEventListener("click", function (e) {

        const modal = document.getElementById("logoutModal");

        if (e.target === modal) {

        closeLogoutModal();
        }
        });

    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>