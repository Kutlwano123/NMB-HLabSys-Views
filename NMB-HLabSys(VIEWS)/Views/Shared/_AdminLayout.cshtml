<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NMB-HLabSys Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" />

    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;600&display=swap"
          rel="stylesheet">

    <style>

        :root {
            --accent: #7a3030;
            --accent-pale: #f8ecec;
            --surface: #ffffff;
            --bg: #f7f8fa;
            --border: #e8e8e8;
            --text-dark: #1f2937;
            --text-mid: #6b7280;
            --text-light: #9ca3af;
        }

        body {
            margin: 0;
            background: var(--bg);
            font-family: 'DM Sans', sans-serif;
            color: var(--text-dark);
        }

        /* ================= SIDEBAR ================= */

        .sidebar {
            position: fixed;
            inset: 0 auto 0 0;
            width: 240px;
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            transition: 0.3s ease;
            overflow: hidden;
            z-index: 100;
        }

        .sidebar.collapsed {
            width: 70px;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 18px;
            border-bottom: 1px solid var(--border);
            text-decoration: none;
        }

        .brand-icon {
            width: 36px;
            height: 36px;
            background: var(--accent);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .brand-text {
            font-family: 'DM Serif Display', serif;
            white-space: nowrap;
        }

        .sidebar.collapsed .brand-text {
            display: none;
        }

        .sidebar-toggle {
            padding: 10px 18px;
            background: none;
            border: none;
            text-align: left;
            font-size: 13px;
            color: var(--text-mid);
            cursor: pointer;
        }

        .sidebar-toggle:hover {
            color: var(--accent);
        }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
        }

        .sidebar-label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--text-light);
            padding: 12px 18px 4px;
        }

        .sidebar.collapsed .sidebar-label {
            display: none;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 18px;
            text-decoration: none;
            color: var(--text-mid);
            border-left: 3px solid transparent;
        }

        .sidebar-link:hover {
            background: var(--accent-pale);
            color: var(--accent);
        }

        .sidebar-link.active {
            background: var(--accent-pale);
            color: var(--accent);
            border-left-color: var(--accent);
            font-weight: 600;
        }

        .sidebar.collapsed .link-text {
            display: none;
        }

        .sidebar-user {
            border-top: 1px solid var(--border);
            padding: 14px 18px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar.collapsed .user-info {
            display: none;
        }

        /* ================= MAIN ================= */

        .main-content {
            margin-left: 240px;
            transition: 0.3s ease;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .main-content.collapsed {
            margin-left: 70px;
        }

        /* ================= TOPBAR ================= */

        .topnav {
            position: sticky;
            top: 0;
            z-index: 50;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 12px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .topnav-title {
            font-family: 'DM Serif Display', serif;
            font-size: 18px;
        }

        .topnav-right {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .icon-btn {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: var(--bg);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            position: relative;
        }

        .icon-btn:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        .notif-dot {
            width: 8px;
            height: 8px;
            background: var(--accent);
            border-radius: 50%;
            position: absolute;
            top: 6px;
            right: 6px;
        }

        .logout-btn {
            background: var(--accent-pale);
            border: 1px solid rgba(122,48,48,0.2);
            color: var(--accent);
            padding: 8px 14px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
        }

        /* ================= BODY ================= */

        .page-body {
            padding: 24px;
            flex: 1;
        }

        /* ================= MODAL ================= */

        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.45);
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }

        .modal-box {
            background: white;
            padding: 24px;
            border-radius: 14px;
            width: 360px;
            text-align: center;
        }

    </style>

    @RenderSection("Styles", required: false)

</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar" id="sidebar">

        <a class="sidebar-brand" href="/Admin/Dashboard">
            <div class="brand-icon"><i class="bi bi-flask"></i></div>
            <span class="brand-text">NMB-HLabSys</span>
        </a>

        <button class="sidebar-toggle" onclick="toggleSidebar()">
            <i class="bi bi-layout-sidebar"></i>
            <span class="link-text">Collapse</span>
        </button>

        <div class="sidebar-nav">

            <div class="sidebar-label">Main</div>

            <a href="~/Admin/Dashboard" class="sidebar-link @(ViewData["ActivePage"]?.ToString()=="Dashboard"?"active":"")">
                <i class="bi bi-speedometer2"></i><span class="link-text">Dashboard</span>
            </a>

            <div class="sidebar-label">Users</div>

            <a href="~/Admin/Users" class="sidebar-link @(ViewData["ActivePage"]?.ToString()=="Users"?"active":"")">
                <i class="bi bi-people"></i><span class="link-text">Users</span>
            </a>

            

           

            

            <div class="sidebar-label">Medical Master Data</div>

            <a href="~/Admin/TestCategories" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "TestCategories" ? "active" : "")">
                <i class="bi bi-tags"></i><span class="link-text">Categories</span>
            </a>

            <a href="~/Admin/Medications" class="sidebar-link @(ViewData["ActivePage"]?.ToString()=="Medications"?"active":"")">
                <i class="bi bi-capsule"></i><span class="link-text">Medications</span>
            </a>

            <a href="~/Admin/Conditions" class="sidebar-link @(ViewData["ActivePage"]?.ToString()=="Conditions"?"active":"")">
                <i class="bi bi-heart-pulse"></i><span class="link-text">Conditions</span>
            </a>

            <a href="~/Admin/Allergies" class="sidebar-link @(ViewData["ActivePage"]?.ToString()=="Allergies"?"active":"")">
                <i class="bi bi-exclamation-triangle"></i><span class="link-text">Allergies</span>
            </a>

            <div class="sidebar-label">System</div>

            <a href="~/Admin/Reports" class="sidebar-link @(ViewData["ActivePage"]?.ToString()=="Reports"?"active":"")">
                <i class="bi bi-bar-chart"></i><span class="link-text">Reports</span>
            </a>
            <a href="~/Admin/AuditLog"
               class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "AuditLog" ? "active" : "")">
                <i class="bi bi-journal-text"></i>
                <span class="link-text">Audit Log</span>
			</a>
        </div>

        <div class="sidebar-user">
            <div class="user-avatar">SA</div>
            <div class="user-info">
                <div class="user-name">System Admin</div>
                <div class="user-role">Administrator</div>
            </div>
        </div>

    </div>

    <!-- MAIN -->
    <div class="main-content" id="main">

        <div class="topnav">

            <div class="topnav-title">@ViewData["Title"]</div>

            <div class="topnav-right">

                <a href="~/Admin/Notifications" class="icon-btn">
                    <i class="bi bi-bell"></i>
                    <span class="notif-dot"></span>
                </a>

                <a href="~/Admin/Settings" class="icon-btn">
                    <i class="bi bi-gear"></i>
                </a>

                <button class="logout-btn" onclick="openLogoutModal()">
                    Logout
                </button>

            </div>

        </div>

        <div class="page-body">
            @RenderBody()
        </div>

    </div>

    <!-- LOGOUT MODAL -->
    <div class="modal-overlay" id="logoutModal">

        <div class="modal-box">

            <h3>Confirm Logout</h3>
            <p style="color:var(--text-mid);font-size:13px;">
                Are you sure you want to logout?
            </p>

            <div style="display:flex;gap:10px;margin-top:20px;">

                <button onclick="closeLogoutModal()" style="flex:1;padding:10px;border:none;border-radius:8px;">
                    Cancel
                </button>

                <a href="~/Home/Index" style="flex:1;text-decoration:none;">
                    <button style="width:100%;padding:10px;background:var(--accent);color:white;border:none;border-radius:8px;">
                        Logout
                    </button>
                </a>

            </div>

        </div>

    </div>

    <script>

        function toggleSidebar() {
            document.getElementById("sidebar").classList.toggle("collapsed");
            document.getElementById("main").classList.toggle("collapsed");
        }

        function openLogoutModal() {
            document.getElementById("logoutModal").style.display = "flex";
        }

        function closeLogoutModal() {
            document.getElementById("logoutModal").style.display = "none";
        }

        window.onclick = function (e) {
            if (e.target.id === "logoutModal") closeLogoutModal();
        }

    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>